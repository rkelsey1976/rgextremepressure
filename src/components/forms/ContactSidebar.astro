---
// ContactSidebar.astro — Left-column editorial sidebar for contact page
// Direct lines, operational hours, trust credentials
// No Tailwind — vanilla CSS using design tokens
---

<aside class="contact-sidebar">
  {/* ── Direct Lines ── */}
  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Direct Line</span>
    <a href="tel:+447552060932" class="cs-value">07552 060932</a>
    <p class="cs-note">Available Mon–Fri, 08:00–18:00. Weekend site visits by arrangement.</p>
  </div>

  {/* ── Email ── */}
  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Email</span>
    <a href="mailto:james.aspectbuilds@gmail.com" class="cs-value cs-value--small">james.aspectbuilds@gmail.com</a>
  </div>

  {/* ── Office ── */}
  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Managing Director</span>
    <p class="cs-value cs-value--small">James Martin</p>
  </div>

  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Registered Office</span>
    <p class="cs-value cs-value--small cs-value--muted">
      Aspect Builds &amp; Maintenance Ltd<br/>
      Bath, Somerset<br/>
      United Kingdom
    </p>
  </div>

  {/* ── Operational Hours ── */}
  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Operational Hours</span>
    <div class="cs-hours">
      <div class="cs-hours-row"><span>Monday – Friday</span><span>08:00 – 18:00</span></div>
      <div class="cs-hours-row"><span>Saturday</span><span>By appointment</span></div>
      <div class="cs-hours-row"><span>Sunday</span><span>Closed</span></div>
    </div>
  </div>

  {/* ── Credentials ── */}
  <div class="cs-block">
    <span class="cs-rule"></span>
    <span class="t-label cs-label">Credentials</span>
    <ul class="cs-creds">
      <li>&#10003;&ensp;Registered Limited Company</li>
      <li>&#10003;&ensp;£10M Public &amp; Employer's Liability</li>
      <li>&#10003;&ensp;Fully Insured (AXA Verified)</li>
    </ul>
    <a
      href="https://www.trustatrader.com/traders/aspect-builds-maintenance-ltd-interior-refurbishment-bath-south"
      target="_blank"
      rel="noopener noreferrer"
      class="cs-trustatrader"
      aria-label="4.97 out of 5 from 12 reviews on TrustATrader"
    >
      <img src="/images/trustatrader-logo.svg" alt="TrustATrader Verified Member" width="64" height="64" loading="lazy" />
      <span class="cs-trustatrader__text">
        <strong>4.97 / 5</strong>
        <span>12 verified reviews</span>
      </span>
    </a>
    <ul class="cs-tt-checks">
      <li>&#10003;&ensp;Identification checked</li>
      <li>&#10003;&ensp;Company address verified</li>
      <li>&#10003;&ensp;Customer references checked</li>
      <li>&#10003;&ensp;Agreed to TrustATrader's high standards</li>
      <li>&#10003;&ensp;Agreed to complaints procedure</li>
    </ul>
  </div>
</aside>

<style>
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding-block: var(--space-xs);
  }

  .cs-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cs-rule {
    display: block;
    width: 32px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 0.25rem;
  }

  .cs-label {
    color: var(--accent);
  }

  .cs-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--chalk);
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: color 0.3s var(--ease-out-expo);
  }

  .cs-value:hover {
    color: var(--accent);
  }

  .cs-value--small {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.6;
  }

  .cs-value--muted {
    color: var(--concrete);
  }

  .cs-note {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
  }

  .cs-hours {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .cs-hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    color: var(--chalk);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(26, 35, 50, 0.08);
  }

  .cs-hours-row span:last-child {
    color: var(--concrete);
  }

  .cs-creds {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--chalk);
    line-height: 1.5;
  }

  .cs-creds li {
    position: relative;
    padding-left: 0;
  }

  .cs-tt-checks {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
    padding: 0.6rem 0.75rem;
    background: rgba(26,35,50,0.04);
    border-left: 2px solid var(--accent);
    list-style: none;
    margin: 0;
  }

  .cs-tt-checks li {
    font-size: 0.75rem;
    color: var(--concrete);
    line-height: 1.4;
  }

  .cs-trustatrader {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cs-trustatrader:hover { opacity: 0.8; }

  .cs-trustatrader__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .cs-trustatrader__text strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: var(--chalk);
  }

  .cs-trustatrader__text span {
    font-size: 0.75rem;
    color: var(--concrete);
  }

  @media (max-width: 768px) {
    .contact-sidebar {
      gap: var(--space-l);
    }
  }
</style>