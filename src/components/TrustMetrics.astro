---
// TrustMetrics.astro — Horizontal strip of big numbers + labels
// Dark background, Bebas for the values

interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<section class="trust-metrics">
  <div class="container">
    <div class="trust-metrics__grid">
      {metrics.map(m => (
        <div class="trust-metrics__item">
          <span class="trust-metrics__value">{m.value}</span>
          <span class="trust-metrics__label">{m.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-metrics {
    background: var(--navy);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .trust-metrics__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-xl);
    text-align: center;
  }

  .trust-metrics__item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .trust-metrics__value {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 1;
    text-transform: uppercase;
    color: var(--accent);
  }

  .trust-metrics__label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 640px) {
    .trust-metrics__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-l);
    }
  }
</style>