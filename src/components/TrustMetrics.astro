---
// TrustMetrics.astro — Trust strip with Google review badge and key credentials

interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics?: Metric[];
}

const { metrics } = Astro.props;
---

<section class="trust-strip">
  <div class="container">
    <div class="trust-strip__inner">

      <!-- Google Reviews badge -->
      <div class="trust-google">
        <svg class="trust-google__logo" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="trust-google__content">
          <div class="trust-google__stars">
            {[1,2,3,4,5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <span class="trust-google__count"><strong>111 reviews</strong> on Google</span>
        </div>
      </div>

      <div class="trust-divider"></div>

      <!-- Credentials -->
      <div class="trust-creds">
        <div class="trust-cred">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Fully Insured</span>
        </div>
        <div class="trust-cred">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          <span>10 Years Experience</span>
        </div>
        <div class="trust-cred">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Free Quotes</span>
        </div>
        <div class="trust-cred">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>Same-Week Bookings</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .trust-strip {
    background: #fff;
    border-bottom: 1px solid rgba(0,85,165,0.08);
    padding: 1rem 0;
  }

  .trust-strip__inner {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  /* Google badge */
  .trust-google {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .trust-google__logo {
    flex-shrink: 0;
  }

  .trust-google__content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .trust-google__stars {
    display: flex;
    gap: 1px;
  }

  .trust-google__count {
    font-size: 0.78rem;
    color: var(--concrete);
    white-space: nowrap;
  }

  .trust-google__count strong {
    color: var(--chalk);
    font-weight: 700;
  }

  .trust-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(0,85,165,0.1);
    flex-shrink: 0;
  }

  /* Credentials */
  .trust-creds {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    flex-wrap: wrap;
    flex: 1;
  }

  .trust-cred {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--chalk);
    white-space: nowrap;
  }

  .trust-cred svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .trust-strip__inner {
      gap: var(--space-m);
    }
    .trust-divider { display: none; }
    .trust-creds { gap: var(--space-m); }
    .trust-cred span { font-size: 0.8rem; }
  }

  @media (max-width: 480px) {
    .trust-creds {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
    }
  }
</style>
