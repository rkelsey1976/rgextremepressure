---
// TestimonialBlock.astro — Clean testimonial card with stars
// Stars at top, quote text, reviewer name

interface Props {
  quote: string;
  name: string;
  role?: string;
  location?: string;
  stars?: number;
  dark?: boolean;
}

const {
  quote,
  name,
  role,
  location,
  stars = 5,
  dark = false,
} = Astro.props;
---

<div class:list={['testimonial-card', dark && 'testimonial-card--dark']}>
  <div class="testimonial-card__top">
    {/* Star rating */}
    <span class="testimonial-card__stars" role="img" aria-label={`${stars} out of 5`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class:list={['testimonial-card__star', i < stars && 'testimonial-card__star--filled']} width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill={i < stars ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5"/>
      </svg>
    ))}
  </span>
  {dark && (
    <svg class="testimonial-card__google" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
  )}
  </div>

  <p class:list={['testimonial-card__quote', dark && 'testimonial-card__quote--dark']}>&ldquo;{quote}&rdquo;</p>

  <div class="testimonial-card__footer">
    <div class="testimonial-card__avatar">{name.charAt(0)}</div>
    <div class="testimonial-card__meta">
      <cite class:list={['testimonial-card__name', dark && 'testimonial-card__name--dark']}>{name}</cite>
      {(role || location) && (
        <span class:list={['testimonial-card__detail', dark && 'testimonial-card__detail--dark']}>
          {role && <>{role}</>}
          {role && location && <> &middot; </>}
          {location && <>{location}</>}
        </span>
      )}
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 8px;
    padding: var(--space-l);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .testimonial-card:hover {
    box-shadow: 0 8px 32px rgba(0, 85, 165, 0.08);
    transform: translateY(-2px);
  }

  .testimonial-card--dark {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .testimonial-card--dark:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .testimonial-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-m);
  }

  /* Star rating at top */
  .testimonial-card__stars {
    display: flex;
    gap: 0.15rem;
  }

  .testimonial-card__google {
    opacity: 0.8;
    flex-shrink: 0;
  }

  .testimonial-card__star {
    color: var(--accent);
    width: 16px;
    height: 16px;
  }

  .testimonial-card__star--filled {
    fill: var(--accent);
  }

  /* Quote text */
  .testimonial-card__quote {
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.75;
    color: var(--chalk);
    margin: 0;
    flex: 1;
  }

  .testimonial-card__quote--dark {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Footer */
  .testimonial-card__footer {
    margin-top: var(--space-l);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Avatar circle */
  .testimonial-card__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonial-card--dark .testimonial-card__avatar {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .testimonial-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .testimonial-card__name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-style: normal;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--chalk);
  }

  .testimonial-card__name--dark {
    color: #fff;
  }

  .testimonial-card__detail {
    font-size: 0.78rem;
    color: var(--concrete);
    font-weight: 400;
  }

  .testimonial-card__detail--dark {
    color: rgba(255, 255, 255, 0.5);
  }
</style>