---
import { srcset } from '../utils/srcset';

// Hero.astro — Modern, clean hero for RG Extreme Pressure
// Options: image-based hero with blue overlay, or clean no-image hero
// New: pill eyebrow badge, Montserrat h1, wave SVG divider

interface Props {
  image?: string;
  video?: string;
  overlay?: 'gradient' | 'blue';
  breadcrumb?: { label: string; href?: string }[];
  eyebrow?: string;
  heading: string;
  body: string;
  bodyMaxWidth?: number;
  cta?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  tags?: string[];
  meta?: { label: string; value: string }[];
  minHeight?: 'full' | 'compact';
  variant?: 'default' | 'dark';
}

const {
  image,
  video,
  overlay = 'blue',
  breadcrumb,
  eyebrow,
  heading,
  body,
  bodyMaxWidth = 52,
  cta,
  ctaSecondary,
  tags,
  meta,
  minHeight = 'full',
  variant = 'default',
} = Astro.props;

const heroSrcset = image ? srcset(image) : undefined;
const hasMedia = !!(image || video);
---

<section
  class:list={[
    'hero',
    minHeight === 'compact' ? 'hero--compact' : '',
    hasMedia ? 'hero--has-image' : '',
    variant === 'dark' ? 'hero--dark' : '',
  ]}
  id="hero"
>
  <div class="hero__bg">
    {video && (
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/images/hero-home.webp"
        aria-hidden="true"
      >
        <source src={video} type="video/mp4" />
      </video>
    )}
    {!video && image && (
      <img
        class="hero__img"
        src={image}
        srcset={heroSrcset}
        sizes="100vw"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        decoding="async"
        loading="eager"
      />
    )}
    <div class="hero__overlay" data-overlay={overlay}></div>
  </div>

  <div class="container hero__content">
    {breadcrumb && (
      <nav class="hero__breadcrumb" aria-label="Breadcrumb">
        {breadcrumb.map((crumb, i) => (
          <>
            {i > 0 && <span>/</span>}
            {crumb.href ? (
              <a href={crumb.href}>{crumb.label}</a>
            ) : (
              <span>{crumb.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    {eyebrow && (
      <div class="hero__eyebrow">
        <span class="hero__eyebrow-pill">{eyebrow}</span>
      </div>
    )}

    {tags && tags.length > 0 && (
      <div class="hero__tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <h1 class="hero__headline" set:html={heading} />

    <p class="hero__sub" style={`max-width:${bodyMaxWidth}ch`}>
      {body}
    </p>

    {(cta || ctaSecondary) && (
      <div class="hero__actions">
        {cta && (
          <a href={cta.href} class="btn btn--primary">
            {cta.label}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn btn--outline">{ctaSecondary.label}</a>
        )}
      </div>
    )}

    {meta && meta.length > 0 && (
      <div class="hero__meta">
        {meta.map((item) => (
          <div class="hero__meta-item">
            <span class="t-label">{item.label}</span>
            <span>{item.value}</span>
          </div>
        ))}
      </div>
    )}
  </div>

</section>

<style>
  /* ── Hero shared styles ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--accent-light);
    padding-bottom: 0;
  }

  .hero--compact {
    min-height: 70svh;
  }

  /* ── No-image hero: light, clean ── */
  .hero:not(.hero--has-image) {
    background: var(--surface);
    align-items: center;
  }

  /* ── Dark variant ── */
  .hero--dark {
    background: var(--navy);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero:not(.hero--has-image) .hero__bg {
    display: none;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Blue overlay for image heroes ── */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero__overlay[data-overlay="blue"] {
    background: linear-gradient(135deg, rgba(0,85,165,0.88) 0%, rgba(0,61,122,0.75) 50%, rgba(0,61,122,0.5) 100%);
  }

  .hero__overlay[data-overlay="gradient"] {
    background: linear-gradient(to top, rgba(15,27,45,0.92) 0%, rgba(15,27,45,0.7) 40%, rgba(15,27,45,0.2) 100%);
  }

  /* Mobile: stronger overlay */
  @media (max-width: 768px) {
    .hero__overlay[data-overlay="blue"] {
      background: linear-gradient(to bottom, rgba(0,85,165,0.85) 0%, rgba(0,85,165,0.75) 60%, rgba(0,85,165,0.6) 100%);
    }
    .hero__overlay[data-overlay="gradient"] {
      background: linear-gradient(to bottom, rgba(15,27,45,0.88) 0%, rgba(15,27,45,0.7) 50%, rgba(15,27,45,0.3) 100%);
    }
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding-top: clamp(6rem, 10vw, 9rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    max-width: 66.666%;
    margin-inline: 0;
  }

  .hero__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    margin-bottom: var(--space-s);
  }

  /* Breadcrumb colours */
  .hero--has-image .hero__breadcrumb,
  .hero--dark .hero__breadcrumb {
    color: rgba(255, 255, 255, 0.65);
  }
  .hero:not(.hero--has-image):not(.hero--dark) .hero__breadcrumb {
    color: var(--concrete);
  }

  .hero__breadcrumb a {
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero--has-image .hero__breadcrumb a:hover,
  .hero--dark .hero__breadcrumb a:hover {
    color: #fff;
  }
  .hero:not(.hero--has-image):not(.hero--dark) .hero__breadcrumb a:hover {
    color: var(--accent);
  }

  /* ── Eyebrow pill badge ── */
  .hero__eyebrow {
    display: flex;
    align-items: center;
  }

  .hero__eyebrow-pill {
    display: inline-block;
    padding: 0.4rem 1.1rem;
    background: rgba(0,85,165,0.12);
    color: var(--accent);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 100px;
  }

  .hero--has-image .hero__eyebrow-pill,
  .hero--dark .hero__eyebrow-pill {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  /* Headline colour */
  .hero--has-image .hero__headline,
  .hero--dark .hero__headline {
    color: #fff;
  }
  .hero:not(.hero--has-image):not(.hero--dark) .hero__headline {
    color: var(--chalk);
  }

  .hero__sub {
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.75;
  }

  /* Sub colour */
  .hero--has-image .hero__sub {
    color: #fff;
  }
  .hero--dark .hero__sub {
    color: rgba(255, 255, 255, 0.7);
  }
  .hero:not(.hero--has-image):not(.hero--dark) .hero__sub {
    color: var(--concrete);
  }

  .hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-s);
  }

  .tag {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-top: var(--space-s);
  }

  /* ── Outline btn on image/dark hero stays white ── */
  .hero--has-image .btn--outline,
  .hero--dark .btn--outline {
    color: #fff;
    border-color: rgba(255,255,255,0.4);
  }
  .hero--has-image .btn--outline:hover,
  .hero--dark .btn--outline:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.1);
  }

  /* ── Outline btn on light hero uses accent ── */
  .hero:not(.hero--has-image):not(.hero--dark) .btn--outline {
    color: var(--accent);
    border-color: var(--accent);
  }
  .hero:not(.hero--has-image):not(.hero--dark) .btn--outline:hover {
    color: #fff;
    background: var(--accent);
  }

  .hero__meta {
    display: flex;
    gap: var(--space-l);
    flex-wrap: wrap;
    margin-top: var(--space-m);
    padding-top: var(--space-m);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero--has-image .hero__meta-item span:last-child,
  .hero--dark .hero__meta-item span:last-child {
    color: #fff;
  }
  .hero:not(.hero--has-image):not(.hero--dark) .hero__meta-item span:last-child {
    color: var(--chalk);
  }

  .hero__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (max-width: 768px) {
    .hero__content {
      padding-block: clamp(2rem, 4vw, 3rem);
      max-width: 100%;
    }
    .hero__actions {
      flex-direction: column;
    }
    .hero__headline {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>