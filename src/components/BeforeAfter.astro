---
// BeforeAfter.astro — Interactive drag-slider before/after comparison
// Two images overlaid, draggable divider reveals transform
// Vanilla CSS + JS, design-system tokens

interface Props {
  beforeSrc: string;
  afterSrc: string;
  beforeAlt?: string;
  afterAlt?: string;
  caption?: string;
}

const {
  beforeSrc,
  afterSrc,
  beforeAlt = 'Before',
  afterAlt = 'After',
  caption,
} = Astro.props;
---

<div class="ba" data-ba>
  <div class="ba__frame">
    {/* After image (full width, behind) */}
    <img class="ba__img ba__img--after" src={afterSrc} alt={afterAlt} loading="lazy" />
    {/* Before image (clipped by slider position) */}
    <div class="ba__before" data-ba-before>
      <img class="ba__img ba__img--before" src={beforeSrc} alt={beforeAlt} loading="lazy" />
    </div>
    {/* Divider handle */}
    <div class="ba__handle" data-ba-handle>
      <div class="ba__line"></div>
      <div class="ba__knob">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7 10H13M10 7L13 10L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="ba__knob-right">
          <path d="M13 10H7M10 13L7 10L10 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
  {caption && <p class="ba__caption">{caption}</p>}
  {/* Labels */}
  <span class="ba__label ba__label--before">Before</span>
  <span class="ba__label ba__label--after">After</span>
</div>

<style>
  .ba {
    position: relative;
    margin: 0;
  }

  .ba__frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--navy);
  }

  /* Base images — both fill the frame */
  .ba__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* After is always full width */
  .ba__img--after {
    position: relative;
    width: 100%;
  }

  /* Before is clipped via inline width on the wrapper */
  .ba__before {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 50%; /* default, overridden by JS */
    overflow: hidden;
    z-index: 2;
  }

  .ba__img--before {
    width: calc(100vw); /* will be set to frame width by JS */
    min-width: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Handle */
  .ba__handle {
    position: absolute;
    top: 0;
    left: 50%;
    width: 40px;
    height: 100%;
    transform: translateX(-50%);
    z-index: 3;
    cursor: ew-resize;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ba__line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 100%;
    background: #fff;
    box-shadow: 0 0 8px rgba(0,0,0,0.5);
  }

  .ba__knob {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    width: 40px;
    height: 40px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    z-index: 1;
    overflow: hidden;
  }

  .ba__knob svg {
    width: 20px;
    height: 20px;
    color: var(--chalk);
  }

  .ba__knob-right {
    position: absolute;
    right: 0;
  }

  /* Labels */
  .ba__label {
    position: absolute;
    bottom: var(--space-m);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    padding: 0.25rem 0.65rem;
    z-index: 4;
  }

  .ba__label--before {
    left: var(--space-m);
  }

  .ba__label--after {
    right: var(--space-m);
  }

  .ba__caption {
    font-size: 0.85rem;
    color: var(--concrete);
    margin-top: var(--space-s);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .ba__knob {
      width: 32px;
      height: 32px;
    }

    .ba__knob svg {
      width: 16px;
      height: 16px;
    }
  }
</style>

<script>
  function initBeforeAfter(container: HTMLElement) {
    const handle = container.querySelector('[data-ba-handle]') as HTMLElement;
    const before = container.querySelector('[data-ba-before]') as HTMLElement;
    const frame = container.querySelector('.ba__frame') as HTMLElement;
    const beforeImg = container.querySelector('.ba__img--before') as HTMLImageElement;

    if (!handle || !before || !frame) return;

    let isDragging = false;

    function setPosition(x: number) {
      const rect = frame.getBoundingClientRect();
      let pct = ((x - rect.left) / rect.width) * 100;
      pct = Math.max(2, Math.min(98, pct));
      before.style.width = `${pct}%`;
      handle.style.left = `${pct}%`;
    }

    handle.addEventListener('mousedown', () => { isDragging = true; });
    handle.addEventListener('touchstart', () => { isDragging = true; }, { passive: true });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      setPosition(e.clientX);
    });

    document.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      setPosition(e.touches[0].clientX);
    }, { passive: true });

    document.addEventListener('mouseup', () => { isDragging = false; });
    document.addEventListener('touchend', () => { isDragging = false; });

    // Set before image width to match frame
    function syncBeforeImgWidth() {
      beforeImg.style.width = `${frame.offsetWidth}px`;
    }
    syncBeforeImgWidth();
    window.addEventListener('resize', syncBeforeImgWidth);
  }

  document.querySelectorAll('[data-ba]').forEach(initBeforeAfter);
</script>