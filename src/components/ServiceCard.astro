---
interface Props {
  href: string;
  image: string;
  title: string;
  subtitle: string;
  description: string;
}

const { href, image, title, subtitle, description } = Astro.props;
---

<a href={href} class="service-card">
  <div class="service-card__img-wrap">
    <img src={image} alt={title} loading="lazy" decoding="async" />
  </div>
  <div class="service-card__body">
    <span class="service-card__subtitle">{subtitle}</span>
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__desc">{description}</p>
    <span class="service-card__link">
      View Service
      <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid rgba(0,85,165,0.08);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    box-shadow: 0 6px 24px rgba(0,85,165,0.12);
    transform: translateY(-3px);
  }

  .service-card__img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--accent-light);
  }

  .service-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
    display: block;
  }

  .service-card:hover .service-card__img-wrap img {
    transform: scale(1.04);
  }

  .service-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-m);
    flex: 1;
  }

  .service-card__subtitle {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--chalk);
    margin: 0;
  }

  .service-card__desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: var(--space-s);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .service-card:hover .service-card__link {
    gap: 0.65rem;
  }
</style>
