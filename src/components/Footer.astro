</footer>

<script>
  const accordions = document.querySelectorAll('.footer-accordion');
  const mql = window.matchMedia('(min-width: 769px)');

  function updateAccordionState() {
    accordions.forEach(btn => {
      const panel = btn.nextElementSibling;
      if (mql.matches) {
        // Desktop: force open, hide toggle icon
        btn.setAttribute('aria-expanded', 'true');
        panel.style.maxHeight = 'none';
        btn.classList.remove('is-collapsed');
      } else {
        // Mobile: respect current state
        const open = btn.getAttribute('aria-expanded') === 'true';
        panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '0';
      }
    });
  }

  accordions.forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const panel = btn.nextElementSibling;
      if (!expanded) {
        panel.style.maxHeight = panel.scrollHeight + 'px';
        btn.classList.remove('is-collapsed');
      } else {
        panel.style.maxHeight = '0';
        btn.classList.add('is-collapsed');
      }
    });
  });

  // On mobile, mark arrows as collapsed on load
  if (!mql.matches) {
    accordions.forEach(btn => btn.classList.add('is-collapsed'));
  }

  mql.addEventListener('change', updateAccordionState);
</script>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.5);
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(2rem, 4vw, 3rem);
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-col--brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .site-footer .ab-logo__name { color: #fff; }
  .site-footer .ab-logo__sub { color: rgba(255, 255, 255, 0.65); }
  .site-footer .ab-logo__mark { color: var(--accent); }

  .footer-about {
    max-width: 50ch;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: var(--space-s);
  }

  .footer-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    transition: background 0.2s, color 0.2s;
  }

  .footer-social__link:hover {
    background: var(--accent);
    color: #fff;
  }

  /* Accordion: looks like a normal heading on desktop, toggle on mobile */
  .footer-accordion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: default;
    margin-bottom: var(--space-m);
  }

  .footer-accordion__icon {
    display: none;
    color: rgba(255, 255, 255, 0.5);
    transition: transform 0.25s ease;
  }

  .footer-accordion__panel {
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .footer-heading--inner {
    margin-top: var(--space-l);
    margin-bottom: var(--space-m);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-contact {
    gap: 0.6rem;
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-contact svg {
    flex-shrink: 0;
    color: var(--accent);
  }

  .footer-contact a {
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-contact a:hover {
    color: var(--accent);
  }

  .footer-areas-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-m);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .footer-areas-link:hover {
    gap: 0.7rem;
  }

  .footer-bottom {
    padding-top: var(--space-m);
    margin-top: 0;
  }

  .footer-bottom__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-s);
  }

  .footer-bottom p {
    color: #8892A4;
    font-size: 0.8rem;
  }

  .footer-bottom__links {
    display: flex;
    gap: var(--space-m);
  }

  .footer-bottom__links a {
    color: #8892A4;
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom__links a:hover {
    color: var(--accent);
  }

  .footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding-left: var(--space-m);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-credit svg {
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-credit:hover svg {
    opacity: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding-bottom: 0;
    }

    .footer-col--brand {
      padding-bottom: var(--space-l);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .footer-col:not(.footer-col--brand) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* Panels closed by default — JS overrides inline when toggled */
    .footer-accordion__panel {
      max-height: 0;
    }

    /* Show accordion toggle */
    .footer-accordion {
      cursor: pointer;
      padding: var(--space-m) 0;
      margin-bottom: 0;
    }

    .footer-accordion__icon {
      display: block;
    }

    .footer-accordion.is-collapsed .footer-accordion__icon {
      transform: rotate(-90deg);
    }

    .footer-heading {
      font-size: 1rem;
    }

    .footer-heading--inner {
      margin-top: var(--space-m);
    }

    .footer-bottom__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>