---
// Footer.astro — Medium-dark blue footer for RG Extreme Pressure
// Desktop: 3-column grid. Mobile: accordion for Services & Contact.

const currentYear = new Date().getFullYear();

const serviceLinks = [
  { label: 'Driveway Cleaning Bath', href: '/driveway-cleaning-bath' },
  { label: 'Patio Cleaning Bath', href: '/patio-cleaning-bath' },
  { label: 'Gutter Cleaning Bath', href: '/gutter-cleaning-bath' },
  { label: 'Roof Cleaning Bath', href: '/roof-cleaning-bath' },
  { label: 'Render Cleaning Bath', href: '/render-cleaning-bath' },
];

const bristolLinks = [
  { label: 'Driveway Cleaning Bristol', href: '/driveway-cleaning-bristol' },
  { label: 'Patio Cleaning Bristol', href: '/patio-cleaning-bristol' },
  { label: 'Roof Cleaning Bristol', href: '/roof-cleaning-bristol' },
  { label: 'Gutter Cleaning Bristol', href: '/gutter-cleaning-bristol' },
  { label: 'Render Cleaning Bristol', href: '/render-cleaning-bristol' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Areas Covered', href: '/areas-covered' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
