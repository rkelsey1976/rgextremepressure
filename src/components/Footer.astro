---
// Footer.astro — Medium-dark blue footer for RG Extreme Pressure
// Desktop: 3-column grid. Mobile: accordion for Services & Contact.

const currentYear = new Date().getFullYear();

const serviceLinks = [
  { label: 'Driveway Cleaning', href: '/driveway-cleaning-bath' },
  { label: 'Patio Cleaning', href: '/patio-cleaning-bath' },
  { label: 'Gutter Cleaning', href: '/gutter-cleaning-bath' },
  { label: 'Roof Cleaning', href: '/roof-cleaning-bath' },
  { label: 'Render Cleaning', href: '/render-cleaning-bath' },
  { label: 'Block Paving Cleaning', href: '/block-paving-cleaning-bath' },
  { label: 'Soffit & Fascia Cleaning', href: '/soffit-fascia-cleaning-bath' },
  { label: 'Conservatory Cleaning', href: '/conservatory-cleaning-bath' },
  { label: 'Commercial Jet Washing', href: '/commercial-jet-washing-bath' },
];

const bristolLinks = [
  { label: 'Driveway Cleaning', href: '/driveway-cleaning-bristol' },
  { label: 'Patio Cleaning', href: '/patio-cleaning-bristol' },
  { label: 'Roof Cleaning', href: '/roof-cleaning-bristol' },
  { label: 'Gutter Cleaning', href: '/gutter-cleaning-bristol' },
  { label: 'Render Cleaning', href: '/render-cleaning-bristol' },
];

const areaLinks = [
  { label: 'Bath', href: '/areas-covered/bath' },
  { label: 'Bristol', href: '/bristol' },
  { label: 'Keynsham', href: '/areas-covered/keynsham' },
  { label: 'Radstock', href: '/areas-covered/radstock' },
  { label: 'Midsomer Norton', href: '/areas-covered/midsomer-norton' },
  { label: 'Frome', href: '/areas-covered/frome' },
  { label: 'View All Areas →', href: '/areas-covered' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Areas Covered', href: '/areas-covered' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Column 1: Logo — always visible, no accordion -->
      <div class="footer-col footer-col--brand">
        <a href="/" class="rg-logo nav-logo nav-logo--lg" aria-label="RG Extreme Pressure">
          <img src="/images/logo.webp" alt="" class="rg-logo__img" width="44" height="44" aria-hidden="true" />
          <span class="rg-logo__text">
            <span class="rg-logo__name">RG Extreme</span>
            <span class="rg-logo__tagline">Pressure</span>
            <span class="rg-logo__sub">Jet Washing Services</span>
          </span>
        </a>
        <p class="footer-about">Professional jet washing and pressure washing services in Bath and Bristol. Driveway cleaning, gutter clearing, roof cleaning, render cleaning and block paving.</p>

        <div class="footer-social">
          <a href="https://www.facebook.com/profile.php?id=100091066506303" aria-label="Facebook" class="footer-social__link" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>

          <a href="https://www.google.com/maps?q=RG+Extreme+Pressure+Bath" aria-label="Google Reviews" class="footer-social__link" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
          </a>
        </div>
      </div>

      <!-- Columns 2+3: Services — two columns on desktop, single accordion on mobile -->
      <div class="footer-col footer-col--services">
        <button class="footer-accordion" aria-expanded="false">
          <h3 class="footer-heading">Services</h3>
          <svg class="footer-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="footer-accordion__panel">
          <div class="footer-services-grid">
            <div>
              <p class="footer-services__city">Bath</p>
              <ul class="footer-links">
                {serviceLinks.map(link => (
                  <li><a href={link.href}>{link.label.replace(' Bath', '')}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <p class="footer-services__city">Bristol</p>
              <ul class="footer-links">
                {bristolLinks.map(link => (
                  <li><a href={link.href}>{link.label.replace(' Bristol', '')}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Column 4: Areas — accordion on mobile -->
      <div class="footer-col">
        <button class="footer-accordion" aria-expanded="false">
          <h3 class="footer-heading">Areas Covered</h3>
          <svg class="footer-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="footer-accordion__panel">
          <ul class="footer-links">
            {areaLinks.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Column 5: Company — accordion on mobile -->
      <div class="footer-col">
        <button class="footer-accordion" aria-expanded="false">
          <h3 class="footer-heading">Company</h3>
          <svg class="footer-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="footer-accordion__panel">
          <ul class="footer-links">
            {companyLinks.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Column 3: Contact — accordion on mobile -->
      <div class="footer-col">
        <button class="footer-accordion" aria-expanded="false">
          <h3 class="footer-heading">
            <svg class="footer-heading__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Get in touch
          </h3>
          <svg class="footer-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="footer-accordion__panel">
          <ul class="footer-links footer-contact">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Bath, Somerset
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:galazkarobert@yahoo.co.uk">galazkarobert@yahoo.co.uk</a>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:07474939398">07474 939 398</a>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Mon&ndash;Fri 8:00&ndash;17:00 &middot; Sat 9:00&ndash;15:00
            </li>
          </ul>

          <a href="/areas-covered" class="footer-areas-link">
            View all areas we cover
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="footer-bottom__inner">
        <p>&copy; {currentYear} RG Extreme Pressure. All rights reserved.</p>
        <div class="footer-bottom__links">
          <a href="/about">About</a>
          <a href="/blog">Blog</a>
          <a href="/privacy">Privacy</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="https://vortexdesignstudio.co.uk" target="_blank" rel="noopener noreferrer" class="footer-credit" aria-label="Website design by Vortex Design Studio">
            Website by Vortex Design Studio
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  const accordions = document.querySelectorAll('.footer-accordion');
  const mql = window.matchMedia('(min-width: 769px)');

  function updateAccordionState() {
    accordions.forEach(btn => {
      const panel = btn.nextElementSibling;
      if (mql.matches) {
        // Desktop: force open, hide toggle icon
        btn.setAttribute('aria-expanded', 'true');
        panel.style.maxHeight = 'none';
        btn.classList.remove('is-collapsed');
      } else {
        // Mobile: respect current state
        const open = btn.getAttribute('aria-expanded') === 'true';
        panel.style.maxHeight = open ? panel.scrollHeight + 'px' : '0';
      }
    });
  }

  accordions.forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const panel = btn.nextElementSibling;
      if (!expanded) {
        panel.style.maxHeight = panel.scrollHeight + 'px';
        btn.classList.remove('is-collapsed');
      } else {
        panel.style.maxHeight = '0';
        btn.classList.add('is-collapsed');
      }
    });
  });

  // On mobile, mark arrows as collapsed on load
  if (!mql.matches) {
    accordions.forEach(btn => btn.classList.add('is-collapsed'));
  }

  mql.addEventListener('change', updateAccordionState);
</script>

<style>
  /* ── Footer ── */
  .site-footer {
    background: var(--navy);
    border-top: 3px solid var(--cta);
    color: rgba(255,255,255,.8);
    padding: var(--space-3xl) 0 var(--space-m);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr 1fr 1fr 1.2fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-col--brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .site-footer .rg-logo__name { color: #fff; font-weight: 800; }
  .site-footer .rg-logo__tagline { color: var(--cta); }
  .site-footer .rg-logo__sub { color: rgba(255, 255, 255, 0.65); }
  .site-footer .rg-logo__img { border-radius: 6px; }

  .footer-about {
    max-width: 50ch;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: var(--space-s);
  }

  .footer-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    transition: background 0.2s, color 0.2s;
  }

  .footer-social__link:hover {
    background: var(--accent);
    color: #fff;
  }

  /* Accordion: looks like a normal heading on desktop, toggle on mobile */
  .footer-accordion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: default;
    margin-bottom: var(--space-m);
  }

  .footer-accordion__icon {
    display: none;
    color: rgba(255, 255, 255, 0.7);
    transition: transform 0.25s ease;
  }

  .footer-accordion__panel {
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-heading__icon {
    color: var(--cta);
    flex-shrink: 0;
  }

  .footer-services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
  }

  .footer-services__city {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cta);
    margin: 0 0 var(--space-s);
  }

  .footer-heading--inner {
    margin-top: var(--space-l);
    margin-bottom: var(--space-m);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-contact {
    gap: 0.6rem;
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-contact svg {
    flex-shrink: 0;
    color: var(--cta);
  }

  .footer-contact a {
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-contact a:hover {
    color: #fff;
  }

  .footer-areas-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-m);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    transition: gap 0.2s;
  }

  .footer-areas-link:hover {
    gap: 0.7rem;
  }

  .footer-bottom {
    padding-top: var(--space-m);
    margin-top: 0;
  }

  .footer-bottom__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-s);
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .footer-bottom__links {
    display: flex;
    gap: var(--space-m);
  }

  .footer-bottom__links a {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom__links a:hover {
    color: #fff;
  }

  .footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding-left: var(--space-m);
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-credit svg {
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-credit:hover svg {
    opacity: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
      padding-bottom: 0;
    }

    .footer-col--brand {
      padding-bottom: var(--space-l);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .footer-col:not(.footer-col--brand) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Panels closed by default — JS overrides inline when toggled */
    .footer-accordion__panel {
      max-height: 0;
    }

    /* Show accordion toggle */
    .footer-accordion {
      cursor: pointer;
      padding: var(--space-m) 0;
      margin-bottom: 0;
    }

    .footer-accordion__icon {
      display: block;
    }

    .footer-accordion.is-collapsed .footer-accordion__icon {
      transform: rotate(-90deg);
    }

    .footer-heading {
      font-size: 1rem;
    }

    .footer-heading--inner {
      margin-top: var(--space-m);
    }

    .footer-bottom__inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-bottom__links {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-s) var(--space-m);
    }

    .footer-bottom__links a {
      font-size: 0.85rem;
      padding: 0.25rem 0;
    }

    .footer-credit {
      border-left: none;
      padding-left: 0;
    }
  }
</style>