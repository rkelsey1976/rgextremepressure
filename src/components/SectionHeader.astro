---
// SectionHeader.astro — Reusable section intro block
// Blue pill eyebrow + Montserrat heading + optional body
// Used as the opening pattern for every content section beneath the hero

interface Props {
  eyebrow: string;
  heading: string;
  body?: string;
  align?: 'left' | 'center';
  dark?: boolean;
  id?: string;
}

const {
  eyebrow,
  heading,
  body,
  align = 'left',
  dark = false,
  id,
} = Astro.props;
---

<div class:list={['sh', `sh--${align}`, dark && 'sh--dark']} id={id}>
  <span class="sh__eyebrow-pill">{eyebrow}</span>
  <h2 class="sh__heading" set:html={heading} />
  {body && <p class:list={['sh__body', dark && 'sh__body--dark']}>{body}</p>}
</div>

<style>
  .sh {
    max-width: var(--text-max);
    padding-block: var(--space-2xl);
  }

  .sh--center {
    max-width: 72ch;
    margin-inline: auto;
    text-align: center;
  }

  /* ── Eyebrow pill ── */
  .sh__eyebrow-pill {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(0,85,165,0.1);
    color: var(--accent);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 100px;
    margin-bottom: var(--space-m);
  }

  .sh--center .sh__eyebrow-pill {
    margin-left: auto;
    margin-right: auto;
  }

  .sh--dark .sh__eyebrow-pill {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }

  /* ── Heading — Montserrat 800, mixed case ── */
  .sh__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    text-transform: none;
    color: var(--chalk);
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }

  .sh--dark .sh__heading {
    color: #fff;
  }

  /* Body text */
  .sh__body {
    font-size: clamp(1.05rem, 1.3vw, 1.25rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--concrete);
    margin-top: var(--space-m);
    margin-bottom: 0;
  }

  .sh__body--dark {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 768px) {
    .sh {
      padding-block: var(--space-l);
    }
  }
</style>