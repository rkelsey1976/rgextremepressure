---
// SectionHeader.astro — Reusable section intro block
// Gold eyebrow + Bebas heading + optional body
// Used as the opening pattern for every content section beneath the hero

interface Props {
  eyebrow: string;
  heading: string;
  body?: string;
  align?: 'left' | 'center';
  dark?: boolean;        // Set true when section bg is dark (#0A1628 / #141A24 / #1A2332)
  id?: string;            // Optional HTML id for anchor linking
}

const {
  eyebrow,
  heading,
  body,
  align = 'left',
  dark = false,
  id,
} = Astro.props;
---

<div class:list={['sh', `sh--${align}`, dark && 'sh--dark']} id={id}>
  <span class="sh__rule"></span>
  <span class="t-label" class:list={[dark && 'sh__label--dark']}>{eyebrow}</span>
  <h2 class="sh__heading" set:html={heading} />
  {body && <p class:list={['sh__body', dark && 'sh__body--dark']}>{body}</p>}
</div>

<style>
  .sh {
    max-width: var(--text-max);
    padding-block: var(--space-xl);
  }

  .sh--center {
    max-width: 72ch;
    margin-inline: auto;
    text-align: center;
  }

  .sh--center .sh__rule {
    margin-inline: auto;
  }

  /* Gold accent bar */
  .sh__rule {
    display: block;
    width: 40px;
    height: 2px;
    background: var(--accent);
    margin-bottom: var(--space-m);
  }

  /* Heading — uses t-heading token scale */
  .sh__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 4rem);
    line-height: 1;
    text-transform: uppercase;
    color: var(--chalk);
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }

  .sh--dark .sh__heading {
    color: #fff;
  }

  /* Body text */
  .sh__body {
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    font-weight: 300;
    line-height: 1.75;
    color: var(--concrete);
    margin-top: var(--space-m);
    margin-bottom: 0;
  }

  .sh__body--dark {
    color: rgba(255, 255, 255, 0.72);
  }

  /* Override t-label colour for dark context */
  :global(.sh--dark) .t-label {
    color: var(--accent) !important;
  }

  @media (max-width: 768px) {
    .sh {
      padding-block: var(--space-l);
    }
  }
</style>