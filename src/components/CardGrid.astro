---
import { srcset } from '../utils/srcset';

// CardGrid.astro — Responsive card grid for services, projects, locations
// Clean, minimal cards: image top, optional tag, title, short body, linked

interface Card {
  title: string;
  body?: string;
  image: string;
  href: string;
  tag?: string;
}

interface Props {
  cards: Card[];
  columns?: 2 | 3;
  style?: 'light' | 'dark';
}

const {
  cards,
  columns = 3,
  style = 'light',
} = Astro.props;

const isLight = style === 'light';
---

<div class:list={['card-grid', `card-grid--${columns}`, `card-grid--${style}`]}>
  {cards.map(card => (
    <a href={card.href} class="card">
      <div class="card__image-wrap">
        <img src={card.image} alt={card.title} class="card__image" loading="lazy" decoding="async" srcset={srcset(card.image)} sizes="(max-width: 768px) 50vw, 33vw" />
        {card.tag && <span class="card__tag">{card.tag}</span>}
      </div>
      <div class="card__content">
        <h3 class="card__title">{card.title}</h3>
        {card.body && <p class="card__body">{card.body}</p>}
        <span class="card__link">
          View project
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </a>
  ))}
</div>

<style>
  .card-grid {
    display: grid;
    gap: var(--space-l);
    padding-block: var(--section-pad);
  }

  .card-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .card-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  /* Card */
  .card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .card:hover {
    transform: translateY(-4px);
  }

  /* Image */
  .card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--stone);
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .card:hover .card__image {
    transform: scale(1.04);
  }

  /* Tag */
  .card__tag {
    position: absolute;
    top: var(--space-xs);
    left: var(--space-xs);
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(4px);
    padding: 0.25rem 0.6rem;
  }

  /* Content */
  .card__content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: var(--space-m);
    flex: 1;
  }

  .card__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.4rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
  }

  .card--dark .card__title {
    color: #fff;
  }

  .card__body {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card--dark .card__body {
    color: rgba(255, 255, 255, 0.6);
  }

  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: auto;
    padding-top: var(--space-s);
    transition: gap 0.2s var(--ease-out-expo);
  }

  .card:hover .card__link {
    gap: 0.6rem;
  }

  /* Mobile */
  @media (max-width: 1024px) {
    .card-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .card-grid--2,
    .card-grid--3 {
      grid-template-columns: 1fr;
    }

    .card:hover {
      transform: none;
    }
  }
</style>