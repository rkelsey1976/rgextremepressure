---
// ServiceDirectory.astro — SEO keyword matrix with tag/pill layout
const columns = [
  {
    title: 'Driveway Cleaning',
    items: ['Block Paving Deep Clean', 'Tarmac & Concrete Driveway Wash', 'Oil Stain & Tyre Mark Removal', 'Resin Drive Gentle Clean', 'Kiln-Dried Sand Re-Jointing', 'Driveway Sealing'],
  },
  {
    title: 'Patio & Outdoor Cleaning',
    items: ['Indian Sandstone Patio Cleaning', 'Porcelain & Slate Tile Washing', 'Concrete Slab & Flagstone Clean', 'Algae & Moss Treatment', 'Decking & Pathway Cleaning', 'Outdoor Surface Restoration'],
  },
  {
    title: 'Roof & Gutter Services',
    items: ['Soft Wash Roof Cleaning', 'Manual Moss Removal', 'Biocide Anti-Growth Treatment', 'Full Gutter Clear & Downpipe Flush', 'Soffit & Fascia Clean', 'Minor Gutter Repair & Reseal'],
  },
  {
    title: 'Render & Exterior Cleaning',
    items: ['K-Rend & Silicone Render Clean', 'Painted Exterior Wall Washing', 'Algae & Pollution Stain Removal', 'Pebbledash & Roughcast Clean', 'Block Paving Re-Sanding & Sealing', 'Brickwork & Stone Cleaning'],
  },
];
---

<section class="sdir">
  <div class="container">
    <div class="sdir__grid">
      {columns.map((col) => (
        <div class="sdir__col">
          <h4 class="sdir__title">{col.title}</h4>
          <div class="sdir__tags">
            {col.items.map((item) => (
              <span class="sdir__tag">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sdir {
    background: var(--surface);
    padding: var(--section-pad) 0;
  }

  .sdir__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .sdir__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .sdir__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.5rem);
    font-weight: 800;
    letter-spacing: 0;
    text-transform: none;
    color: var(--chalk);
    margin: 0;
    padding-bottom: var(--space-s);
    border-bottom: 2px solid var(--accent);
    display: inline-block;
    align-self: flex-start;
  }

  .sdir__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sdir__tag {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--accent-light);
    color: var(--accent);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    border-radius: 100px;
    line-height: 1.4;
  }

  @media (max-width: 960px) {
    .sdir__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .sdir__grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
</style>