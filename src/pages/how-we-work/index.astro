---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';

const steps = [
  {
    number: '01',
    title: 'Initial Consultation',
    body: 'James visits your property to understand the scope, discuss your vision, and assess any constraints — listed status, party walls, ground conditions. No charge, no obligation.',
  },
  {
    number: '02',
    title: 'Fixed-Price Quote',
    body: 'You receive a fully itemised quote with no hidden costs. Materials, labour, waste removal — everything is broken down so you know exactly what you\'re paying for.',
  },
  {
    number: '03',
    title: 'Scheduling & Preparation',
    body: 'Once you accept, we agree start dates and working hours. We organise materials, arrange skips, protect your property with dust sheets and floor coverings, and set up a clean, secure site.',
  },
  {
    number: '04',
    title: 'On-Site Works',
    body: 'Our skilled team carries out the work to the agreed standard. Daily tidy-ups, protected access routes, and transparent communication — you always know where things stand.',
  },
  {
    number: '05',
    title: 'Quality Check & Handover',
    body: 'Before we leave, James walks through the finished work with you. Any snags are dealt with immediately. We only sign off when you\'re fully satisfied.',
  },
  {
    number: '06',
    title: 'Aftercare',
    body: 'We don\'t disappear once the invoice is paid. If anything needs attention down the line, we come back. Our reputation depends on long-term client relationships, not one-off jobs.',
  },
];
---

<Base
  title="How We Work"
  description="Transparent pricing, clean sites, and a clear process from first visit to final handover. How Aspect Builds delivers every project across Bath & BANES."
  preloadImage="/images/hero-james-bath-property-5.webp"
>

  <Hero
    image="/images/hero-james-bath-property-5.webp"
    overlay="left"
    eyebrow="Our Process"
    heading="Six Steps.<br>Zero Surprises."
    body="Transparent pricing, clean sites, and a clear process from first visit to final handover."
    cta={{ label: 'Get a Quote', href: '/contact' }}
  />

  {/* ── Process Steps ── */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        label="Our Process"
        heading="Six Steps. Zero Surprises."
        body="Every project follows the same straightforward process — whether it's a single-room refresh or a full structural extension."
      />

      <div class="steps-grid">
        {steps.map(step => (
          <div class="step-card">
            <span class="step-card__number">{step.number}</span>
            <h3 class="step-card__title">{step.title}</h3>
            <p class="step-card__body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Principles ── */}
  <section class="principles-section">
    <div class="container">
      <SectionHeader
        label="What We Stand For"
        heading="Built on Trust"
        body="Four principles that govern every project we take on."
        dark={true}
      />

      <div class="principles-grid">
        <div class="principle">
          <span class="principle__rule"></span>
          <h3 class="principle__title">Fixed Quotes, Fixed Prices</h3>
          <p class="principle__body">What we quote is what you pay. No day rates, no open-ended estimates. If the spec changes, we re-quote before proceeding — never after.</p>
        </div>
        <div class="principle">
          <span class="principle__rule"></span>
          <h3 class="principle__title">Clean, Respectful Sites</h3>
          <p class="principle__body">Dust sheets, daily tidy-ups, protected access routes. Your home gets treated like our own. We leave it spotless at handover.</p>
        </div>
        <div class="principle">
          <span class="principle__rule"></span>
          <h3 class="principle__title">Skilled, Dependable People</h3>
          <p class="principle__body">Friendly, experienced tradespeople who turn up on time and work to a high standard. No subcontractor roulette — it's our team from start to finish.</p>
        </div>
        <div class="principle">
          <span class="principle__rule"></span>
          <h3 class="principle__title">Reputation Earned</h3>
          <p class="principle__body">Our business is built on repeat work and personal recommendations. That only happens when you deliver — and we do, every time.</p>
        </div>
      </div>
    </div>
  </section>

  <ImageCTA
    image="/images/hero-james-bath-property-3.webp"
    heading="Ready to Start?"
    body="Get a fixed, transparent quote from a local team that treats your home like their own."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
  />

</Base>

<style>
  /* ── Steps Grid ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    margin-top: var(--space-xl);
  }

  .step-card {
    padding: var(--space-l);
    border-left: 3px solid var(--accent);
    background: var(--stone);
  }

  .step-card__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--accent);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .step-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--chalk);
    margin: var(--space-s) 0 var(--space-xs);
  }

  .step-card__body {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0;
  }

  /* ── Principles ── */
  .principles-section {
    padding: var(--section-pad) 0;
    background: var(--charcoal);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .principle {
    padding-left: var(--space-m);
  }

  .principle__rule {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: var(--space-s);
  }

  .principle__title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 var(--space-xs);
  }

  .principle__body {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr; }
  }
</style>