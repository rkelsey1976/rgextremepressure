---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SplitFeature from '../../components/SplitFeature.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import TestimonialBlock from '../../components/TestimonialBlock.astro';
---

<Base
  title="Property Maintenance & Garden Landscaping Bath | Aspect Builds"
  description="Professional property maintenance, garden landscaping, structural retaining walls and responsive repairs across Bath & BANES. Reliable, organised, insured."
  preloadImage="/images/hero-james-bath-property-3.webp"
  serviceSchema={{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Property Maintenance",
    "name": "Property Care & Landscaping Bath",
    "description": "Outdoor and architectural landscaping, structural retaining walls, comprehensive property maintenance and responsive home repairs across Bath and BANES.",
    "provider": {
      "@type": "HomeAndConstructionBusiness",
      "name": "Aspect Builds & Maintenance Ltd",
      "url": "https://www.aspectbuilds.co.uk"
    },
    "areaServed": ["Bath", "Keynsham", "Bradford on Avon", "Chippenham", "Corsham", "Frome", "Box", "Batheaston", "Bathampton", "Bathford"],
    "url": "https://www.aspectbuilds.co.uk/services/property-care/"
  }}
>
  <Hero
    image="/images/hero-james-bath-property-3.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services', href: '/services' }, { label: 'Property Care & Landscaping' }]}
    eyebrow="Landscaping · Maintenance · Repairs"
    heading="Property Care<br>&amp; Landscaping"
    body="Your property doesn't stop needing care once the build is done. We provide premium garden landscaping and a reliable, organised domestic maintenance service across Bath &amp; BANES — backed by the same fixed-price approach and direct communication as our larger projects."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Skilled', label: 'Dependable Workforce' },
    { value: 'Fixed', label: 'Transparent Pricing' },
    { value: 'Clean', label: 'Respect for Your Home' },
  ]} />

  <section class="split-video" style="padding:var(--section-pad) 0">
    <div class="container">
      <div class="split-video__grid">
        <div class="split-video__media">
          <video
            src="/images/bath-landscaping-video.mp4"
            poster="/images/bath-landscaping-video-poster.webp"
            muted
            controls
            playsinline
            preload="metadata"
            class="split-video__player"
          ></video>
        </div>
        <div class="split-video__content">
          <p class="split-video__eyebrow">Property Care &amp; Landscaping</p>
          <h2 class="split-video__heading">The Same Standard of Care. Inside and Out.</h2>
          <p class="split-video__body">Most building companies treat maintenance and landscaping as an afterthought. We treat them as a discipline in their own right. Bath's garden terrain — steeply sloped plots, narrow rear access, Bath stone boundary walls that need structural understanding as well as aesthetic sensitivity — demands builders who know what they're doing. Our landscaping team combines structural engineering knowledge with design sensibility. Our maintenance service is organised, accountable, and reliable — the things that most tradespeople are not.</p>
          <ul class="split-video__list">
            <li>Structural and aesthetic landscaping across Bath's varied terrain</li>
            <li>Sloped garden and retaining wall solutions on hillside plots</li>
            <li>Planned maintenance programmes and responsive repair callouts</li>
            <li>Fully insured, vetted tradespeople on every job</li>
          </ul>
          <a href="/contact" class="btn btn--accent">Discuss Your Requirements</a>
        </div>
      </div>
    </div>
  </section>

  <section class="sub-services">
    <div class="container">
      <SectionHeader
        eyebrow="Property Care Specialisms"
        heading="Four Ways We Care for<br>Your Property"
        body="Whether you need a garden transformed, a wall built, or a reliable maintenance team on call — the Aspect approach applies at every scale."
      />
      <div class="sub-grid">

        <div class="sub-card">
          <div class="sub-card__num">01</div>
          <h3 class="sub-card__title">Garden Landscaping &amp; Paving</h3>
          <p class="sub-card__body">Bath's garden culture is exacting — premium paving, considered planting, and structures that complement the architecture rather than clash with it. We design and build outdoor spaces that are both beautiful and built to last, using premium materials specified to the setting: natural stone, reclaimed Bath cobbles, porcelain large-format paving, and traditional gravel paths that work with period properties rather than undermining them.</p>
          <ul class="sub-card__list">
            <li>Natural stone and premium porcelain paving installation</li>
            <li>Raised planting beds and garden structure construction</li>
            <li>Pergolas, garden walls, and outdoor living structures</li>
            <li>Gravel paths, resin bound driveways, and soft landscaping</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">02</div>
          <h3 class="sub-card__title">Structural Retaining Walls</h3>
          <p class="sub-card__body">Bath's hillside plots are defined by their slopes — and a sloped garden without a properly engineered retaining wall is both a safety risk and a wasted opportunity. We design and build structural stone, block, and timber retaining walls that hold the slope, create usable terraced garden levels, and — where the setting demands it — use Bath stone to maintain the visual coherence of the property's wider character.</p>
          <ul class="sub-card__list">
            <li>Structural engineering assessment for all retaining walls</li>
            <li>Bath stone, block, and timber retaining wall construction</li>
            <li>Terraced garden level creation on sloped plots</li>
            <li>Drainage design behind retaining structures</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">03</div>
          <h3 class="sub-card__title">Property Maintenance Programmes</h3>
          <p class="sub-card__body">A well-maintained property retains its value and avoids the expensive emergency repairs that result from deferred upkeep. We provide planned maintenance programmes for residential properties across Bath and BANES — covering all the trades that a home needs on a regular cycle: gutters and drainage, external decoration, roof tile checks, carpentry repairs, and seasonal garden maintenance. One number, every trade.</p>
          <ul class="sub-card__list">
            <li>Annual and biannual planned maintenance schedules</li>
            <li>Gutter cleaning and drainage maintenance</li>
            <li>External painting and decoration programmes</li>
            <li>Carpentry repairs — fences, gates, fascias, soffits</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">04</div>
          <h3 class="sub-card__title">Responsive Repairs &amp; Roofing</h3>
          <p class="sub-card__body">When something goes wrong — a cracked render, a leaking flat roof, a damp patch that's appeared on the chimney breast — you need a builder who responds promptly, diagnoses correctly, and fixes it properly rather than masking the symptoms. We offer responsive repair callouts for homeowners across Bath and BANES, covering roofing, render, pointing, damp investigation, and structural crack assessment, all by the same vetted and insured team.</p>
          <ul class="sub-card__list">
            <li>Roof tile replacement and flat roof repairs</li>
            <li>Render repair and external wall crack assessment</li>
            <li>Damp investigation and remediation</li>
            <li>Chimney stack repointing and flaunching repairs</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <SplitFeature
    image="/images/hero-james-bath-property-4.webp"
    imageAlt="Bath property exterior — maintenance and care"
    eyebrow="Why Maintenance Matters in Bath"
    heading="Bath Stone Weathers. Lime Mortars Need Attention. Don't Leave It."
    body="Bath's building stock is spectacular — and it's also exceptionally unforgiving of neglect. Traditional Bath stone is soft and porous; left unpointed, rainwater tracks into the masonry and causes progressive structural degradation that is expensive to reverse. Heritage timber windows deteriorate rapidly without a regular painting cycle. Valley gutters on Georgian roofs become blocked and cause internal water ingress that appears as ceiling damp rather than roof leakage — often misdiagnosed for years. A planned maintenance programme costs a fraction of the emergency repairs that neglect eventually produces."
    dark={true}
    reverse={true}
    list={[
      'Annual pointing inspection and minor repair programme',
      'External joinery painting cycle — typically every 5 years',
      'Gutter and valley gutter clearance — recommended biannually',
      'Roof inspection after significant weather events',
    ]}
    cta={{ label: 'Set Up a Maintenance Programme', href: '/contact' }}
  />

  <section style="background:var(--stone);padding:var(--section-pad) 0">
    <div class="container" style="max-width:48rem">
      <TestimonialBlock
        quote="I couldn't recommend Aspect Builds highly enough for the landscaping and garden build they completed for us. From the initial design to the final handover, the team was professional, communicative, and genuinely invested in getting the details right. Site was kept tidy, timeframes were clear, and any issues were handled quickly with no fuss."
        name="Cole Hulbert"
        role="Landscaping & Garden Build · TrustATrader"
      />
    </div>
  </section>

  {/* ── Areas We Cover ── */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        eyebrow="Coverage"
        heading="Property Care &amp; Landscaping Across Bath &amp; BANES"
        body="We maintain, repair, and landscape properties throughout Bath, BANES, and West Wiltshire. Responsive service, clean sites, proper finishes."
      />
      <div class="area-links">
        <a href="/areas-covered/central-bath-districts">Central Bath & Districts</a>
        <a href="/areas-covered/batheaston">Batheaston</a>
        <a href="/areas-covered/bathampton">Bathampton</a>
        <a href="/areas-covered/bathford">Bathford</a>
        <a href="/areas-covered/bradford-on-avon">Bradford on Avon</a>
        <a href="/areas-covered/corsham">Corsham</a>
        <a href="/areas-covered/saltford-keynsham">Keynsham & Saltford</a>
        <a href="/areas-covered/box">Box</a>
        <a href="/areas-covered/chippenham">Chippenham</a>
        <a href="/areas-covered/frome-radstock-midsomer-norton">Frome & Radstock</a>
      </div>
    </div>
  </section>

  <ImageCTA
    heading="Keep Your Property in Peak Condition."
    body="Whether you need a one-off repair or a planned annual maintenance programme, we provide fixed-price, reliable, fully insured property care across Bath &amp; BANES."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-james-bath-property-5.webp"
  />
</Base>

<style>
  .split-video__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl, 3rem);
    align-items: center;
  }

  .split-video__player {
    width: 100%;
    border-radius: 4px;
    background: #000;
  }

  .split-video__eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin: 0 0 var(--space-s, 0.5rem);
  }

  .split-video__heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--chalk);
    margin: 0 0 var(--space-m, 1rem);
  }

  .split-video__body {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0 0 var(--space-l, 1.5rem);
  }

  .split-video__list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-l, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .split-video__list li {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--chalk);
    padding-left: 1rem;
    position: relative;
  }

  .split-video__list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .area-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-xl);
  }

  .area-links a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--chalk);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(26, 35, 50, 0.12);
    background: #fff;
    transition: border-color 0.2s, color 0.2s;
  }

  .area-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .split-video__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl, 2rem);
    }
  }

  .sub-services {
    padding: var(--section-pad) 0;
    background: var(--stone);
  }

  .sub-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .sub-card {
    background: #fff;
    padding: var(--space-xl);
    border: 1px solid rgba(26, 35, 50, 0.08);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .sub-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.4;
  }

  .sub-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
    line-height: 1.1;
  }

  .sub-card__body {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0;
  }

  .sub-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border-top: 1px solid var(--stone);
    padding-top: var(--space-m);
  }

  .sub-card__list li {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--chalk);
    padding-left: 1rem;
    position: relative;
  }

  .sub-card__list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .sub-grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
</style>
