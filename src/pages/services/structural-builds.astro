---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SplitFeature from '../../components/SplitFeature.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import TestimonialBlock from '../../components/TestimonialBlock.astro';
---

<Base
  title="Structural Builds & New Builds Bath"
  description="Structural extensions, loft conversions, basement conversions and new builds across Bath & BANES. Fixed-price quotes, clean sites, full project management."
  preloadImage="/images/hero-james-bath-property-1.webp"
  serviceSchema={{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Structural Building",
    "name": "Structural & Scale Builds Bath",
    "description": "New build projects, structural steel and RSJ installations, basement and garage conversions, and complete groundworks across Bath and BANES.",
    "provider": {
      "@type": "HomeAndConstructionBusiness",
      "name": "Aspect Builds & Maintenance Ltd",
      "url": "https://www.aspectbuilds.co.uk"
    },
    "areaServed": ["Bath", "Keynsham", "Bradford on Avon", "Chippenham", "Corsham", "Frome", "Box", "Batheaston", "Bathampton", "Bathford"],
    "url": "https://www.aspectbuilds.co.uk/services/structural-builds/"
  }}
>
  <Hero
    image="/images/hero-james-bath-property-1.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services', href: '/services' }, { label: 'Structural & Scale Builds' }]}
    eyebrow="Extensions · Conversions · New Build"
    heading="Structural &amp;<br>Scale Builds"
    body="Expand your property's footprint, convert unused space, or build from the ground up. We manage every structural project across Bath &amp; BANES with fixed-price quotes, clean sites, and engineering precision."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'CSCS', label: 'Cardholders' },
    { value: 'City & Guilds', label: 'Qualified' },
    { value: 'Fixed', label: 'Transparent Pricing' },
    { value: 'Clean', label: 'Respect for Your Home' },
  ]} />

  <SplitFeature
    image="/images/hero-james-bath-property-6.webp"
    imageAlt="House extension under construction in Bath"
    eyebrow="Structural & Scale Builds"
    heading="Engineering Excellence for Bath's Diverse Housing Stock"
    body="From Georgian terraces in Widcombe to 1930s semis in Keynsham, Bath's residential architecture demands builders who understand both the planning constraints and the structural realities of each property type. We manage every phase — from initial site appraisal and planning consultation through to structural steelwork, groundworks, and final handover — under a single fixed-price contract."
    dark={false}
    list={[
      'Fixed-price contracts with itemised cost breakdowns',
      'Single point of contact throughout the entire project',
      'Full planning and building regulations management',
      'Structural engineering coordination and party wall compliance',
    ]}
    cta={{ label: 'Get a Fixed-Price Quote', href: '/contact' }}
  />

  <section class="sub-services">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        heading="Four Structural Specialisms.<br>One Project Management Standard."
        body="Every project type below is delivered under the same fixed-quote, single-contact Aspect process — from the first site visit to the final snag list."
      />
      <div class="sub-grid">

        <div class="sub-card">
          <div class="sub-card__num">01</div>
          <h3 class="sub-card__title">House Extensions</h3>
          <p class="sub-card__body">Single and double-storey rear extensions, side-return extensions, wraparound extensions, and garden rooms. We handle the full build — from groundworks and structural steel to plastering, flooring, and decoration — giving you a seamless addition that feels like it was always there.</p>
          <ul class="sub-card__list">
            <li>Single-storey rear &amp; side-return extensions</li>
            <li>Double-storey extensions &amp; above-garage additions</li>
            <li>Orangeries, garden rooms &amp; glazed extensions</li>
            <li>Permitted development and full planning applications</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">02</div>
          <h3 class="sub-card__title">Loft Conversions</h3>
          <p class="sub-card__body">Converting your loft is the most cost-effective way to add a bedroom, home office, or studio without losing garden space. We assess your roof structure, advise on the right conversion type, and manage the full build including staircase, dormer windows, insulation, and party wall compliance.</p>
          <ul class="sub-card__list">
            <li>Dormer conversions (rear &amp; side)</li>
            <li>Hip-to-gable &amp; L-shaped dormers</li>
            <li>Mansard conversions</li>
            <li>Velux rooflight conversions (minimal structural change)</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">03</div>
          <h3 class="sub-card__title">New Build Projects</h3>
          <p class="sub-card__body">Turnkey new build delivery for residential clients, plot developers, and self-builders across Bath and West Wiltshire. We coordinate every trade and discipline from groundworks and substructure through to fit-out, landscaping, and final handover — with weekly progress reports throughout.</p>
          <ul class="sub-card__list">
            <li>Detached &amp; semi-detached new builds</li>
            <li>Plot development coordination</li>
            <li>Self-build project management</li>
            <li>Groundworks, drainage &amp; substructure</li>
          </ul>
        </div>

        <div class="sub-card">
          <div class="sub-card__num">04</div>
          <h3 class="sub-card__title">Basement &amp; Garage Conversions</h3>
          <p class="sub-card__body">Unlock below-ground space or transform an underused garage into a habitable room. Basement projects require specialist waterproofing and structural assessment — both of which are managed as standard within our scope. Garage conversions offer fast programme times with high value returns for family homes.</p>
          <ul class="sub-card__list">
            <li>Basement tanking &amp; structural waterproofing</li>
            <li>Below-ground living space conversions</li>
            <li>Garage-to-room conversions (integral &amp; detached)</li>
            <li>Structural steel &amp; RSJ beam installations</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <SplitFeature
    image="/images/hero-james-bath-property-4.webp"
    imageAlt="Bath Georgian terrace — extensions and planning"
    eyebrow="Planning in Bath"
    heading="Conservation Areas, Listed Buildings &amp; Permitted Development"
    body="Bath is one of the most planning-sensitive cities in England. Any structural addition — even within permitted development limits — must respect the city's heritage character. We work closely with the BANES planning department and, where required, specialist heritage consultants to ensure your project is approved first time. We manage all pre-application enquiries, drawings coordination, and building regulations submissions as part of our service."
    dark={true}
    reverse={true}
    list={[
      'Pre-application planning advice and BANES liaison',
      'Conservation area and Article 4 Direction compliance',
      'Listed Building Consent applications where required',
      'Party wall surveyor coordination and award management',
    ]}
    cta={{ label: 'Arrange a Site Appraisal', href: '/contact' }}
  />

  <section style="background:var(--stone);padding:var(--section-pad) 0">
    <div class="container" style="max-width:48rem">
      <TestimonialBlock
        quote="I have worked with Aspect on several projects. I have always found James approachable with Aspect working to a high standard."
        name="Timothy"
        role="Multiple Projects · TrustATrader"
      />
    </div>
  </section>

  {/* ── Areas We Cover ── */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        eyebrow="Coverage"
        heading="Structural Builds Across Bath &amp; BANES"
        body="We deliver structural projects throughout Bath, BANES, and West Wiltshire. Our team understands local planning constraints, party wall requirements, and building control expectations."
      />
      <div class="area-links">
        <a href="/areas-covered/central-bath-districts">Central Bath & Districts</a>
        <a href="/areas-covered/batheaston">Batheaston</a>
        <a href="/areas-covered/bathampton">Bathampton</a>
        <a href="/areas-covered/bathford">Bathford</a>
        <a href="/areas-covered/bradford-on-avon">Bradford on Avon</a>
        <a href="/areas-covered/corsham">Corsham</a>
        <a href="/areas-covered/saltford-keynsham">Keynsham & Saltford</a>
        <a href="/areas-covered/box">Box</a>
        <a href="/areas-covered/chippenham">Chippenham</a>
        <a href="/areas-covered/frome-radstock-midsomer-norton">Frome & Radstock</a>
      </div>
    </div>
  </section>

  <ImageCTA
    heading="Ready to Extend, Convert, or Build?"
    body="Get a free, no-obligation structural consultation. We'll assess your property, outline your planning options, and provide a fully itemised fixed-price quote — with no surprises."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-james-bath-property-6.webp"
  />
</Base>

<style>
  .sub-services {
    padding: var(--section-pad) 0;
    background: var(--stone);
  }

  .sub-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .sub-card {
    background: #fff;
    padding: var(--space-xl);
    border: 1px solid rgba(26, 35, 50, 0.08);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .sub-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.4;
  }

  .sub-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
    line-height: 1.1;
  }

  .sub-card__body {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0;
  }

  .sub-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border-top: 1px solid var(--stone);
    padding-top: var(--space-m);
  }

  .sub-card__list li {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--chalk);
    padding-left: 1rem;
    position: relative;
  }

  .sub-card__list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .area-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-xl);
  }

  .area-links a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--chalk);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(26, 35, 50, 0.12);
    background: #fff;
    transition: border-color 0.2s, color 0.2s;
  }

  .area-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .sub-grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
</style>
