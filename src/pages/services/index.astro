---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceDirectory from '../../components/ServiceDirectory.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import { servicesData } from '../../data/services';
---

<Base title="Jet Washing Services Bath | Pressure Washing"
  description="Browse all RG Extreme Pressure cleaning services — driveway, patio, roof, gutter, render and block paving. Serving Bath, Bristol and Somerset. 27 five-star reviews. Free quotes.">

  <Hero
    image="/images/before-after/roof-after-2.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
    eyebrow="Professional External Cleaning"
    heading="Jet Washing Services Bath"
    body="From driveway deep cleans to specialist roof cleaning — every service delivered with professional equipment, eco-friendly products and honest pricing."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Service Cards ── */}
  <section class="service-cards-section">
    <div class="container">
      <SectionHeader
        eyebrow="Our Services"
        heading="Explore Each Service"
        body="Click through for full details, before and after photos, FAQs and pricing for each of our professional cleaning services."
      />
      <div class="service-cards-grid">
        {servicesData.map(s => (
          <a href={s.href} class="service-card">
            <div class="service-card__icon">
              {s.id === 'driveway-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="1"/><path d="M5 11V7a2 2 0 012-2h10a2 2 0 012 2v4"/><line x1="3" y1="16" x2="21" y2="16"/></svg>}
              {s.id === 'patio-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>}
              {s.id === 'gutter-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 6l2 12h12l2-12"/><path d="M10 10v4M14 10v4"/><path d="M8 6V4h8v2"/></svg>}
              {s.id === 'roof-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-16 9 16H3z"/><path d="M12 10v6M12 18h.01"/></svg>}
              {s.id === 'render-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>}
              {s.id === 'block-paving-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="1" width="10" height="10" rx="1"/><rect x="13" y="1" width="10" height="10" rx="1"/><rect x="1" y="13" width="10" height="10" rx="1"/><rect x="13" y="13" width="10" height="10" rx="1"/></svg>}
            </div>
            <span class="service-card__subtitle">{s.subtitle}</span>
            <h3 class="service-card__title">{s.title}</h3>
            <p class="service-card__desc">{s.description}</p>
            <span class="service-card__link">
              View Service
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ── Trust bar ── */}
  <TrustMetrics metrics={[
    { value: '27', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  {/* ── SEO keyword directory ── */}
  <ServiceDirectory />

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready for a Free Quote?"
    body="Whether you need a driveway deep clean in Bath or a specialist roof clean in Bristol, get in touch today for a free, no-obligation quote."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after-2.webp"
  />
</Base>

<style>
  /* ── Service Cards ── */
  .service-cards-section {
    background: var(--surface);
    padding: var(--section-pad) 0;
  }

  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    padding-top: var(--space-l);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid rgba(0,85,165,0.08);
    border-radius: var(--radius);
    padding: var(--space-l);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(0,85,165,0.08);
    transform: translateY(-3px);
  }

  .service-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-light);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xs);
  }

  .service-card__subtitle {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.4vw, 1.4rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
  }

  .service-card__desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: auto;
    padding-top: var(--space-s);
    transition: gap 0.2s;
  }

  .service-card:hover .service-card__link {
    gap: 0.6rem;
  }

  @media (max-width: 1024px) {
    .service-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .service-cards-grid {
      grid-template-columns: 1fr;
    }
    .service-card:hover {
      transform: none;
    }
  }
</style>