---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServicesShowcase from '../../components/ServicesShowcase.astro';
import ServiceDirectory from '../../components/ServiceDirectory.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';
---

<Base title="Builders Bath | Building Services & Contractors"
  description="Builders and building contractors in Bath. Loft conversions, extensions, new builds, heritage restoration, renovations and property maintenance across Bath & BANES."
  preloadImage="/images/hero-james-bath-property-11.webp">
  {/* ── Hero ── */}
  <Hero
    image="/images/hero-james-bath-property-11.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
    eyebrow="Craftsmanship & Expertise"
    heading="Our Core<br>Architectural Pillars"
    body="From structural extensions and heritage restorations to turnkey interiors and ongoing property care — every service delivered with fixed quotes, clean sites, and direct communication."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust bar ── */}
  <TrustMetrics metrics={[
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'CSCS', label: 'Cardholders' },
    { value: 'City & Guilds', label: 'Qualified' },
    { value: 'Fixed', label: 'Transparent Pricing' },
    { value: 'Clean', label: 'Respect for Your Home' },
  ]} />

  {/* ── Services showcase (tabbed) ── */}
  <ServicesShowcase />

  {/* ── Guarantee section ── */}
  <section class="guarantee-section">
    <div class="container">

      {/* ── Header row ── */}
      <div class="guarantee-header">
        <div class="guarantee-header__left">
          <span class="rule--accent"></span>
          <span class="t-label guarantee-eyebrow">The Aspect Builds Guarantee</span>
          <h2 class="guarantee-heading">Honest Advice.<br/>Transparent Pricing.<br/>Clean Sites.</h2>
        </div>
        <div class="guarantee-header__right">
          <p class="guarantee-intro">Fully insured and professional service. Every on-site team member holds valid CSCS cards and City &amp; Guilds / NVQ qualifications. Honest advice with transparent pricing — what we quote is what you pay.</p>
          <a href="/contact" class="btn btn--outline-light guarantee-cta">
            Arrange a Consultation
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      {/* ── Divider ── */}
      <div class="guarantee-divider"></div>

      {/* ── Items ── */}
      <div class="guarantee-grid">

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">01</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Fully Insured</h3>
            <p class="guarantee-desc">Complete public and employer's liability cover on every project. Your property and our workforce are fully protected — no exceptions.</p>
            <span class="guarantee-proof">Full insurance on every project</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">02</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">CSCS Cardholders &amp; Qualified</h3>
            <p class="guarantee-desc">Every on-site team member holds valid CSCS cards and industry-recognized qualifications (City &amp; Guilds / NVQ), ensuring the highest standards of safety and craftsmanship.</p>
            <span class="guarantee-proof">Verified qualifications</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">03</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Honest, Transparent Pricing</h3>
            <p class="guarantee-desc">Itemised quotes agreed before work starts. No hidden costs, no surprise extras. What we quote is what you pay.</p>
            <span class="guarantee-proof">Zero hidden extras on every project</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">04</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Clean, Respectful Sites</h3>
            <p class="guarantee-desc">Dust sheets, daily tidy-ups, and protected access routes. Your home gets treated like our own — we leave it spotless.</p>
            <span class="guarantee-proof">Clean site protocols as standard</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">05</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Reputation Earned</h3>
            <p class="guarantee-desc">Our business is built on repeat work and personal recommendations. That only happens when you deliver — and we do, every time.</p>
            <span class="guarantee-proof">Repeat business and referrals</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── SEO keyword directory ── */}
  <ServiceDirectory />

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready to Start Planning Your Next Project?"
    body="Whether you need a heritage restoration in Bath or a modern extension in Keynsham, get in touch today for a free, transparent site consultation."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-james-bath-property-6.webp"
  />
</Base>

<style>
  /* ── Guarantee section ── */
  .guarantee-section {
    background: var(--charcoal);
    padding: var(--section-pad) 0;
  }

  /* ── Header row: heading left, intro right ── */
  .guarantee-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl, 5rem);
    align-items: end;
  }

  .guarantee-header__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .guarantee-eyebrow {
    color: var(--accent);
  }

  .guarantee-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .guarantee-header__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding-bottom: 0.25rem;
  }

  .guarantee-intro {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-width: 52ch;
  }

  .btn--outline-light {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s;
    align-self: flex-start;
  }

  .btn--outline-light:hover {
    border-color: var(--accent);
    background: rgba(174, 132, 85, 0.1);
  }

  .btn--outline-light svg {
    transition: transform 0.3s var(--ease-out-expo);
  }

  .btn--outline-light:hover svg {
    transform: translateX(4px);
  }

  /* ── Divider ── */
  .guarantee-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: var(--space-2xl) 0;
  }

  /* ── Items grid ── */
  .guarantee-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .guarantee-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding: var(--space-xl);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 3px solid transparent;
    transition: border-top-color 0.3s;
  }

  .guarantee-item:hover {
    border-top-color: var(--accent);
  }

  .guarantee-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 5vw, 6rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.25;
    display: block;
    transition: opacity 0.3s;
  }

  .guarantee-item:hover .guarantee-num {
    opacity: 0.6;
  }

  .guarantee-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    flex: 1;
  }

  .guarantee-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.8vw, 2rem);
    line-height: 1.05;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .guarantee-desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    flex: 1;
  }

  .guarantee-proof {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    padding-top: var(--space-m);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .guarantee-header {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 960px) {
    .guarantee-grid {
      grid-template-columns: repeat(2, 1fr);
      border-left: none;
    }

    .guarantee-item {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }
  }

  @media (max-width: 640px) {
    .guarantee-grid {
      grid-template-columns: 1fr;
    }
  }
</style>