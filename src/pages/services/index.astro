---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServicesShowcase from '../../components/ServicesShowcase.astro';
import ServiceDirectory from '../../components/ServiceDirectory.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';
---

<Base title="Our Services" preloadImage="/images/hero-batheaston-renovation.jpg">
  {/* ── Hero ── */}
  <Hero
    image="/images/hero-batheaston-renovation.jpg"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
    eyebrow="Craftsmanship & Expertise"
    heading="Our Core Architectural Pillars"
    body="From structural extensions and heritage restorations to turnkey interiors and ongoing property care — every service delivered with fixed quotes, clean sites, and direct communication."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust bar ── */}
  <TrustMetrics metrics={[
    { value: '4.9', label: 'Local Homeowners' },
    { value: 'TrustATrader', label: 'Certified & Verified' },
    { value: '£5M+ Cover', label: 'Fully Insured' },
    { value: 'Turnkey', label: 'Professional Maintenance' },
  ]} />

  {/* ── Services showcase (tabbed) ── */}
  <ServicesShowcase />

  {/* ── Guarantee section ── */}
  <section class="guarantee-section">
    <div class="container">

      {/* ── Header row ── */}
      <div class="guarantee-header">
        <div class="guarantee-header__left">
          <span class="rule--accent"></span>
          <span class="t-label guarantee-eyebrow">The Aspect Builds Guarantee</span>
          <h2 class="guarantee-heading">Fixed Quotes.<br/>Clean Sites.<br/>Direct Lines.</h2>
        </div>
        <div class="guarantee-header__right">
          <p class="guarantee-intro">We don't do hidden costs, chaotic worksites, or unanswered calls. Every project runs on transparent, itemised quotes, tidy sites, and a single point of contact who picks up the phone.</p>
          <a href="/contact" class="btn btn--outline-light guarantee-cta">
            Arrange a Consultation
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      {/* ── Divider ── */}
      <div class="guarantee-divider"></div>

      {/* ── Items ── */}
      <div class="guarantee-grid">

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">01</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Fixed, Transparent Quotes</h3>
            <p class="guarantee-desc">Itemised cost breakdowns agreed before any tools touch your property. What we quote is what you pay — no variation orders, no late surprises.</p>
            <span class="guarantee-proof">Zero hidden extras on every project</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">02</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Logistical Precision</h3>
            <p class="guarantee-desc">Conservation area permits, city-centre parking restrictions, crane lifts on tight lanes — we manage all site logistics end-to-end from day one.</p>
            <span class="guarantee-proof">Full site logistics managed within scope</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">03</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Clean, Respectful Sites</h3>
            <p class="guarantee-desc">Your home is not a building site to us. Dust sheets, hoarding, daily tidy-ups, and protected access routes are standard — not extras.</p>
            <span class="guarantee-proof">Site clean protocols on every job from day one</span>
          </div>
        </div>

        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">04</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Direct Communication</h3>
            <p class="guarantee-desc">One named contact throughout the entire project. Weekly written progress updates. We pick up the phone — and if we miss it, we call back the same day.</p>
            <span class="guarantee-proof">Weekly written updates as standard</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── SEO keyword directory ── */}
  <ServiceDirectory />

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready to Start Planning Your Next Project?"
    body="Whether you need a heritage restoration in Bath or a modern extension in Keynsham, get in touch today for a free, transparent site consultation."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-batheaston-renovation.jpg"
  />
</Base>

<style>
  /* ── Guarantee section ── */
  .guarantee-section {
    background: var(--charcoal);
    padding: var(--section-pad) 0;
  }

  /* ── Header row: heading left, intro right ── */
  .guarantee-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl, 5rem);
    align-items: end;
  }

  .guarantee-header__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .guarantee-eyebrow {
    color: var(--accent);
  }

  .guarantee-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .guarantee-header__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding-bottom: 0.25rem;
  }

  .guarantee-intro {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-width: 52ch;
  }

  .btn--outline-light {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s;
    align-self: flex-start;
  }

  .btn--outline-light:hover {
    border-color: var(--accent);
    background: rgba(174, 132, 85, 0.1);
  }

  .btn--outline-light svg {
    transition: transform 0.3s var(--ease-out-expo);
  }

  .btn--outline-light:hover svg {
    transform: translateX(4px);
  }

  /* ── Divider ── */
  .guarantee-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: var(--space-2xl) 0;
  }

  /* ── Items grid ── */
  .guarantee-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .guarantee-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding: var(--space-xl);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 3px solid transparent;
    transition: border-top-color 0.3s;
  }

  .guarantee-item:hover {
    border-top-color: var(--accent);
  }

  .guarantee-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 5vw, 6rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.25;
    display: block;
    transition: opacity 0.3s;
  }

  .guarantee-item:hover .guarantee-num {
    opacity: 0.6;
  }

  .guarantee-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    flex: 1;
  }

  .guarantee-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.8vw, 2rem);
    line-height: 1.05;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .guarantee-desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    flex: 1;
  }

  .guarantee-proof {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    padding-top: var(--space-m);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .guarantee-header {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 960px) {
    .guarantee-grid {
      grid-template-columns: repeat(2, 1fr);
      border-left: none;
    }

    .guarantee-item {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }
  }

  @media (max-width: 640px) {
    .guarantee-grid {
      grid-template-columns: 1fr;
    }
  }
</style>