---
import Base from '../../layouts/Base.astro';
---

<Base title="Enquiry Received">
  <section class="success-page">
    <div class="container">
      <div class="success-inner">
        <span class="rule--accent"></span>
        <span class="t-label" style="color:var(--accent)">Enquiry Received</span>
        <h1 class="success-heading">Thank You.<br>We'll Be in Touch.</h1>
        <p class="success-body">Your project details have been received. A member of our team will review your enquiry and respond within 24 operational hours — usually sooner.</p>
        <div class="success-actions">
          <a href="/" class="btn btn--primary">
            Return to Homepage
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/projects" class="success-link">
            View our projects
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .success-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: var(--section-pad) 0;
    background: #fff;
  }

  .success-inner {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .success-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
  }

  .success-body {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0;
    max-width: 48ch;
  }

  .success-actions {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    flex-wrap: wrap;
    margin-top: var(--space-s);
  }

  .success-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--concrete);
    text-decoration: none;
    transition: color 0.25s;
  }

  .success-link:hover {
    color: var(--accent);
  }
</style>
