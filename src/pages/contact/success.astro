---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
---

<Base title="Enquiry Received" noindex>
  <Hero
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Contact', href: '/contact' }, { label: 'Enquiry Received' }]}
    eyebrow="Enquiry Received"
    heading="Thank You.<br>We'll Be in Touch."
    body="Your project details have been received. A member of our team will review your enquiry and respond within 24 operational hours — usually sooner."
    image="/images/before-after/roof-after.jpg"
    overlay="blue"
    minHeight="compact"
  />

  <section class="success-page">
    <div class="container">
      <div class="success-inner">
        <div class="success-actions">
          <a href="/" class="btn btn--primary">
            Return to Homepage
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/services" class="success-link">
            View our services
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .success-page {
    padding: var(--section-pad) 0;
    background: #fff;
  }

  .success-inner {
    max-width: 560px;
  }

  .success-actions {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    flex-wrap: wrap;
  }

  .success-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--concrete);
    text-decoration: none;
    transition: color 0.25s;
  }

  .success-link:hover {
    color: var(--accent);
  }
</style>
