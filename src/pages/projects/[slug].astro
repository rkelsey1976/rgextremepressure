---
// Dynamic case study page template
// Generates /projects/[slug] from src/content/portfolio/*.md

import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const portfolio = await getCollection('portfolio');
  return portfolio.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const {
  title,
  location,
  category,
  categoryLabel,
  image,
  brief,
  challenge,
  execution,
  gallery,
  video,
  tags,
  meta,
  featured,
} = entry.data;
---

<Base title={title} description={brief} preloadImage={image}>
  <Hero
    image={image}
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Projects', href: '/projects' }, { label: title }]}
    tags={tags}
    heading={title}
    body={brief}
    minHeight="compact"
    meta={meta}
  />

  <div class="container">
    <!-- Narrative: Brief / Challenge / Execution -->
    <ProjectGallery
      brief={brief}
      challenge={challenge}
      execution={execution}
      gallery={gallery}
      video={video}
    />
  </div>

  <!-- CTA -->
  <ImageCTA
    heading="Start a Similar Project"
    body="Every build begins with a conversation. Tell us what you're planning and we'll come back with a clear, fixed-price quote."
    cta={{ label: 'Get a Quote', href: '/contact' }}
    image="/images/hero-medford-garden-extension.webp"
  />
</Base>

<style>
</style>