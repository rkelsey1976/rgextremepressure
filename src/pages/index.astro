---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import ThreeBestRated from '../components/ThreeBestRated.astro';
import FbVideoFacade from '../components/FbVideoFacade.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import { servicesData } from '../data/services';
import { googleReviews } from '../data/reviews';
---

<Base title="Jet Washing Bath"
  description="Professional jet washing in Bath. Driveway cleaning, patio cleaning, gutter clearing, roof cleaning, render cleaning and block paving. 27 five-star reviews. Call 07474 939 398."
  preloadImage="/images/hero-home.webp">

  {/*
    ═══════════════════════════════════════
    A. HERO — photo hero with blue overlay
    ═══════════════════════════════════════
  */}
  <Hero
    video="/videos/hero-roof-cleaning.mp4"
    overlay="blue"
    eyebrow="Bath · Bristol · Somerset"
    heading="Professional Jet Washing &amp; Pressure Washing in Bath"
    body="Professional jet washing and specialist cleaning services for driveways, patios, roofs, gutters, render and block paving. 27 five-star reviews. Fully insured. Free quotes."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    ctaSecondary={{ label: 'View Services', href: '/services' }}
  />

  {/*
    ═══════════════════════════════════════
    B. TRUST BAR
    ═══════════════════════════════════════
  */}
  <TrustMetrics metrics={[
    { value: '27', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <ThreeBestRated />

  {/*
    ═══════════════════════════════════════
    B2. VIDEO — See Us In Action
    ═══════════════════════════════════════
  */}
  <section class="video-section">
    <div class="container">
      <SectionHeader
        eyebrow="See Us In Action"
        heading="Watch Our Work"
        body="A quick look at the RG Extreme Pressure difference — professional jet washing that transforms properties across Bath and Bristol."
        align="center"
      />
      <div class="video-wrap">
        <FbVideoFacade
          src="https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2F100091066506303%2Fvideos%2F1751025128677768%2F&show_text=false&width=560&t=0"
          title="RG Extreme Pressure — jet washing in action"
          poster="/images/before-after/roof-after-2.webp"
        />
      </div>
    </div>
  </section>

  {/* ── GALLERY ── */}
  <section class="gallery-section">
    <div class="container">
      <SectionHeader
        eyebrow="Real Results"
        heading="Before &amp; After"
        body="Drag the handle to see the transformation. Every photo is our own work — no stock images."
        align="center"
      />
      <div class="ba-grid">
        <div class="ba-grid__item">
          <BeforeAfter
            beforeSrc="/images/before-after/roof-before-1.webp"
            afterSrc="/images/before-after/roof-after-2.webp"
            beforeAlt="Roof covered in moss before cleaning"
            afterAlt="Clean roof after professional moss removal"
            caption="Roof cleaning — moss removal and biocide treatment"
          />
        </div>
        <div class="ba-grid__item">
          <BeforeAfter
            beforeSrc="/images/before-after/driveway-before-1.webp"
            afterSrc="/images/before-after/driveway-after-1.webp"
            beforeAlt="Driveway before jet washing"
            afterAlt="Driveway after professional jet washing"
            caption="Driveway jet washing — block paving restored"
          />
        </div>
      </div>
      <div class="gallery-grid" style="margin-top:var(--space-l)">
        <div class="gallery-item">
          <img src="/images/before-after/job-portrait-1.webp" alt="Roof cleaning from ground level" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/job-portrait-2.webp" alt="Roof cleaning results" loading="lazy" />
        </div>
        <div class="gallery-item gallery-item--wide">
          <img src="/images/before-after/job-landscape-1.webp" alt="Roof cleaning transformation" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/roof-after-1.webp" alt="Roof after professional cleaning" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/job-square-2.webp" alt="Jet washing completed job" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    C. SERVICE CARDS — horizontal layout with blue left border
    ═══════════════════════════════════════
  */}
  <section class="service-cards-section">
    <div class="container">
      <SectionHeader
        eyebrow="Our Services"
        heading="Explore Each Service"
        body="Click through for full details, before and after photos, FAQs and pricing for each of our professional cleaning services."
      />
      <div class="service-cards-grid">
        {servicesData.map(s => (
          <a href={s.href} class="service-card">
            <div class="service-card__icon">
              {s.id === 'driveway-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="1"/><path d="M5 11V7a2 2 0 012-2h10a2 2 0 012 2v4"/><line x1="3" y1="16" x2="21" y2="16"/></svg>}
              {s.id === 'patio-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>}
              {s.id === 'gutter-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 6l2 12h12l2-12"/><path d="M10 10v4M14 10v4"/><path d="M8 6V4h8v2"/></svg>}
              {s.id === 'roof-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-16 9 16H3z"/><path d="M12 10v6M12 18h.01"/></svg>}
              {s.id === 'render-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>}
              {s.id === 'block-paving-cleaning' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="1" width="10" height="10" rx="1"/><rect x="13" y="1" width="10" height="10" rx="1"/><rect x="1" y="13" width="10" height="10" rx="1"/><rect x="13" y="13" width="10" height="10" rx="1"/></svg>}
            </div>
            <div class="service-card__text">
              <span class="service-card__subtitle">{s.subtitle}</span>
              <h3 class="service-card__title">{s.title}</h3>
              <p class="service-card__desc">{s.description}</p>
            </div>
            <span class="service-card__link">
              View Service
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    D. WHY RG EXTREME PRESSURE — 2-column layout with accent numbers
    ═══════════════════════════════════════
  */}
  <section class="why-strip">
    <div class="container">
      <SectionHeader
        eyebrow="Why Choose RG Extreme Pressure"
        heading="What Sets Us Apart"
        dark={true}
      />
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">01</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Fully Insured Service</h3>
            <p class="why-item__body">Complete public and employer's liability cover on every job. Your property and our workforce are fully protected — no exceptions.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">02</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">10 Years Experience</h3>
            <p class="why-item__body">A decade of professional jet washing and soft wash experience. We know the right pressure and treatment for every surface type — from delicate sandstone to heavy-duty tarmac.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">03</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Honest, Transparent Pricing</h3>
            <p class="why-item__body">No hidden costs, no surprise extras. We provide clear, itemised quotes upfront — what we quote is what you pay.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">04</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Eco-Friendly Products</h3>
            <p class="why-item__body">Biodegradable cleaning solutions and biocide treatments that are safe for your garden, your pets and the environment.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">05</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">27 Five-Star Reviews</h3>
            <p class="why-item__body">Our business is built on repeat work and personal recommendations. That only happens when you deliver — and we do, every time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  {/*
    ═══════════════════════════════════════
    E. TESTIMONIALS
    ═══════════════════════════════════════
  */}
  <section class="testimonials-section">
    <div class="container">
      <SectionHeader
        eyebrow="Verified Google Reviews"
        heading="27 Five-Star Reviews"
      />

      <div class="testimonials-grid">
        {googleReviews.map((review) => (
          <TestimonialBlock
            quote={review.quote}
            name={review.name}
            role={review.service}
            location={review.location}
            stars={review.stars}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ── CTA Banner ── */}
  <ImageCTA
    heading="Ready for a Free Quote?"
    body="Get a free, no-obligation quote from Bath's highest-rated jet washing service. 27 five-star reviews. Fully insured. Eco-friendly products."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after-2.webp"
  />

  {/* ── Review schema ── */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "RG Extreme Pressure",
    "review": googleReviews.map(r => ({
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": String(r.stars), "bestRating": "5" },
      "author": { "@type": "Person", "name": r.name },
      "reviewBody": r.quote
    })),
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "bestRating": "5",
      "worstRating": "1",
      "reviewCount": "27"
    }
  })} />
</Base>

<style>
  /* ── Video Section ── */
  .video-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  /* ── Gallery ── */
  .gallery-section { padding: var(--section-pad) 0; background: var(--stone); }
  .ba-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
    margin-bottom: var(--space-l);
  }
  @media (max-width: 768px) {
    .ba-grid { grid-template-columns: 1fr; }
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }
  .gallery-item {
    overflow: hidden;
    border-radius: 6px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .gallery-item:hover img {
    transform: scale(1.03);
  }
  .gallery-item--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }
  .gallery-item:not(.gallery-item--wide) {
    aspect-ratio: 3/4;
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item--wide { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-item--wide { grid-column: span 1; aspect-ratio: 16/10; }
  }

  .video-wrap {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,85,165,0.1);
  }

  .video-wrap iframe {
    width: 100%;
    height: auto;
    aspect-ratio: 560 / 314;
    display: block;
  }

  /* ── Service Cards — horizontal layout with blue left border ── */
  .service-cards-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
    padding-top: var(--space-l);
  }

  .service-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-m);
    background: #fff;
    border: 1px solid rgba(0,85,165,0.08);
    border-left: 4px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: var(--space-m);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: var(--accent);
    border-left-color: var(--accent);
    box-shadow: 0 4px 20px rgba(0,85,165,0.1);
    transform: translateY(-2px);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 8px;
    background: var(--accent-light);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-card__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .service-card__subtitle {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.25rem);
    font-weight: 800;
    line-height: 1.15;
    text-transform: none;
    color: var(--chalk);
    margin: 0;
  }

  .service-card__desc {
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: auto;
    padding-top: var(--space-xs);
    transition: gap 0.2s;
  }

  .service-card:hover .service-card__link {
    gap: 0.6rem;
  }

  @media (max-width: 1024px) {
    .service-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .service-cards-grid {
      grid-template-columns: 1fr;
    }
    .service-card:hover {
      transform: none;
    }
  }

  /* ── Why RG Extreme Pressure Strip — 2-column layout ── */
  .why-strip {
    background: var(--accent);
    padding: var(--section-pad) 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-l) var(--space-xl);
  }

  .why-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-m);
    padding: var(--space-m);
    background: rgba(255,255,255,0.06);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .why-item__left {
    flex-shrink: 0;
  }

  .why-item__number {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
    color: rgba(255,255,255,0.82);
    display: block;
  }

  .why-item__right {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .why-item__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 800;
    text-transform: none;
    letter-spacing: 0;
    color: #fff;
    margin: 0;
  }

  .why-item__body {
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
    margin: 0;
  }

  /* Last item spans full width if odd */
  .why-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  /* ── Testimonials ── */
  .testimonials-section {
    position: relative;
    padding: var(--section-pad) 0;
    background: var(--accent-light);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-l);
  }

  @media (max-width: 960px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }

  @media (max-width: 768px) {
    .service-card {
      flex-direction: column;
      border-left-width: 4px;
    }
  }

  @media (max-width: 640px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>