---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import FbVideoFacade from '../components/FbVideoFacade.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { servicesData } from '../data/services';
import { googleReviews } from '../data/reviews';
---

<Base title="Jet Washing Bath"
  description="Professional jet washing in Bath. Driveway cleaning, patio cleaning, gutter clearing, roof cleaning, render cleaning and block paving. 111 five-star reviews. Call 07474 939 398."
  preloadImage="/images/hero-home.webp">

  {/*
    ═══════════════════════════════════════
    A. HERO — photo hero with blue overlay
    ═══════════════════════════════════════
  */}
  <Hero
    video="/videos/hero-roof-cleaning.mp4"
    overlay="blue"
    eyebrow="Bath · Bristol · Somerset"
    heading="Professional Jet Washing &amp; Pressure Washing in Bath"
    body="Professional jet washing and specialist cleaning services for driveways, patios, roofs, gutters, render and block paving. 111 five-star reviews. Fully insured. Free quotes."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    ctaSecondary={{ label: 'View Services', href: '/services' }}
  />

  {/*
    ═══════════════════════════════════════
    B. TRUST BAR
    ═══════════════════════════════════════
  */}
  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />


  {/*
    ═══════════════════════════════════════
    B2. VIDEO — See Us In Action
    ═══════════════════════════════════════
  */}
  <section class="video-section">
    <div class="container">
      <SectionHeader
        eyebrow="See Us In Action"
        heading="Watch Our Work"
        body="A quick look at the RG Extreme Pressure difference — professional jet washing that transforms properties across Bath and Bristol."
        align="center"
      />
      <div class="video-wrap">
        <FbVideoFacade
          src="https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2F100091066506303%2Fvideos%2F1751025128677768%2F&show_text=false&width=560&t=0"
          title="RG Extreme Pressure — jet washing in action"
          poster="/images/before-after/roof-after-2.webp"
        />
      </div>
    </div>
  </section>

  {/* ── GALLERY ── */}
  <section class="gallery-section">
    <div class="container">
      <SectionHeader
        eyebrow="Real Results"
        heading="Before &amp; After"
        body="Drag the handle to see the transformation. Every photo is our own work — no stock images."
        align="center"
      />
      <div class="ba-grid">
        <div class="ba-grid__item">
          <BeforeAfter
            beforeSrc="/images/before-after/render-before-1.webp"
            afterSrc="/images/before-after/render-after-1.webp"
            beforeAlt="Render covered in algae before soft wash"
            afterAlt="Render restored after soft wash treatment"
            caption="Render soft wash — algae and staining removed"
          />
        </div>
        <div class="ba-grid__item">
          <BeforeAfter
            beforeSrc="/images/before-after/patio-before-1.webp"
            afterSrc="/images/before-after/patio-after-1.webp"
            beforeAlt="Patio slabs dirty and stained before cleaning"
            afterAlt="Clean patio slabs after professional jet washing"
            caption="Patio cleaning — Indian sandstone restored"
          />
        </div>
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    C. SERVICE CARDS — horizontal layout with blue left border
    ═══════════════════════════════════════
  */}
  <section class="service-cards-section">
    <div class="container">
      <SectionHeader
        eyebrow="Our Services"
        heading="Explore Each Service"
        body="Click through for full details, before and after photos, FAQs and pricing for each of our professional cleaning services."
      />
      <div class="service-cards-grid">
        {servicesData.map(s => (
          <ServiceCard href={s.href} image={s.image} title={s.title} subtitle={s.subtitle} description={s.description} />
        ))}
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    D. WHY RG EXTREME PRESSURE — 2-column layout with accent numbers
    ═══════════════════════════════════════
  */}
  <section class="why-strip">
    <div class="container">
      <SectionHeader
        eyebrow="Why Choose RG Extreme Pressure"
        heading="What Sets Us Apart"
        dark={true}
      />
      <div class="why-grid">
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">01</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Fully Insured Service</h3>
            <p class="why-item__body">Complete public and employer's liability cover on every job. Your property and our workforce are fully protected — no exceptions.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">02</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">10 Years Experience</h3>
            <p class="why-item__body">A decade of professional jet washing and soft wash experience. We know the right pressure and treatment for every surface type — from delicate sandstone to heavy-duty tarmac.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">03</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Honest, Transparent Pricing</h3>
            <p class="why-item__body">No hidden costs, no surprise extras. We provide clear, itemised quotes upfront — what we quote is what you pay.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">04</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">Eco-Friendly Products</h3>
            <p class="why-item__body">Biodegradable cleaning solutions and biocide treatments that are safe for your garden, your pets and the environment.</p>
          </div>
        </div>
        <div class="why-item">
          <div class="why-item__left">
            <span class="why-item__number" aria-hidden="true">05</span>
          </div>
          <div class="why-item__right">
            <h3 class="why-item__title">111 Five-Star Reviews</h3>
            <p class="why-item__body">Our business is built on repeat work and personal recommendations. That only happens when you deliver — and we do, every time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  {/*
    ═══════════════════════════════════════
    E. TESTIMONIALS
    ═══════════════════════════════════════
  */}
  <section class="testimonials-section">
    <div class="container">

      <div class="reviews-header">
        <div class="reviews-header__google">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <div class="reviews-header__score">
            <span class="reviews-header__number">5.0</span>
            <div class="reviews-header__stars">
              {[1,2,3,4,5].map(() => (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#FBBC05"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="reviews-header__count">111 verified Google reviews</span>
          </div>
        </div>
        <p class="reviews-header__sub">Bath & Bristol's highest-rated jet washing service</p>
      </div>

      <div class="testimonials-grid">
        {googleReviews.map((review) => (
          <TestimonialBlock
            quote={review.quote}
            name={review.name}
            role={review.service}
            location={review.location}
            stars={review.stars}
            dark={true}
          />
        ))}
      </div>

      <div class="reviews-footer">
        <a href="https://www.google.com/search?q=RG+Extreme+Pressure+Bath+reviews" target="_blank" rel="noopener noreferrer" class="reviews-footer__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Read all 111 reviews on Google
        </a>
      </div>

    </div>
  </section>

  {/* ── CTA Banner ── */}
  <ImageCTA
    heading="Ready for a Free Quote?"
    body="Get a free, no-obligation quote from Bath's highest-rated jet washing service. 111 five-star reviews. Fully insured. Eco-friendly products."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after-2.webp"
  />

  {/* ── Review schema — attached to the main LocalBusiness entity ── */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://rgextremepressure.co.uk/#organization",
    "review": googleReviews.map(r => ({
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": String(r.stars), "bestRating": "5", "worstRating": "1" },
      "author": { "@type": "Person", "name": r.name },
      "reviewBody": r.quote
    }))
  })} />
</Base>

<style>
  /* ── Video Section ── */
  .video-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  /* ── Gallery ── */
  .gallery-section { padding: var(--section-pad) 0; background: var(--stone); }
  .ba-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
    margin-bottom: var(--space-l);
  }
  @media (max-width: 768px) {
    .ba-grid { grid-template-columns: 1fr; }
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }
  .gallery-item {
    overflow: hidden;
    border-radius: 6px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .gallery-item:hover img {
    transform: scale(1.03);
  }
  .gallery-item--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }
  .gallery-item:not(.gallery-item--wide) {
    aspect-ratio: 3/4;
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item--wide { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-item--wide { grid-column: span 1; aspect-ratio: 16/10; }
  }

  .video-wrap {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,85,165,0.1);
  }

  .video-wrap iframe {
    width: 100%;
    height: auto;
    aspect-ratio: 560 / 314;
    display: block;
  }

  .service-cards-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
    padding-top: var(--space-l);
  }

  @media (max-width: 1024px) {
    .service-cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .service-cards-grid { grid-template-columns: 1fr; }
  }

  /* ── Why RG Extreme Pressure Strip — 2-column layout ── */
  .why-strip {
    background: var(--accent);
    padding: var(--section-pad) 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl) var(--space-2xl);
  }

  .why-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-l);
    padding: var(--space-l);
    background: rgba(255,255,255,0.06);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .why-item__left {
    flex-shrink: 0;
  }

  .why-item__number {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
    color: rgba(255,255,255,0.82);
    display: block;
  }

  .why-item__right {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .why-item__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 800;
    text-transform: none;
    letter-spacing: 0;
    color: #fff;
    margin: 0;
  }

  .why-item__body {
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
    margin: 0;
  }

  /* Last item spans full width if odd */
  .why-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  /* ── Testimonials ── */
  .testimonials-section {
    position: relative;
    padding: var(--section-pad) 0;
    background: var(--navy);
  }

  .reviews-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .reviews-header__google {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 1rem 2rem;
    margin-bottom: 1rem;
  }

  .reviews-header__score {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .reviews-header__number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .reviews-header__stars {
    display: flex;
    gap: 2px;
  }

  .reviews-header__count {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.02em;
  }

  .reviews-header__sub {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    margin: 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-xl);
  }

  .reviews-footer {
    text-align: center;
    margin-top: var(--space-xl);
  }

  .reviews-footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 0.65rem 1.4rem;
    transition: all 0.2s;
  }

  .reviews-footer__link:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.06);
  }

  @media (max-width: 960px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }

  @media (max-width: 768px) {
    .service-card {
      flex-direction: column;
      border-left-width: 4px;
    }
  }

  @media (max-width: 640px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>