---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ImageCTA from '../components/ImageCTA.astro';
import { servicesData } from '../data/services';
import { srcset } from '../utils/srcset';
---

<Base title="Builders & Property Maintenance in Bath"
  description="Loft conversions, extensions, heritage restoration and property maintenance across Bath. Fixed quotes, clean sites, fully insured."
  preloadImage="/images/hero-james-bath-property-1.webp">
  {/*
    ═══════════════════════════════════════
    A. DARK LUXURY HERO FOLD
    ═══════════════════════════════════════
  */}
  <Hero
    image="/images/hero-james-bath-property-1.webp"
    overlay="left"
    eyebrow="Bath · BANES · Wiltshire"
    heading="We Build Bath's<br>Best Projects<span class='gold-period'>.</span>"
    body="From Georgian stone restorations to contemporary extensions — fixed quotes, clean sites, zero surprises."
    cta={{ label: 'Start a Project', href: '/contact' }}
    ctaSecondary={{ label: 'View Projects', href: '/projects' }}
  />

  {/*
    ═══════════════════════════════════════
    B. EDITORIAL SERVICE PILLARS
    Alternating split rows — image left, then image right
    ═══════════════════════════════════════
  */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        eyebrow="What We Deliver"
        heading="Six Services. One Standard."
        body="Every project — whether a heritage restoration in Bathwick or a modern extension in Keynsham — is governed by the same rigorous process."
      />

      <div class="pillars">
        {servicesData.map((pillar, i) => {
          const isReversed = i % 2 === 1;
          return (
            <div class:list={['pillar-row', isReversed && 'pillar-row--reversed']}>
              <div class="pillar-row__image">
                {pillar.video ? (
                  <video
                    src={pillar.video}
                    poster={pillar.videoPoster || undefined}
                    muted
                    controls
                    playsinline
                    preload="metadata"
                  >
                    <track kind="captions" srclang="en" label="English" default />
                  </video>
                ) : (
                  <img src={pillar.image} alt={pillar.subtitle} loading="lazy" decoding="async" srcset={srcset(pillar.image)} sizes="(max-width: 768px) 100vw, 40vw" />
                )}
              </div>
              <div class="pillar-row__text">
                <span class="t-label" style="color:var(--accent-dim)">{pillar.subtitle}</span>
                <h3 class="pillar-row__title">{pillar.title}</h3>
                <p class="pillar-row__desc">{pillar.description}</p>
                <ul class="pillar-row__features">
                  {pillar.features.map((feat) => (
                    <li>
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="pillar-row__check">
                        <path d="M2 7l3.5 3.5L12 3" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {feat}
                    </li>
                  ))}
                </ul>
                <a href={pillar.href} class="pillar-row__link" aria-label={`Explore ${pillar.title} service`}>
                  Explore this service
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
                    <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    C. WHY ASPECT — Differentiator strip
    ═══════════════════════════════════════
  */}
  <section class="why-strip">
    <div class="container">
      <SectionHeader
        eyebrow="Why Choose Aspect Builds"
        heading="What Sets Us Apart"
        dark={true}
      />
      <div class="why-grid">
        <div class="why-item">
          <span class="why-item__number" aria-hidden="true">01</span>
          <h3 class="why-item__title">Fully Insured Service</h3>
          <p class="why-item__body">Complete public and employer's liability cover on every project. Your property and our workforce are fully protected — no exceptions.</p>
        </div>
        <div class="why-item">
          <span class="why-item__number" aria-hidden="true">02</span>
          <h3 class="why-item__title">CSCS Cardholders &amp; Qualified</h3>
          <p class="why-item__body">Every on-site team member holds valid CSCS cards and industry-recognized qualifications (City &amp; Guilds / NVQ), ensuring the highest standards of safety and craftsmanship.</p>
        </div>
        <div class="why-item">
          <span class="why-item__number" aria-hidden="true">03</span>
          <h3 class="why-item__title">Honest, Transparent Pricing</h3>
          <p class="why-item__body">No hidden costs, no surprise extras. We provide clear, itemised quotes upfront — what we quote is what you pay.</p>
        </div>
        <div class="why-item">
          <span class="why-item__number" aria-hidden="true">04</span>
          <h3 class="why-item__title">Clean, Respectful Sites</h3>
          <p class="why-item__body">Dust sheets, daily tidy-ups, and protected access routes. Your home gets treated like our own — we leave it spotless.</p>
        </div>
        <div class="why-item">
          <span class="why-item__number" aria-hidden="true">05</span>
          <h3 class="why-item__title">Reputation Earned</h3>
          <p class="why-item__body">Our business is built on repeat work and personal recommendations. That only happens when you deliver — and we do, every time.</p>
        </div>
      </div>
    </div>
  </section>


  {/*
    ═══════════════════════════════════════
    E. TESTIMONIALS
    ═══════════════════════════════════════
  */}
  <section class="testimonials-section">
    <div class="testimonials-bg" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1">
      <SectionHeader
        eyebrow="Verified Client Reviews"
        heading="What Our Clients Say"
        dark={true}
      />

      <div class="testimonials-grid">
        <TestimonialBlock
          quote="I couldn't recommend Aspect Builds highly enough for the landscaping and garden build they completed for us. From the initial design to the final handover, the team was professional, communicative, and genuinely invested in getting the details right. The quality of workmanship is excellent. Site was kept tidy, timeframes were clear, and any issues were handled quickly with no fuss."
          name="Cole Hulbert"
          role="Landscaping & Garden Build"
          stars={5}
          dark={true}
        />
        <TestimonialBlock
          quote="I have worked with Aspect on several projects. I have always found James approachable with Aspect working to a high standard."
          name="Timothy"
          role="Multiple Projects"
          stars={5}
          dark={true}
        />
        <TestimonialBlock
          quote="Very happy with work. James Martin decorated 2 rooms for us. Very reliable and clean and tidy. Arrived on time every day and work was very satisfactory. Would highly recommend."
          name="Amy"
          role="Interior Decoration"
          stars={5}
          dark={true}
        />
      </div>

      <div style="display:flex;justify-content:center;margin-top:var(--space-xl)">
        <a
          href="https://www.trustatrader.com/traders/aspect-builds-maintenance-ltd-interior-refurbishment-bath-south"
          target="_blank"
          rel="noopener noreferrer"
          class="trustatrader-badge trustatrader-badge--dark"
          aria-label="4.97 out of 5 from 12 verified reviews on TrustATrader"
        >
          <img src="/images/trustatrader-logo.svg" alt="TrustATrader" width="72" height="72" loading="lazy" />
          <span class="trustatrader-badge__text">
            <strong>4.97 / 5</strong>
            <span>12 verified reviews on TrustATrader</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  {/*
    ═══════════════════════════════════════
    F. SELECTED PROJECTS
    ═══════════════════════════════════════
  */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        eyebrow="Recent Work"
        heading="Selected Projects"
        body="From heritage restorations in Central Bath to modern extensions in Keynsham — see how we deliver."
      />

      <div class="projects-showcase">
        {/* ── Featured hero project (large, left) ── */}
        <a href="/projects/bath-loft-extension" class="project-card project-card--featured">
          <div class="project-card__image">
            <img src="/images/hero-bath-loft-extension.webp" alt="Bath Loft Extension" width="800" height="600" loading="lazy" />
          </div>
          <div class="project-card__overlay">
            <span class="t-label" style="color:var(--accent)">Loft Conversions</span>
            <h3 class="project-card__title">Bath Loft Extension</h3>
            <p class="project-card__body">Full top-floor loft conversion — four rooms, ensuite, new staircase and two Juliet balconies.</p>
            <span class="project-card__cta">View project</span>
          </div>
        </a>

        {/* ── Four stacked side projects (right) ── */}
        <div class="project-card__side">
          <a href="/projects/medford-garden-extension" class="project-card project-card--small">
            <div class="project-card__image">
              <img src="/images/hero-james-bath-property-5.webp" alt="Medford Garden Extension" width="600" height="450" loading="lazy" />
            </div>
            <div class="project-card__content">
              <span class="t-label" style="color:var(--accent-dim);font-size:0.65rem">Extensions</span>
              <h3 class="project-card__title-sm">Medford Garden Extension</h3>
              <p class="project-card__body-sm">Open-plan living with full-width glazing and seamless garden connection.</p>
            </div>
          </a>
          <a href="/projects/chilcompton-rendering-decoration" class="project-card project-card--small">
            <div class="project-card__image">
              <img src="/images/hero-chilcompton-rendering.webp" alt="Chilcompton Rendering" width="600" height="450" loading="lazy" />
            </div>
            <div class="project-card__content">
              <span class="t-label" style="color:var(--accent-dim);font-size:0.65rem">Heritage</span>
              <h3 class="project-card__title-sm">Chilcompton Rendering</h3>
              <p class="project-card__body-sm">Exterior rendering — crisp, weatherproof finish on a tired facade.</p>
            </div>
          </a>
          <a href="/projects/bath-countryside-landscaping" class="project-card project-card--small">
            <div class="project-card__image">
              <img src="/images/bath-landscaping-1.webp" alt="Bath Countryside Landscaping" width="600" height="450" loading="lazy" />
            </div>
            <div class="project-card__content">
              <span class="t-label" style="color:var(--accent-dim);font-size:0.65rem">Landscaping</span>
              <h3 class="project-card__title-sm">Bath Countryside Landscaping</h3>
              <p class="project-card__body-sm">Cobble borders, sandstone paving, greenhouse on reclaimed brick.</p>
            </div>
          </a>
          <a href="/projects/frome-garage-conversion" class="project-card project-card--small">
            <div class="project-card__image">
              <img src="/images/hero-frome-garage-conversion.webp" alt="Frome Garage Conversion" width="600" height="450" loading="lazy" />
            </div>
            <div class="project-card__content">
              <span class="t-label" style="color:var(--accent-dim);font-size:0.65rem">Conversions</span>
              <h3 class="project-card__title-sm">Frome Garage Conversion</h3>
              <p class="project-card__body-sm">Unused garage transformed into warm, habitable living space.</p>
            </div>
          </a>
        </div>
      </div>

      <div style="text-align:center;margin-top:var(--space-xl)">
        <a href="/projects" class="btn btn--primary">
          View All Projects
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-left:0.4rem">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready to Start Your Project?"
    body="Get a fixed, transparent quote from a local team that treats your home like their own."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-james-bath-property-3.webp"
  />

  {/* ── Review schema — only on this page where reviews are displayed ── */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "Aspect Builds & Maintenance Ltd",
    "review": [
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Cole Hulbert" },
        "reviewBody": "I couldn't recommend Aspect Builds highly enough for the landscaping and garden build they completed for us. From the initial design to the final handover, the team was professional, communicative, and genuinely invested in getting the details right. The quality of workmanship is excellent. Site was kept tidy, timeframes were clear, and any issues were handled quickly with no fuss.",
        "datePublished": "2026-02-16",
        "publisher": { "@type": "Organization", "name": "TrustATrader" }
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Timothy" },
        "reviewBody": "I have worked with Aspect on several projects. I have always found James approachable with Aspect working to a high standard.",
        "datePublished": "2026-02-16",
        "publisher": { "@type": "Organization", "name": "TrustATrader" }
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Amy" },
        "reviewBody": "Very happy with work. James Martin decorated 2 rooms for us. Very reliable and clean and tidy. Arrived on time every day and work was very satisfactory. Would highly recommend.",
        "datePublished": "2026-03-06",
        "publisher": { "@type": "Organization", "name": "TrustATrader" }
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Barbara" },
        "reviewBody": "Aspect did an amazing job painting my house. They were efficient, friendly, tidy and I would definitely use them again. Can't fault them.",
        "datePublished": "2026-06-01",
        "publisher": { "@type": "Organization", "name": "TrustATrader" }
      }
    ]
  })} />
</Base>

<style>
  /* ── Gold period on hero heading ── */
  :global(.gold-period) {
    color: var(--accent);
  }

  /* ── Editorial Pillar Split Rows ── */
  .pillars {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl, 6rem);
    margin-top: var(--space-2xl);
  }

  .pillar-row {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .pillar-row--reversed {
    grid-template-columns: 5fr 7fr;
  }

  .pillar-row--reversed .pillar-row__image {
    order: 2;
  }

  .pillar-row--reversed .pillar-row__text {
    order: 1;
  }

  .pillar-row__image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--stone);
  }

  .pillar-row__image img,
  .pillar-row__image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .pillar-row:hover .pillar-row__image img,
  .pillar-row:hover .pillar-row__image video {
    transform: scale(1.03);
  }

  .pillar-row__text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pillar-row__text .t-label {
    display: block;
    margin-bottom: 0.25rem;
  }

  .pillar-row__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--chalk);
    margin: 0;
  }

  .pillar-row__desc {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--concrete);
    margin: 0;
    max-width: 42ch;
  }

  .pillar-row__features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pillar-row__features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 400;
    color: var(--chalk);
  }

  .pillar-row__check {
    flex-shrink: 0;
  }

  .pillar-row__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-dim);
    text-decoration: none;
    margin-top: var(--space-m);
    transition: gap 0.2s;
  }

  .pillar-row__link:hover {
    gap: 0.7rem;
  }

  /* ── Why Aspect Strip ── */
  .why-strip {
    background: var(--navy);
    padding: var(--section-pad) 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-xl);
  }

  .why-item {
    padding-left: var(--space-l);
    border-left: 2px solid var(--accent);
  }

  .why-item__number {
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.7;
    display: block;
    margin-bottom: var(--space-s);
  }

  .why-item__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .why-item__body {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.62);
    margin: 0;
  }

  /* ── Testimonials ── */
  .testimonials-section {
    position: relative;
    padding: var(--section-pad) 0;
    background: var(--navy);
    overflow: hidden;
  }

  .testimonials-bg {
    position: absolute;
    inset: 0;
    background: url('/images/hero-james-bath-property-5.webp') center 40% / cover no-repeat;
    opacity: 0.08;
    pointer-events: none;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    margin-top: var(--space-2xl);
  }

  .trustatrader-badge {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .trustatrader-badge:hover { opacity: 0.8; }

  .trustatrader-badge__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .trustatrader-badge__text strong {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.04em;
    color: var(--chalk);
  }

  .trustatrader-badge__text span {
    font-size: 0.8rem;
    color: var(--concrete);
  }

  .trustatrader-badge--dark .trustatrader-badge__text strong {
    color: #fff;
  }

  .trustatrader-badge--dark .trustatrader-badge__text span {
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Project Showcase ── */
  .projects-showcase {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-l);
    margin-top: var(--space-2xl);
  }

  /* Featured hero card — full bleed overlay */
  .project-card {
    text-decoration: none;
    color: inherit;
  }

  .project-card--featured {
    position: relative;
    display: block;
    overflow: hidden;
  }

  .project-card__image {
    position: relative;
    overflow: hidden;
    background: var(--stone);
  }

  .project-card--featured .project-card__image {
    aspect-ratio: 3 / 4;
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .project-card:hover .project-card__image img {
    transform: scale(1.04);
  }

  /* Overlay on featured card */
  .project-card--featured .project-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xl) var(--space-l);
    background: linear-gradient(to top, rgba(13,21,32,0.92) 0%, rgba(13,21,32,0.6) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-card--featured .project-card__overlay .t-label {
    margin-bottom: 0.2rem;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0;
  }

  .project-card__body {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255,255,255,0.72);
    margin: 0;
    max-width: 36ch;
  }

  .project-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: var(--space-s);
    transition: gap 0.2s;
  }

  .project-card--featured:hover .project-card__cta {
    gap: 0.7rem;
  }

  /* Side cards — horizontal layout */
  .project-card__side {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .project-card--small {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-m);
    align-items: center;
    overflow: hidden;
  }

  .project-card--small .project-card__image {
    aspect-ratio: 1 / 1;
  }

  .project-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .project-card__title-sm {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--chalk);
    margin: 0;
    transition: color 0.2s;
  }

  .project-card--small:hover .project-card__title-sm {
    color: var(--accent);
  }

  .project-card__body-sm {
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .pillar-row,
