---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import ImageCTA from '../components/ImageCTA.astro';
import { getCollection } from 'astro:content';

const portfolio = await getCollection('portfolio');

const projects = portfolio.map((entry) => ({
  title: entry.data.title,
  slug: entry.id,
  location: entry.data.location,
  category: entry.data.category,
  categoryLabel: entry.data.categoryLabel,
  image: entry.data.image,
}));
---

<Base title="Projects — Aspect Builds & Maintenance" preloadImage="/images/hero-larkhall-extension.jpg">
  <Hero
    image="/images/hero-larkhall-extension.jpg"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Projects' }]}
    eyebrow="Our work"
    heading="Built.<br>Delivered.<br>Proven."
    body={`${projects.length} completed projects across Bath and BANES. Every one delivered on time, on budget, and to a standard we put our name on.`}
  />

  <PortfolioGrid projects={projects} />

  <ImageCTA
    heading="Ready to Start Your Project?"
    body="Get a fixed-price quote from a team that delivers on budget, on time — every time."
    cta={{ label: 'Get a Quote', href: '/contact' }}
    image="/images/hero-larkhall-extension.jpg"
  />
</Base>