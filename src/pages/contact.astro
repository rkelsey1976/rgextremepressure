---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ContactSidebar from '../components/forms/ContactSidebar.astro';
import MainContactForm from '../components/forms/MainContactForm.astro';
---

<Base title="Arrange a Consultation | Aspect Builds & Maintenance" preloadImage="/images/hero-james-bath-property-3.webp">
  <Hero
    image="/images/hero-james-bath-property-3.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
    eyebrow="Get in touch"
    heading="Arrange a Consultation"
    body="Whether you're planning an extension, a loft conversion, or a full new build — we'd rather hear from you early. The sooner we're involved, the smoother the process."
    minHeight="compact"
  />

  {/* ── Testimonial strip ── */}
  <section style="background:var(--chalk);padding:var(--space-2xl) 0">
    <div class="container" style="max-width:48rem">
      <TestimonialBlock
        quote="I couldn't recommend Aspect Builds highly enough. From the initial design to the final handover, the team was professional, communicative, and genuinely invested in getting the details right. Site was kept tidy, timeframes were clear, and any issues were handled quickly with no fuss."
        name="Cole Hulbert"
        role="Landscaping & Garden Build · TrustATrader Verified"
        dark={true}
      />
    </div>
  </section>

  {/* ── Contact Section: Sidebar + Form ── */}
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        {/* Left: Sidebar */}
        <div class="contact-grid__sidebar">
          <ContactSidebar />
        </div>

        {/* Right: Form */}
        <div class="contact-grid__form">
          <MainContactForm />
        </div>

      </div>
    </div>
  </section>
</Base>

<style>
  .contact-section {
    padding-block: var(--section-pad);
    background: var(--stone);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-3xl, 5rem);
    align-items: start;
  }

  .contact-grid__form {
    background: #fff;
    border: 1px solid var(--stone);
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  @media (max-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>