---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ContactSidebar from '../components/forms/ContactSidebar.astro';
import MainContactForm from '../components/forms/MainContactForm.astro';
---

<Base title="Get a Free Quote"
  description="Get a free, no-obligation quote for jet washing and pressure washing in Bath and Bristol. Driveway, patio, gutter, roof and render cleaning. Call 07474 939 398."
  >
  <Hero
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
    eyebrow="Get in Touch"
    heading="Get a Free Quote"
    body="Call 07474 939 398 or fill in the form below. We cover Bath, Bristol and all surrounding areas."
    image="/images/before-after/drive-after.jpg"
    overlay="blue"
    minHeight="compact"
  />

  <TrustMetrics />

  {/* ── Testimonial strip ── */}
  <section style="background:var(--chalk);padding:var(--space-2xl) 0">
    <div class="container" style="max-width:48rem">
      <TestimonialBlock
        quote="Robert did a fantastic job on our driveway and patio. Years of grime gone in a few hours — they look brand new. Professional, on time, and great value. We've already booked him for the roof next."
        name="Sarah"
        role="Driveway & Patio Cleaning · Bath"
      />
    </div>
  </section>

  {/* ── Contact Section: Sidebar + Form ── */}
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        {/* Left: Sidebar */}
        <div class="contact-grid__sidebar">
          <ContactSidebar />
        </div>

        {/* Right: Form */}
        <div class="contact-grid__form">
          <MainContactForm />
        </div>

      </div>
    </div>
  </section>
</Base>

<style>
  .contact-section {
    padding-block: var(--section-pad);
    background: var(--stone);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-3xl, 5rem);
    align-items: start;
  }

  .contact-grid__form {
    background: #fff;
    border: 1px solid var(--stone);
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  @media (max-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>