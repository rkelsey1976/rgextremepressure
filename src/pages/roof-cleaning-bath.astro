---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';

const title = 'Roof Cleaning Bath';
const description = 'Professional roof cleaning in Bath using specialist spinning brush systems. Moss removal, algae treatment and full gutter clear. 111 five-star reviews. Call 07474 939 398.';

const faqs = [
  {
    q: 'Is pressure washing safe for roof tiles?',
    a: 'Yes — when done with the right equipment. We use specialist spinning brush heads on telescopic lances, not a pressure washer held directly against the tiles. The brush head rotates at controlled speed, cleaning the surface evenly without concentrated pressure on any one point. No walking on your roof, no risk of cracking tiles.'
  },
  {
    q: 'What makes your method different from a standard pressure washer?',
    a: 'A standard pressure washer blasts a concentrated jet of water at close range — that can crack tiles, strip mortar and drive water under the roof covering. Our spinning brush system uses controlled water flow with soft rotating bristles that agitate and lift moss, algae and dirt without concentrated pressure. The brush head is designed specifically for roof cleaning.'
  },
  {
    q: 'Will you remove moss by hand first?',
    a: 'Yes. Thick moss growth is manually scraped from the roof before we begin washing. This removes the bulk of the growth so the spinning brush can clean right down to the tile surface.'
  },
  {
    q: 'Do you clean gutters after roof cleaning?',
    a: 'Absolutely. Moss and debris removed from the roof inevitably ends up in the gutters. We include a full gutter clear and downpipe flush with every roof cleaning job — no extra charge.'
  },
  {
    q: 'How long does a roof clean last?',
    a: 'A professional clean with biocide treatment typically keeps roofs clean for 3-5 years depending on proximity to trees, aspect and local conditions. The biocide kills spores at the root, preventing rapid regrowth.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Cleaning Bath",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": [{ "@type": "City", "name": "Bath" }, { "@type": "City", "name": "Bristol" }],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" }
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[
  { name: 'Services', item: 'https://rgextremepressure.co.uk/services' },
  { name: 'Roof Cleaning Bath', item: 'https://rgextremepressure.co.uk/roof-cleaning-bath' }
]}>
  <Hero
    image="/images/before-after/job-gallery-25.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Roof Cleaning' }]}
    eyebrow="Professional Roof Cleaning"
    heading="Roof Cleaning Bath"
    body="Moss, algae and lichen eat into roof tiles, causing cracks, leaks and expensive repairs. Our specialist spinning brush system cleans your roof safely from ground level — no walking on tiles, no concentrated pressure."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
  minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="What We Do"
            heading="Specialist Roof Cleaning"
            body="We clean roofs using professional spinning brush heads mounted on telescopic lances — the same system trusted by professional exterior cleaning companies across the UK. The rotating brush agitates and lifts moss, algae and dirt without blasting concentrated water at your tiles."
          />

          <div class="service-intro-image">
            <img src="/images/before-after/job-roof-action-3.webp" alt="Robert cleaning roof tiles with specialist spinning brush equipment" loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">What Our Roof Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Spinning Brush Cleaning</strong>
                  <p class="feature-card__body">Specialist rotating brush heads clean evenly without concentrated pressure on any one tile.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Telescopic Lance System</strong>
                  <p class="feature-card__body">Reach from ground level or ladder — no walking on your roof, no risk of damage.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Manual Moss Removal</strong>
                  <p class="feature-card__body">Thick moss scraped by hand before treatment begins — thorough prep is what makes the difference.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Biocide Anti-Growth Treatment</strong>
                  <p class="feature-card__body">Kills spores at the root and prevents regrowth for up to 5 years.</p>
                  <span class="feature-card__badge">Pure Seal Approved Applicator</span>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Gutter &amp; Valley Clear</strong>
                  <p class="feature-card__body">All moss debris cleared from gutters and roof valleys so everything drains freely.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Tile Condition Report</strong>
                  <p class="feature-card__body">We flag any cracked, slipped or missing tiles found during the clean — no extra charge.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to book? Get a free, no-obligation quote today.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Method" heading="Why Our Spinning Brush System Works" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">Standard Pressure Washer</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Concentrated jet can crack tiles at close range
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Requires walking on the roof — risk of tile damage
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Strips mortar from ridge and hip joints
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Drives water under tiles causing leaks
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Our Spinning Brush System</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Rotating brush head distributes pressure evenly
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Operated from ground level — no walking on roof
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Soft bristles clean without stripping mortar
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Controlled water flow — no water forced under tiles
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Safe, thorough clean — no damage, no leaks, no voided warranties
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Roof Survey</h4>
                  <p class="process-step__body">We assess tile type, moss levels, access requirements and any existing damage before we start.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Manual Moss Removal</h4>
                  <p class="process-step__body">Thick growth is scraped by hand from the roof surface — no blasting, no cracked tiles.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Spinning Brush Clean</h4>
                  <p class="process-step__body">Our specialist rotating brush head cleans evenly across the surface from ground level or ladder.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Biocide Treatment</h4>
                  <p class="process-step__body">An anti-growth solution kills remaining spores at the root and prevents regrowth for up to 5 years.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Gutter Clear</h4>
                  <p class="process-step__body">All debris is removed from gutters and downpipes so everything drains cleanly.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Moss causing you concern? We can usually quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Protect Your Roof Today</h3>
            <p class="sidebar-card__body">Moss causes cracked tiles and leaks. Our specialist spinning brush system cleans safely from ground level. Get a free, no-obligation quote.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
            <div class="sidebar-accreditation">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <p>Robert is a <strong>Pure Seal Approved Applicator</strong> — trained and certified by the UK's leading external cleaning chemical specialists. We only use their licensed, professional-grade biocides.</p>
            </div>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Other Services</span>
            <h3 class="sidebar-card__heading">Explore Our Services</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bath">Driveway Cleaning Bath</a></li>
              <li><a href="/patio-cleaning-bath">Patio Cleaning Bath</a></li>
              <li><a href="/gutter-cleaning-bath">Gutter Cleaning Bath</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning Bath</a></li>
              <li><a href="/driveway-cleaning-bath">Block Paving Cleaning Bath</a></li>
              <li><a href="/bristol/">Jet Washing Bristol</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body="Real results from jobs across Bath and Bristol." align="center" />
      <div class="before-after-wrap">
        <img src="/images/before-after/job-gallery-25.webp" alt="Same roof mid-clean — left side black with moss and algae, right side restored to clean terracotta" class="before-after-composite" />
        <p class="before-after-caption">Same roof, same day — half cleaned to show the transformation. This is what our spinning brush system does.</p>
      </div>
      <div class="photo-library">
        <div class="photo-library__header">
          <p class="photo-library__sub">More photos from recent jobs</p>
          <span class="photo-library__count">6 photos</span>
        </div>
        <div class="photo-library__grid">
          <a href="/images/before-after/job-gallery-25.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: roof tiles half-cleaned showing dramatic contrast">
            <img src="/images/before-after/job-gallery-25.webp" alt="Roof tiles half-cleaned showing dramatic before and after contrast" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-roof-action-3.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: Robert cleaning roof tiles">
            <img src="/images/before-after/job-roof-action-3.webp" alt="Robert cleaning roof tiles with specialist equipment" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-roof-scaffold-2.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: roof cleaning on scaffold">
            <img src="/images/before-after/job-roof-scaffold-2.webp" alt="Roof cleaning on scaffold at Somerset property" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-roof-after-cottage.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: stone cottage clean roof">
            <img src="/images/before-after/job-roof-after-cottage.webp" alt="Stone cottage with clean roof after professional treatment" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/roof-after-4.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: aerial view clean roof">
            <img src="/images/before-after/roof-after-4.webp" alt="Aerial view of clean roof after moss removal" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/roof-cleaning-action.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: roof cleaning in action">
            <img src="/images/before-after/roof-cleaning-action.webp" alt="Roof cleaning in action — spinning brush system at work" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">

    <div class="container">
