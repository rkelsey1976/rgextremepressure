---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ImageCTA from '../components/ImageCTA.astro';

const title = 'Roof Cleaning Bath';
const description = 'Professional roof cleaning in Bath using specialist spinning brush systems. Moss removal, algae treatment and full gutter clear. 111 five-star reviews. Call 07474 939 398.';

const faqs = [
  {
    q: 'Is pressure washing safe for roof tiles?',
    a: 'Yes — when done with the right equipment. We use specialist spinning brush heads on telescopic lances, not a pressure washer held directly against the tiles. The brush head rotates at controlled speed, cleaning the surface evenly without concentrated pressure on any one point. No walking on your roof, no risk of cracking tiles.'
  },
  {
    q: 'What makes your method different from a standard pressure washer?',
    a: 'A standard pressure washer blasts a concentrated jet of water at close range — that can crack tiles, strip mortar and drive water under the roof covering. Our spinning brush system uses controlled water flow with soft rotating bristles that agitate and lift moss, algae and dirt without concentrated pressure. The brush head is designed specifically for roof cleaning.'
  },
  {
    q: 'Will you remove moss by hand first?',
    a: 'Yes. Thick moss growth is manually scraped from the roof before we begin washing. This removes the bulk of the growth so the spinning brush can clean right down to the tile surface.'
  },
  {
    q: 'Do you clean gutters after roof cleaning?',
    a: 'Absolutely. Moss and debris removed from the roof inevitably ends up in the gutters. We include a full gutter clear and downpipe flush with every roof cleaning job — no extra charge.'
  },
  {
    q: 'How long does a roof clean last?',
    a: 'A professional clean with biocide treatment typically keeps roofs clean for 3-5 years depending on proximity to trees, aspect and local conditions. The biocide kills spores at the root, preventing rapid regrowth.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Cleaning Bath",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": [{ "@type": "City", "name": "Bath" }, { "@type": "City", "name": "Bristol" }],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" }
};
---

<Base {title} {description} serviceSchema={serviceSchema}>
  <Hero
    image="/images/before-after/roof-after-1.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Roof Cleaning' }]}
    eyebrow="Professional Roof Cleaning"
    heading="Roof Cleaning Bath"
    body="Moss, algae and lichen eat into roof tiles, causing cracks, leaks and expensive repairs. Our specialist spinning brush system cleans your roof safely from ground level — no walking on tiles, no concentrated pressure."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="What We Do"
            heading="Specialist Roof Cleaning"
            body="We clean roofs using professional spinning brush heads mounted on telescopic lances — the same system trusted by professional exterior cleaning companies across the UK. The rotating brush agitates and lifts moss, algae and dirt without blasting concentrated water at your tiles."
          />

          <div class="service-features">
            <h3 class="service-features__title">What Our Roof Cleaning Includes</h3>
            <ul class="service-features__list">
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Spinning brush cleaning</strong> — specialist rotating brush heads clean evenly without concentrated pressure on any one tile</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Telescopic lance system</strong> — reach from ground level or ladder, no walking on your roof</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Manual moss removal</strong> — thick moss scraped by hand before treatment begins</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Biocide anti-growth treatment</strong> — kills spores at the root, prevents regrowth for up to 5 years</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Gutter and valley clear</strong> — all moss debris removed from gutters and roof valleys</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Tile condition report</strong> — we flag any cracked, slipped or missing tiles found during cleaning</span>
              </li>
            </ul>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Method" heading="Why Our Spinning Brush System Works" />
            <div class="method-grid">
              <div class="method-card method-card--bad">
                <span class="method-card__icon">&#10060;</span>
                <h4 class="method-card__title">Standard Pressure Washer</h4>
                <ul class="method-card__list">
                  <li>Concentrated jet can crack tiles at close range</li>
                  <li>Requires walking on the roof — risk of tile damage</li>
                  <li>Strips mortar from ridge and hip joints</li>
                  <li>Drives water under tiles causing leaks</li>
                </ul>
              </div>
              <div class="method-card method-card--good">
                <span class="method-card__icon">&#10003;</span>
                <h4 class="method-card__title">Our Spinning Brush System</h4>
                <ul class="method-card__list">
                  <li>Rotating brush head distributes pressure evenly</li>
                  <li>Operated from ground level — no walking on roof</li>
                  <li>Soft bristles clean without stripping mortar</li>
                  <li>Controlled water flow — no water forced under tiles</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li><strong>Free roof survey</strong> — we assess tile type, moss levels, access and any existing damage</li>
              <li><strong>Manual moss removal</strong> — thick growth scraped by hand from the roof surface</li>
              <li><strong>Spinning brush clean</strong> — specialist rotating brush head cleans evenly from ground level or ladder</li>
              <li><strong>Biocide treatment</strong> — anti-growth solution applied to kill remaining spores and prevent regrowth</li>
              <li><strong>Gutter clear</strong> — all debris removed from gutters and downpipes</li>
            </ol>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Protect Your Roof Today</h3>
            <p class="sidebar-card__body">Moss causes cracked tiles and leaks. Our specialist spinning brush system cleans safely from ground level. Get a free, no-obligation quote.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card sidebar-card--trust">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Trusted Local Service</span>
            <div class="sidebar-trust">
              <div class="sidebar-trust__item"><span class="sidebar-trust__value">111</span><span class="sidebar-trust__label">Five-Star Google Reviews</span></div>
              <div class="sidebar-trust__item"><span class="sidebar-trust__value">10</span><span class="sidebar-trust__label">Years Experience</span></div>
              <div class="sidebar-trust__item"><span class="sidebar-trust__value">&#10003;</span><span class="sidebar-trust__label">Fully Insured</span></div>
            </div>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Other Services</span>
            <h3 class="sidebar-card__heading">Explore Our Services</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bath">Driveway Cleaning Bath</a></li>
              <li><a href="/patio-cleaning-bath">Patio Cleaning Bath</a></li>
              <li><a href="/gutter-cleaning-bath">Gutter Cleaning Bath</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning Bath</a></li>
              <li><a href="/driveway-cleaning-bath">Block Paving Cleaning Bath</a></li>
              <li><a href="/bristol/">Jet Washing Bristol</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body="See the results of professional roof cleaning." align="center" />
      <div class="before-after-wrap">
        <img src="/images/before-after/wix-roof.webp" alt="Roof cleaning before and after" class="before-after-composite" />
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      <SectionHeader eyebrow="Our Work" heading="Roof Cleaning Results" body="Real jobs across Bath and Bristol — every photo is our own work." align="center" />
      <div class="gallery-grid">
        <div class="gallery-item gallery-item--wide">
          <img src="/images/before-after/roof-after-2.webp" alt="Clean roof after professional cleaning" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/job-portrait-1.webp" alt="Roof cleaning from ground level" loading="lazy" />
        </div>
        <div class="gallery-item gallery-item--wide">
          <img src="/images/before-after/job-landscape-1.webp" alt="Roof cleaning transformation" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/job-portrait-2.webp" alt="Roof cleaning results" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/driveway-after-1.webp" alt="Driveway after jet washing" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/before-after/job-square-2.webp" alt="Jet washing completed job" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Roof Cleaning FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ── Bath District Links ── */}
  <section class="district-links-section">
    <div class="container">
      <h2 class="district-links__heading">Roof Cleaning Across Bath</h2>
      <p class="district-links__intro">We cover every Bath district. Click your area for a dedicated local page.</p>
      <ul class="district-links__grid">
        <li><a href="/roof-cleaning/oldfield-park-bath">Roof Cleaning Oldfield Park</a></li>
        <li><a href="/roof-cleaning/combe-down-bath">Roof Cleaning Combe Down</a></li>
        <li><a href="/roof-cleaning/bear-flat-bath">Roof Cleaning Bear Flat</a></li>
        <li><a href="/roof-cleaning/newbridge-bath">Roof Cleaning Newbridge</a></li>
        <li><a href="/roof-cleaning/twerton-bath">Roof Cleaning Twerton</a></li>
        <li><a href="/roof-cleaning/weston-bath">Roof Cleaning Weston</a></li>
      </ul>
    </div>
  </section>

  <ImageCTA heading="Protect Your Roof From Moss Damage" body="Our specialist spinning brush system cleans your roof safely from ground level. Get a free, no-obligation quote from Bath's highest-rated jet washing service. 111 five-star reviews. Fully insured." cta={{ label: 'Get a Free Quote', href: '/contact' }} image="/images/before-after/roof-after-2.webp" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
  .service-body__grid { display: grid; grid-template-columns: 7fr 4fr; gap: var(--space-3xl, 5rem); align-items: start; }
  .service-features { margin-top: var(--space-2xl); }
  .service-features__title { font-family: var(--font-display); font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0 0 var(--space-m); }
  .service-features__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-m); }
  .service-features__list li { display: flex; align-items: flex-start; gap: var(--space-s); font-size: 0.95rem; line-height: 1.7; color: var(--concrete); }
  .service-features__list li svg { flex-shrink: 0; margin-top: 0.35em; }
  .service-features__list li strong { color: var(--chalk); }

  /* ── Method comparison ── */
  .method-comparison { margin-top: var(--space-3xl); }
  .method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-l); margin-top: var(--space-l); }
  .method-card { background: #fff3f3; padding: var(--space-xl); border: 1px solid rgba(200, 50, 50, 0.15); }
  .method-card--good { background: #f3f8f3; border-color: rgba(0, 120, 60, 0.15); }
  .method-card__icon { font-size: 1.5rem; display: block; margin-bottom: var(--space-s); }
  .method-card__title { font-family: var(--font-display); font-size: 1.3rem; text-transform: uppercase; color: var(--chalk); margin: 0 0 var(--space-m); }
  .method-card__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .method-card__list li { font-size: 0.9rem; line-height: 1.6; color: var(--concrete); padding-left: 1.2rem; position: relative; }
  .method-card__list li::before { content: '\2022'; position: absolute; left: 0; color: var(--accent); }

  .service-process { margin-top: var(--space-3xl); }
  .process-steps { list-style: none; padding: 0; margin: 0; counter-reset: step; display: flex; flex-direction: column; gap: var(--space-m); }
  .process-steps li { counter-increment: step; display: flex; align-items: flex-start; gap: var(--space-s); font-size: 0.95rem; line-height: 1.7; color: var(--concrete); }
  .process-steps li::before { content: counter(step); font-family: var(--font-display); font-size: 1.8rem; line-height: 1; color: var(--accent); flex-shrink: 0; min-width: 2rem; }
  .process-steps li strong { color: var(--chalk); }
  .service-body__sidebar { display: flex; flex-direction: column; gap: var(--space-xl); position: sticky; top: 6rem; }
  .sidebar-card { background: var(--stone); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-s); }
  .sidebar-card--trust { background: var(--navy); }
  .sidebar-card__heading { font-family: var(--font-display); font-size: clamp(1.1rem, 1.5vw, 1.4rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0; }
  .sidebar-card--trust .sidebar-card__heading { color: #fff; }
  .sidebar-card__body { font-size: 0.92rem; line-height: 1.7; color: var(--concrete); margin: 0; }
  .sidebar-card--trust .sidebar-card__body { color: rgba(255,255,255,0.65); }
  .sidebar-card .btn { margin-top: var(--space-xs); align-self: flex-start; }
  .sidebar-card__phone { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 0.04em; color: var(--accent); text-decoration: none; margin-top: var(--space-xs); }
  .sidebar-card__phone svg { flex-shrink: 0; }
  .sidebar-trust { display: flex; flex-direction: column; gap: var(--space-m); margin-top: var(--space-s); }
  .sidebar-trust__item { display: flex; align-items: center; gap: var(--space-s); }
  .sidebar-trust__value { font-family: var(--font-display); font-size: 2rem; line-height: 1; color: var(--accent); }
  .sidebar-trust__label { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
  .sidebar-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-links a { font-size: 0.9rem; color: var(--concrete); text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 0.3rem; }
  .sidebar-links a::before { content: '\2192'; color: var(--accent); font-size: 0.8rem; }
  .sidebar-links a:hover { color: var(--accent); }
  .before-after-section { padding: var(--section-pad) 0; background: var(--stone); }
  .before-after-wrap { max-width: 900px; margin: 0 auto; }
  .before-after-composite { width: 100%; height: auto; border-radius: 6px; box-shadow: 0 4px 20px rgba(0,0,0,.1); }

  /* ── Gallery ── */
  .gallery-section { padding: var(--section-pad) 0; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }
  .gallery-item {
    overflow: hidden;
    border-radius: 6px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .gallery-item:hover img {
    transform: scale(1.03);
  }
  .gallery-item--wide {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }
  .gallery-item:not(.gallery-item--wide) {
    aspect-ratio: 3/4;
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item--wide { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-item--wide { grid-column: span 1; aspect-ratio: 16/10; }
  }
  .faq-section { padding: var(--section-pad) 0; }
  .faq-list { max-width: 72ch; display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid var(--stone); }
  .faq-item__q { font-family: var(--font-body); font-size: 1rem; font-weight: 500; line-height: 1.5; color: var(--chalk); padding: var(--space-m) 0; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; }
  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q::after { content: '+'; font-family: var(--font-display); font-size: 1.5rem; color: var(--accent); flex-shrink: 0; margin-left: var(--space-s); }
  .faq-item[open] .faq-item__q::after { content: '\2212'; }
  .faq-item__a { font-size: 0.95rem; font-weight: 300; line-height: 1.75; color: var(--concrete); padding: 0 0 var(--space-m); max-width: 60ch; }
  @media (max-width: 768px) { .method-grid { grid-template-columns: 1fr; } }
  @media (max-width: 960px) { .service-body__grid { grid-template-columns: 1fr; gap: var(--space-2xl); } .service-body__sidebar { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-l); } }
  @media (max-width: 640px) { .service-body__sidebar { grid-template-columns: 1fr; } }
</style>