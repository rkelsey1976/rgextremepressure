---
// roof-clean-landing.astro — Ad landing page for roof cleaning
// NO nav, NO footer links — bare minimum, single CTA
import BeforeAfter from '../components/BeforeAfter.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import '../styles/global.css';

const title = 'Roof Cleaning Bath — Free Quote';
const description = 'Soft wash roof cleaning in Bath. Safe moss removal and biocide treatment. 111 five-star reviews. 10 years experience. Fully insured. Call 07474 939 398.';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} | RG Extreme Pressure</title>
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0d1520" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="RG Extreme Pressure" />
  <meta property="og:title" content={`${title} | RG Extreme Pressure`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="en_GB" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght,0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=optional" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght,0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=optional" /></noscript>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Roof Cleaning Bath",
    "description": description,
    "provider": {
      "@type": "LocalBusiness",
      "name": "RG Extreme Pressure",
      "telephone": "+447474939398"
    },
    "areaServed": [{ "@type": "City", "name": "Bath" }, { "@type": "City", "name": "Bristol" }],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "111" }
  })} />
</head>
<body style="background:var(--navy);color:#fff;font-family:var(--font-body);margin:0;overflow-x:hidden;">

  {/* ── Urgent hero ── */}
  <section class="lp-hero">
    <div class="container">
      <div class="lp-hero__badge">111 Five-Star Reviews</div>
      <h1 class="lp-hero__heading">Is Moss Destroying Your Roof?</h1>
      <p class="lp-hero__body">Moss eats into roof tiles, causing cracks, leaks and expensive repairs. Our soft wash system removes it safely — without damaging your roof.</p>
      <div class="lp-hero__ctas">
        <a href="tel:07474939398" class="btn btn--primary lp-cta-phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call 07474 939 398
        </a>
        <a href="/contact" class="btn btn--outline lp-cta-form">Get a Free Quote</a>
      </div>
    </div>
  </section>

  {/* ── Trust strip ── */}
  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
  ]} />

  {/* ── Before / After ── */}
  <section class="lp-section">
    <div class="container">
      <h2 class="lp-section__heading">See the Difference</h2>
      <p class="lp-section__body">Drag the slider to see what soft wash roof cleaning achieves.</p>
      <div class="lp-ba-wrap">
        <BeforeAfter
          beforeSrc="/images/roof-before.webp"
          afterSrc="/images/roof-after.webp"
          beforeAlt="Roof before soft wash cleaning"
          afterAlt="Roof after soft wash cleaning"
          caption="Roof in Bath — moss removed safely with soft wash treatment"
        />
      </div>
    </div>
  </section>

  {/* ── Soft wash explainer ── */}
  <section class="lp-section lp-section--light">
    <div class="container">
      <h2 class="lp-section__heading">Why Soft Wash?</h2>
      <p class="lp-section__body">Pressure washing cracks tiles, strips mortar and voids insurance. Soft washing kills moss at the root and prevents regrowth for up to 5 years.</p>
      <div class="lp-features">
        <div class="lp-feature">
          <span class="lp-feature__icon">&#10003;</span>
          <h3 class="lp-feature__title">Zero Risk of Tile Damage</h3>
          <p class="lp-feature__body">Low-pressure application — no cracked or dislodged tiles</p>
        </div>
        <div class="lp-feature">
          <span class="lp-feature__icon">&#10003;</span>
          <h3 class="lp-feature__title">Kills Moss at the Root</h3>
          <p class="lp-feature__body">Biocide treatment destroys spores, not just surface growth</p>
        </div>
        <div class="lp-feature">
          <span class="lp-feature__icon">&#10003;</span>
          <h3 class="lp-feature__title">3-5 Year Protection</h3>
          <p class="lp-feature__body">Anti-growth treatment prevents rapid regrowth</p>
        </div>
        <div class="lp-feature">
          <span class="lp-feature__icon">&#10003;</span>
          <h3 class="lp-feature__title">Safe for All Roof Types</h3>
          <p class="lp-feature__body">Clay, concrete, slate — soft wash works on every roof</p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Trust signals ── */}
  <section class="lp-section lp-section--dark">
    <div class="container">
      <h2 class="lp-section__heading">Why Choose RG Extreme Pressure?</h2>
      <div class="lp-trust-grid">
        <div class="lp-trust-item">
          <span class="lp-trust-item__value">10</span>
          <span class="lp-trust-item__label">Years Experience</span>
        </div>
        <div class="lp-trust-item">
          <span class="lp-trust-item__value">&#10003;</span>
          <span class="lp-trust-item__label">Fully Insured</span>
        </div>
        <div class="lp-trust-item">
          <span class="lp-trust-item__value">&#10003;</span>
          <span class="lp-trust-item__label">Eco-Friendly Products</span>
        </div>
        <div class="lp-trust-item">
          <span class="lp-trust-item__value">5.0</span>
          <span class="lp-trust-item__label">Google Rating (111 Reviews)</span>
        </div>
      </div>
    </div>
  </section>

  {/* ── Final CTA ── */}
  <section class="lp-final-cta">
    <div class="container">
      <h2 class="lp-final-cta__heading">Get Your Free Roof Cleaning Quote</h2>
      <p class="lp-final-cta__body">Protect your roof from moss damage. Soft wash cleaning is safe, effective and long-lasting. No obligation — just honest advice.</p>
      <div class="lp-hero__ctas">
        <a href="tel:07474939398" class="btn btn--primary lp-cta-phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call 07474 939 398
        </a>
        <a href="/contact" class="btn btn--outline lp-cta-form">Get a Free Quote</a>
      </div>
      <p class="lp-final-cta__note">Also covering Bristol, Keynsham, Bradford on Avon, Corsham and surrounding areas.</p>
    </div>
  </section>

  {/* ── Reveal animation ── */}
  <script>
    const revealEls = document.querySelectorAll('.reveal, .reveal-left, .stagger, .clip-reveal');
    if (revealEls.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      revealEls.forEach(el => observer.observe(el));
    }
  </script>

  {/* ── Before/After init (already auto-inits from component script) ── */}
</body>
</html>

<style>
  /* ── Landing page styles ── */
  .lp-hero {
    padding: clamp(6rem, 14vw, 10rem) 0 clamp(4rem, 8vw, 6rem);
    text-align: center;
    background: var(--navy);
  }

  .lp-hero__badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.35rem 1.2rem;
    margin-bottom: var(--space-l);
  }

  .lp-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 var(--space-m);
    max-width: 14ch;
    margin-inline: auto;
  }

  .lp-hero__body {
    font-size: clamp(1.05rem, 1.4vw, 1.35rem);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.72);
    max-width: 52ch;
    margin: 0 auto var(--space-xl);
  }

  .lp-hero__ctas {
    display: flex;
    gap: var(--space-m);
    justify-content: center;
    flex-wrap: wrap;
  }

  .lp-cta-phone {
    font-size: 0.9rem !important;
  }

  /* ── Sections ── */
  .lp-section {
    padding: var(--section-pad) 0;
    background: var(--navy);
  }

  .lp-section--light {
    background: var(--charcoal);
  }

  .lp-section--dark {
    background: var(--navy);
  }

  .lp-section__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    margin: 0 0 var(--space-m);
  }

  .lp-section__body {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.72);
    text-align: center;
    max-width: 52ch;
    margin: 0 auto var(--space-2xl);
  }

  /* ── Before/After wrap ── */
  .lp-ba-wrap {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Features grid ── */
  .lp-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
  }

  .lp-feature {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: var(--space-l);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .lp-feature__icon {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--accent);
  }

  .lp-feature__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.5vw, 1.4rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .lp-feature__body {
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  /* ── Trust grid ── */
  .lp-trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .lp-trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lp-trust-item__value {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 1;
    color: var(--accent);
  }

  .lp-trust-item__label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ── Final CTA ── */
  .lp-final-cta {
    padding: var(--section-pad) 0;
    text-align: center;
    background: var(--charcoal);
  }

  .lp-final-cta__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 var(--space-m);
    max-width: 14ch;
    margin-inline: auto;
  }

  .lp-final-cta__body {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.72);
    max-width: 52ch;
    margin: 0 auto var(--space-xl);
  }

  .lp-final-cta__note {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    margin-top: var(--space-xl);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .lp-features {
      grid-template-columns: 1fr;
    }

    .lp-trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lp-hero__ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>