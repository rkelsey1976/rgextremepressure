---
// style-guide.astro — Live design system reference for Aspect Builds
// Showcases every token, typography scale, colour, spacing unit, and component pattern
// used across the site. This page is dev-only; exclude from sitemap/nav.
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SplitFeature from '../components/SplitFeature.astro';
import CardGrid from '../components/CardGrid.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import CTABanner from '../components/CTABanner.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import ProjectGallery from '../components/ProjectGallery.astro';
---

<!-- Block indexing -->
<meta name="robots" content="noindex, nofollow">
<Base title="Style Guide">

  <div class="sg-page">
    <!-- ═══════════ HEADER ═══════════ -->
    <header class="sg-header">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">Internal Reference</span>
        <h1 class="sg-title">Aspect Builds<br>Design System</h1>
        <p class="t-body-lg">Every token, type scale, colour, spacing unit, and component pattern — in one place.</p>
      </div>
    </header>

    <!-- ═══════════ 01 — COLOUR PALETTE ═══════════ -->
    <section class="sg-section">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">01</span>
        <h2 class="t-heading sg-section__heading">Colour Palette</h2>

        <div class="sg-swatch-grid">
          <!-- Core darks -->
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#0d1520"></div>
            <p class="sg-swatch__name">Navy</p>
            <p class="sg-swatch__hex">#0d1520 — <code>--navy</code></p>
            <p class="sg-swatch__note">Hero bg, footer, TrustMetrics</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#2f3538"></div>
            <p class="sg-swatch__name">Charcoal</p>
            <p class="sg-swatch__hex">#2f3538 — <code>--charcoal</code></p>
            <p class="sg-swatch__note">Dark sections, split feature, CTA banner</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#1A2332"></div>
            <p class="sg-swatch__name">Chalk</p>
            <p class="sg-swatch__hex">#1A2332 — <code>--chalk</code></p>
            <p class="sg-swatch__note">Primary text, nav bg (scrolled)</p>
          </div>

          <!-- Mid tones -->
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#546178"></div>
            <p class="sg-swatch__name">Concrete</p>
            <p class="sg-swatch__hex">#546178 — <code>--concrete</code></p>
            <p class="sg-swatch__note">Secondary/body text, subdued labels</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#636E7E"></div>
            <p class="sg-swatch__name">Steel</p>
            <p class="sg-swatch__hex">#636E7E — <code>--steel</code></p>
            <p class="sg-swatch__note">Tertiary text, dividers</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#E8EBF0"></div>
            <p class="sg-swatch__name">Stone</p>
            <p class="sg-swatch__hex">#E8EBF0 — <code>--stone</code></p>
            <p class="sg-swatch__note">Light section background</p>
          </div>

          <!-- Accent -->
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#AE8455"></div>
            <p class="sg-swatch__name">Gold Accent</p>
            <p class="sg-swatch__hex">#AE8455 — <code>--accent</code></p>
            <p class="sg-swatch__note">CTAs, eyebrows, hover states, icons</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#8A6840"></div>
            <p class="sg-swatch__name">Gold Dim</p>
            <p class="sg-swatch__hex">#8A6840 — <code>--accent-dim</code></p>
            <p class="sg-swatch__note">Hover state for accents</p>
          </div>
          <div class="sg-swatch">
            <div class="sg-swatch__chip" style="background:#FFFFFF; border:1px solid var(--stone)"></div>
            <p class="sg-swatch__name">White</p>
            <p class="sg-swatch__hex">#FFFFFF — <code>--white</code></p>
            <p class="sg-swatch__note">Page background, hero text</p>
          </div>
        </div>

        <!-- Overlay swatches -->
        <h3 class="t-label sg-sublabel">Overlay Gradients (hero component)</h3>
        <div class="sg-swatch-grid sg-swatch-grid--sm">
          <div class="sg-swatch">
            <div class="sg-swatch__chip sg-swatch__chip--tall" style="background:linear-gradient(to right, rgba(0,0,0,.92) 0%, rgba(0,0,0,.88) 40%, rgba(0,0,0,.45) 100%)"></div>
            <p class="sg-swatch__name">left vignette (desktop default)</p>
            <p class="sg-swatch__note">Deep L-to-R shadow — all pages</p>
          </div>
          <div>
            <div class="sg-swatch__chip sg-swatch__chip--tall" style="background:linear-gradient(to bottom, rgba(0,0,0,.95) 0%, rgba(0,0,0,.75) 50%, rgba(0,0,0,.3) 100%)"></div>
            <p class="sg-swatch__name">top-down (mobile)</p>
            <p class="sg-swatch__note">Dark at nav, fading toward bottom</p>
          </div>
        </div>

        <!-- Semantic opacity tokens -->
        <h3 class="t-label sg-sublabel">Semantic Opacity Tokens</h3>
        <div class="sg-opacity-grid">
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.72)"></span> white/72 — hero body text</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.65)"></span> white/65 — nav links over hero</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.55)"></span> white/55 — breadcrumbs, dimmer text</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.50)"></span> white/50 — labels, meta keys</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.40)"></span> white/40 — tag borders, outline buttons</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(26,35,50,.12)"></span> chalk/12 — section dividers</div>
          <div class="sg-opacity-item"><span class="sg-opacity-dot" style="background:rgba(255,255,255,.08)"></span> white/08 — footer dividers</div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 02 — TYPOGRAPHY ═══════════ -->
    <section class="sg-section sg-section--stone">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">02</span>
        <h2 class="t-heading sg-section__heading">Typography</h2>

        <div class="sg-type-grid">
          <!-- Display -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Display</span>
              <code>.t-display</code>
              <p>Bebas Neue · clamp(4.5rem, 12vw, 14rem) · lh .92 · trackedtight · uppercase</p>
            </div>
            <div class="sg-type-sample t-display">Aspect Builds</div>
          </div>

          <!-- Display SM -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Display SM</span>
              <code>.t-display-sm</code>
              <p>Bebas Neue · clamp(3rem, 6vw, 7rem) · lh .94 · uppercase</p>
            </div>
            <div class="sg-type-sample t-display-sm">Bath</div>
          </div>

          <!-- Hero Headline (component-scoped) -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Hero Headline</span>
              <code>.hero__headline</code>
              <p>Bebas Neue · clamp(3.5rem, 8vw, 8rem) · lh .94 · uppercase · white</p>
            </div>
            <div class="sg-type-sample sg-type-sample--dark">
              <span class="hero__headline">Built for Bath.</span>
            </div>
          </div>

          <!-- Heading -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Heading</span>
              <code>.t-heading</code>
              <p>Bebas Neue · clamp(2rem, 3.5vw, 4rem) · lh 1 · uppercase</p>
            </div>
            <div class="sg-type-sample t-heading">Our Services</div>
          </div>

          <!-- Label -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Label / Eyebrow</span>
              <code>.t-label</code>
              <p>DM Sans · .7rem · weight 500 (semibold) · tracked .22em · uppercase · concrete</p>
            </div>
            <div class="sg-type-sample t-label">The Aspect Standard</div>
          </div>

          <!-- Body Large -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Body Large</span>
              <code>.t-body-lg</code>
              <p>DM Sans · clamp(1.1rem, 1.4vw, 1.35rem) · weight 300 · lh 1.75 · concrete</p>
            </div>
            <div class="sg-type-sample t-body-lg">Premium construction across Bath & BANES. Extensions, loft conversions, Georgian renovation and new build — delivered with precision, without surprises.</div>
          </div>

          <!-- Body (default) -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Body (default)</span>
              <code>body</code>
              <p>DM Sans · clamp(1rem, 1.1vw, 1.125rem) · weight 300 · lh 1.7 · chalk</p>
            </div>
            <div class="sg-type-sample">The price we quote is the price you pay — and the work we leave behind is something we put our name on permanently.</div>
          </div>

          <!-- Footer Heading -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Footer Heading</span>
              <code>.footer-heading</code>
              <p>Bebas Neue · 1.1rem · tracked .08em · uppercase · white</p>
            </div>
            <div class="sg-type-sample sg-type-sample--dark">
              <span class="footer-heading">Services</span>
            </div>
          </div>

          <!-- Nav link -->
          <div class="sg-type-row">
            <div class="sg-type-meta">
              <span class="t-label">Nav Link</span>
              <code>.nav-link</code>
              <p>DM Sans · .8rem · weight 500 (semibold) · tracked .1em · uppercase · concrete</p>
            </div>
            <div class="sg-type-sample"><a href="#" class="nav-link">About</a></div>
          </div>
        </div>

        <!-- Font pairing reference -->
        <div class="sg-font-pair">
          <h3 class="t-label sg-sublabel">Font Pairing</h3>
          <div class="sg-pair-grid">
            <div class="sg-pair-card">
              <p class="sg-pair-card__role">Display / Headlines</p>
              <p class="sg-pair-card__name">Bebas Neue</p>
              <p class="sg-pair-card__meta">Condensed sans · Caps only · <code>--font-display</code></p>
              <p class="sg-pair-card__sample" style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;line-height:.95">ABCDEFGHIJKLMNOPQRSTUVWXYZ 0123456789</p>
            </div>
            <div class="sg-pair-card">
              <p class="sg-pair-card__role">Body / UI</p>
              <p class="sg-pair-card__name">DM Sans</p>
              <p class="sg-pair-card__meta">Wght 300/400/500 · <code>--font-body</code></p>
              <p class="sg-pair-card__sample" style="font-family:'DM Sans',sans-serif;font-size:1.125rem;font-weight:300;line-height:1.7">ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789</p>
              <p class="sg-pair-card__sample" style="font-family:'DM Sans',sans-serif;font-size:1.125rem;font-weight:500;line-height:1.7">SemiBold 500 — labels, nav, buttons</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 03 — SPACING ═══════════ -->
    <section class="sg-section">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">03</span>
        <h2 class="t-heading sg-section__heading">Spacing Scale</h2>

        <div class="sg-space-list">
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-3xs) * 10)"></div>
            <code>--space-3xs</code>
            <span>.25rem (4px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-2xs) * 10)"></div>
            <code>--space-2xs</code>
            <span>.5rem (8px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-xs) * 10)"></div>
            <code>--space-xs</code>
            <span>.75rem (12px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-s) * 10)"></div>
            <code>--space-s</code>
            <span>1rem (16px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-m) * 10)"></div>
            <code>--space-m</code>
            <span>1.5rem (24px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-l) * 10)"></div>
            <code>--space-l</code>
            <span>2rem (32px) — nav gap, hero content gap</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar" style="width:calc(var(--space-xl) * 10)"></div>
            <code>--space-xl</code>
            <span>3rem (48px) — footer grid gap</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar sg-space-bar--accent" style="width:calc(var(--space-2xl) * 10)"></div>
            <code>--space-2xl</code>
            <span>5rem (80px)</span>
          </div>
          <div class="sg-space-item">
            <div class="sg-space-bar sg-space-bar--accent" style="width:min(calc(var(--space-3xl) * 5), 200px)"></div>
            <code>--space-3xl</code>
            <span>8rem (128px)</span>
          </div>
        </div>

        <h3 class="t-label sg-sublabel">Structural Tokens</h3>
        <div class="sg-token-table">
          <div class="sg-token-row"><code>--section-pad</code><span>clamp(6rem, 14vw, 16rem)</span><span>Vertical section padding</span></div>
          <div class="sg-token-row"><code>--gutter</code><span>clamp(1.5rem, 5vw, 5rem)</span><span>Horizontal page gutter</span></div>
          <div class="sg-token-row"><code>--max-w</code><span>1440px</span><span>Container max-width</span></div>
          <div class="sg-token-row"><code>--text-max</code><span>72ch</span><span>Max line-length for body text</span></div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 04 — BUTTONS & CTAs ═══════════ -->
    <section class="sg-section sg-section--stone">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">04</span>
        <h2 class="t-heading sg-section__heading">Buttons & CTAs</h2>

        <div class="sg-component-group">
          <div class="sg-component">
            <span class="t-label">Primary Button</span>
            <div class="sg-component__preview">
              <a href="#" class="btn btn--primary">Start a Project <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            </div>
            <code>.btn .btn--primary</code>
          </div>

          <div class="sg-component">
            <span class="t-label">Outline Button (dark hero context)</span>
            <div class="sg-component__preview sg-component__preview--dark">
              <a href="#" class="btn btn--outline">View Projects</a>
            </div>
            <code>.btn .btn--outline</code>
          </div>

          <div class="sg-component">
            <span class="t-label">Nav CTA Button</span>
            <div class="sg-component__preview">
              <a href="#" class="nav-link nav-cta">Get a Quote</a>
            </div>
            <code>.nav-link .nav-cta</code>
          </div>
        </div>

        <div class="sg-spec-grid">
          <div class="sg-spec-item"><span class="sg-spec-label">Font</span> DM Sans · .85rem · weight 500 · tracked .15em · uppercase</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Padding</span> .9rem 2rem</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Border</span> 1px solid · radius 0 (sharp)</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Transition</span> all .3s ease-out-expo</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Primary BG</span> --accent (#AE8455) · hover: --accent-dim (#8A6840)</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Outline border</span> white/40 · hover: --accent border + black/50 bg</div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 05 — LOGO & NAV ═══════════ -->
    <section class="sg-section">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">05</span>
        <h2 class="t-heading sg-section__heading">Logo & Navigation</h2>

        <div class="sg-component-group">
          <!-- Logo on white -->
          <div class="sg-component">
            <span class="t-label">Logo — light background</span>
            <div class="sg-component__preview" style="padding:2rem">
              <a href="/" class="ab-logo nav-logo nav-logo--lg" style="text-decoration:none">
                <svg class="ab-logo__mark" width="28" height="18" viewBox="-2 -2 26 18" fill="none" aria-hidden="true"><polyline points="0,14 11,0 22,14" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round"></polyline></svg>
                <span class="ab-logo__text">
                  <span class="ab-logo__name">Aspect</span>
                  <span class="ab-logo__sub">Builds &amp; Maintenance LTD</span>
                </span>
              </a>
            </div>
          </div>

          <!-- Logo on dark -->
          <div class="sg-component">
            <span class="t-label">Logo — dark background (hero)</span>
            <div class="sg-component__preview sg-component__preview--dark" style="padding:2rem">
              <a href="/" class="ab-logo nav-logo nav-logo--lg" style="text-decoration:none">
                <svg class="ab-logo__mark" width="28" height="18" viewBox="-2 -2 26 18" fill="none" aria-hidden="true"><polyline points="0,14 11,0 22,14" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round"></polyline></svg>
                <span class="ab-logo__text">
                  <span class="ab-logo__name" style="color:#fff">Aspect</span>
                  <span class="ab-logo__sub" style="color:rgba(255,255,255,.5)">Builds &amp; Maintenance LTD</span>
                </span>
              </a>
            </div>
          </div>
        </div>

        <div class="sg-spec-grid">
          <div class="sg-spec-item"><span class="sg-spec-label">Mark</span> SVG polyline chevron · 28×18 · stroke 3.5</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Name</span> Bebas Neue · 1.7rem · tracked .04em · chalk (#1A2332)</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Subtitle</span> DM Sans · .55rem · weight 500 · tracked .22em · uppercase · concrete</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Mark colour</span> --accent (gold) · name colour: chalk (light) / white (dark hero)</div>
          <div class="sg-spec-item"><span class="sg-spec-label">Gap</span> .65rem between mark and text, 2px between name rows</div>
        </div>

        <!-- Nav full -->
        <h3 class="t-label sg-sublabel">Full Navigation Bar</h3>
        <div class="sg-component">
          <div class="sg-component__preview sg-component__preview--dark" style="padding:1rem 2rem">
            <div style="display:flex;align-items:center;justify-content:space-between;max-width:1440px;margin:0 auto">
              <a href="/" class="ab-logo nav-logo nav-logo--lg" style="text-decoration:none">
                <svg class="ab-logo__mark" width="28" height="18" viewBox="-2 -2 26 18" fill="none" aria-hidden="true"><polyline points="0,14 11,0 22,14" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round"></polyline></svg>
                <span class="ab-logo__text">
                  <span class="ab-logo__name" style="color:#fff">Aspect</span>
                  <span class="ab-logo__sub" style="color:rgba(255,255,255,.5)">Builds &amp; Maintenance LTD</span>
                </span>
              </a>
              <div class="nav-links">
                <a href="#" class="nav-link" style="color:rgba(255,255,255,.65)">About</a>
                <a href="#" class="nav-link" style="color:rgba(255,255,255,.65)">Services</a>
                <a href="#" class="nav-link" style="color:rgba(255,255,255,.65)">Projects</a>
                <a href="#" class="nav-link" style="color:rgba(255,255,255,.65)">Locations</a>
                <a href="#" class="nav-link nav-cta">Get a Quote</a>
              </div>
            </div>
          </div>
        </div>

        <h3 class="t-label sg-sublabel">Nav scroll state (scrolled = solid bg)</h3>
        <div class="sg-component">
          <div class="sg-component__preview" style="padding:1rem 2rem;background:rgba(26,35,50,.97);backdrop-filter:blur(8px)">
            <div style="display:flex;align-items:center;justify-content:space-between;max-width:1440px;margin:0 auto">
              <a href="/" class="ab-logo nav-logo nav-logo--lg" style="text-decoration:none">
                <svg class="ab-logo__mark" width="28" height="18" viewBox="-2 -2 26 18" fill="none" aria-hidden="true"><polyline points="0,14 11,0 22,14" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round" stroke-linecap="round"></polyline></svg>
                <span class="ab-logo__text">
                  <span class="ab-logo__name">Aspect</span>
                  <span class="ab-logo__sub">Builds &amp; Maintenance LTD</span>
                </span>
              </a>
              <div class="nav-links">
                <a href="#" class="nav-link">About</a>
                <a href="#" class="nav-link">Services</a>
                <a href="#" class="nav-link">Projects</a>
                <a href="#" class="nav-link">Locations</a>
                <a href="#" class="nav-link nav-cta">Get a Quote</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 06 — SECTION PATTERNS ═══════════ -->
    <section class="sg-section sg-section--stone">
      <div class="container">
        <span class="t-label" style="color:var(--accent)">06</span>
        <h2 class="t-heading sg-section__heading">Section Patterns</h2>

        <div class="sg-component-group">
          <div class="sg-component">
            <span class="t-label">Light Section</span>
            <div class="sg-component__preview sg-component__preview--stone" style="padding:var(--space-xl) var(--gutter)">
              <p>Background: <code>--stone</code> (#E8EBF0) · Text: <code>--chalk</code> (#1A2332)</p>
