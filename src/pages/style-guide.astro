<style>
  /* ═══════════════════════════════════════════
     Style Guide Page — isolated, no global bleed
     ═══════════════════════════════════════════ */

  .sg-page {
    padding-top: 100px; /* clear fixed nav */
  }

  /* Header */
  .sg-header {
    padding-block: var(--space-3xl);
    border-bottom: var(--border);
  }
  .sg-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: .94;
    text-transform: uppercase;
    color: var(--chalk);
    margin: var(--space-s) 0;
  }

  /* Sections */
  .sg-section {
    padding-block: var(--section-pad);
  }
  .sg-section--stone {
    background: var(--stone);
  }
  .sg-section__heading {
    margin-bottom: var(--space-xl);
  }
  .sg-sublabel {
    display: block;
    margin: var(--space-xl) 0 var(--space-m);
    padding-top: var(--space-m);
    border-top: var(--border);
  }

  /* Swatch grid */
  .sg-swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-m);
  }
  .sg-swatch-grid--sm {
    grid-template-columns: repeat(3, 1fr);
  }
  .sg-swatch {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .sg-swatch__chip {
    height: 80px;
    border-radius: 2px;
  }
  .sg-swatch__chip--tall {
    height: 120px;
  }
  .sg-swatch__name {
    font-weight: 600;
    font-size: .85rem;
    color: var(--chalk);
  }
  .sg-swatch__hex {
    font-size: .78rem;
    color: var(--concrete);
  }
  .sg-swatch__note {
    font-size: .72rem;
    color: var(--steel);
  }

  /* Opacity tokens */
  .sg-opacity-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-s);
    margin-top: var(--space-s);
  }
  .sg-opacity-item {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    font-size: .85rem;
    color: var(--concrete);
  }
  .sg-opacity-dot {
    width: 28px;
    height: 28px;
    border-radius: 2px;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,.1);
  }

  /* Typography grid */
  .sg-type-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .sg-type-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-l);
    align-items: baseline;
    padding-bottom: var(--space-l);
    border-bottom: var(--border);
  }
  .sg-type-meta {
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }
  .sg-type-meta code {
    font-size: .78rem;
    color: var(--accent);
  }
  .sg-type-meta p {
    font-size: .8rem;
    color: var(--steel);
    line-height: 1.5;
  }
  .sg-type-sample {
    color: var(--chalk);
  }
  .sg-type-sample--dark {
    background: var(--navy);
    padding: var(--space-m);
    border-radius: 2px;
  }

  /* Font pairing cards */
  .sg-pair-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
    margin-top: var(--space-s);
  }
  .sg-pair-card {
    padding: var(--space-l);
    background: #fff;
    border: var(--border);
  }
  .sg-pair-card__role {
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .5rem;
  }
  .sg-pair-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--chalk);
  }
  .sg-pair-card__meta {
    font-size: .8rem;
    color: var(--steel);
    margin-bottom: var(--space-m);
  }
  .sg-pair-card__sample {
    color: var(--chalk);
    opacity: .9;
  }

  /* Spacing bars */
  .sg-space-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }
  .sg-space-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: var(--space-s);
    align-items: center;
    font-size: .85rem;
    color: var(--concrete);
  }
  .sg-space-bar {
    height: 12px;
    background: var(--stone);
    border-radius: 1px;
  }
  .sg-space-bar--accent {
    background: var(--accent);
    opacity: .5;
  }

  /* Token table */
  .sg-token-table {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    margin-top: var(--space-s);
  }
  .sg-token-row {
    display: grid;
    grid-template-columns: 200px 1fr 1fr;
    gap: var(--space-s);
    font-size: .85rem;
    padding: .5rem 0;
    border-bottom: 1px solid var(--stone);
  }
  .sg-token-row code {
    color: var(--accent);
  }

  /* Component group */
  .sg-component-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    margin-bottom: var(--space-xl);
  }
  .sg-component {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .sg-component code {
    font-size: .78rem;
    color: var(--accent);
  }
  .sg-component__preview {
    padding: var(--space-l);
    border: var(--border);
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }
  .sg-component__preview--dark {
    background: var(--navy);
    border-color: rgba(255,255,255,.1);
  }
  .sg-component__preview--stone {
    background: var(--stone);
  }

  /* Spec grid */
  .sg-spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-s);
  }
  .sg-spec-item {
    font-size: .85rem;
    color: var(--concrete);
    line-height: 1.6;
  }
  .sg-spec-label {
    font-weight: 600;
    color: var(--chalk);
    margin-right: .5rem;
  }

  /* Reveal demo */
  .sg-reveal-demo {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    margin: var(--space-m) 0;
  }
  .sg-reveal-item {
    padding: var(--space-m);
    background: var(--stone);
    font-size: .85rem;
    color: var(--chalk);
  }

  /* Variable reference */
  .sg-var-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-l);
  }
  .sg-var-group {
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }
  .sg-var-row {
    font-size: .82rem;
    color: var(--concrete);
  }
  .sg-var-row code {
    color: var(--accent);
    margin-right: .5rem;
  }

  .sg-note {
    font-size: .85rem;
    color: var(--concrete);
    margin: var(--space-s) 0;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .sg-type-row {
      grid-template-columns: 1fr;
    }
    .sg-swatch-grid--sm {
      grid-template-columns: 1fr;
    }
    .sg-space-item {
      grid-template-columns: 1fr;
    }
    .sg-token-row {
      grid-template-columns: 1fr;
    }
    .sg-pair-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

