---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import BeforeAfter from '../components/BeforeAfter.astro';

const title = 'Driveway Cleaning Bristol';
const description = 'Professional driveway cleaning across Bristol (BS1–BS16). Block paving, tarmac and concrete jet washed, re-sanded and sealed. 111 five-star reviews. Call 07474 939 398.';

const faqs = [
  {
    q: 'Do you cover all Bristol postcodes?',
    a: 'Yes. We cover all Bristol postcodes from BS1 to BS16, including Clifton, Redland, Bishopston, Henleaze, Kingswood, Fishponds, Brislington, Bedminster, Southville, Knowle and surrounding areas. If you are unsure whether we cover your location, just call and we will confirm.'
  },
  {
    q: 'How much does driveway cleaning cost in Bristol?',
    a: 'Driveway cleaning typically starts from around £3 per square metre depending on surface type, condition and access. We provide free on-site quotes with no obligation — call 07474 939 398 or use our contact form.'
  },
  {
    q: 'Will pressure washing damage my block paving?',
    a: 'No. We adjust pressure and lance angle to suit each surface. Block paving is cleaned at a medium pressure that lifts dirt and moss without dislodging or etching the blocks. We always re-sand joints afterwards to stabilise the surface.'
  },
  {
    q: 'How long does driveway cleaning take?',
    a: 'A standard double driveway (approx 30m²) takes 2–4 hours. Larger driveways or heavily soiled surfaces may take a full day. We will advise on timing during your free quote.'
  },
  {
    q: 'Do you offer driveway sealing after cleaning in Bristol?',
    a: 'Yes. We offer acrylic and polyurethane sealant applications for block paving across Bristol. Sealing protects against oil stains, weed growth and colour fading — extending the life of your driveway significantly.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Driveway Cleaning Bristol",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": { "@type": "City", "name": "Bristol" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" }
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[{ name: 'Services', item: 'https://rgextremepressure.co.uk/services' }, { name: 'Driveway Cleaning Bristol', item: 'https://rgextremepressure.co.uk/driveway-cleaning-bristol' }]}>
  <Hero
    image="/images/before-after/drive-after.jpg"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Bristol', href: '/bristol' }, { label: 'Driveway Cleaning' }]}
    eyebrow="Professional Driveway Cleaning Bristol"
    heading="Driveway Cleaning Bristol"
    body="Restore your Bristol driveway to look brand new. Professional jet washing removes years of dirt, oil stains, tyre marks and weed growth from block paving, tarmac, concrete and resin. 111 five-star reviews. Free quotes."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
  minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="Driveway Cleaning Across Bristol"
            heading="Professional Driveway Jet Washing in Bristol"
            body="Bristol's wet climate means driveways grow algae and moss faster than almost anywhere else. Add vehicle traffic, oil drips and leaf mould and even a well-laid block paving driveway can look years older than it is. Our professional jet washing strips it all back and restores the original surface."
          />

          <div class="service-features">
            <h3 class="service-features__title">What Our Bristol Driveway Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Block Paving Deep Clean</strong>
                  <p class="feature-card__body">High-pressure flat surface cleaner removes ingrained dirt, algae and moss from the surface and between joints.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Oil Stain & Tyre Mark Removal</strong>
                  <p class="feature-card__body">Specialist degreaser pre-treatment applied before washing to lift stubborn automotive stains.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Kiln-Dried Sand Re-Jointing</strong>
                  <p class="feature-card__body">Fresh jointing sand brushed into block paving joints after cleaning — stabilises and inhibits weed regrowth.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Tarmac & Concrete Wash</strong>
                  <p class="feature-card__body">Pressure adjusted to suit the surface type — removes growth without etching or surface damage.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Resin Drive Gentle Clean</strong>
                  <p class="feature-card__body">Low-pressure soft wash for resin-bound surfaces — removes algae and discolouration without damage.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Sealant Application</strong>
                  <p class="feature-card__body">Optional protective seal guards against future staining, weed growth and colour fading.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to book? Free quotes across all Bristol postcodes.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Equipment" heading="Why We Use a Flat Surface Cleaner" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">Standard Pressure Wand</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Leaves visible stripes and streaks across the surface
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Uneven cleaning — concentrated jet misses between passes
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Operator-dependent — results vary with speed and angle
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    High splash — overspray onto cars, walls and planting
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Flat Surface Cleaner</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Two or three nozzles on a spinning bar inside a circular housing — uniform coverage every pass
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    No stripes or streaks — the enclosed head distributes pressure evenly across the surface
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Enclosed housing contains splash — protects your car, walls and borders
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Covers large areas quickly and consistently — the professional standard
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  A consistently clean finish — no stripes, no missed patches, no mess on your property
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Site Visit</h4>
                  <p class="process-step__body">We assess surface type, condition and any problem areas — and confirm a fixed price before starting.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Pre-Treatment</h4>
                  <p class="process-step__body">Oil stains and stubborn marks treated with specialist degreaser and left to dwell.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Flat Surface Clean</h4>
                  <p class="process-step__body">Professional flat surface cleaner delivers even, stripe-free pressure washing across the full driveway.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Re-Sanding</h4>
                  <p class="process-step__body">Kiln-dried jointing sand brushed into block paving joints to stabilise and prevent weed regrowth.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Final Inspection</h4>
                  <p class="process-step__body">We walk the job with you before leaving to make sure you are completely happy with the result.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Bristol driveway going green? We can usually quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="areas-covered">
            <SectionHeader eyebrow="Bristol Coverage" heading="Bristol Areas We Serve" />
            <p class="areas-text">Clifton, Redland, Cotham, Montpelier, Bishopston, Westbury Park, Henleaze, Stoke Bishop, Fishponds, Stapleton, Downend, Emersons Green, Kingswood, Hanham, Brislington, Totterdown, Knowle, Bedminster, Southville, Ashton, Sea Mills, Shirehampton, Portishead and all surrounding Bristol postcodes (BS1–BS16).</p>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Ready to Transform Your Driveway?</h3>
            <p class="sidebar-card__body">Call us or request a free, no-obligation quote. We cover all Bristol postcodes and surrounding areas.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Bristol Services</span>
            <h3 class="sidebar-card__heading">Also in Bristol</h3>
            <ul class="sidebar-links">
              <li><a href="/patio-cleaning-bristol">Patio Cleaning Bristol</a></li>
              <li><a href="/gutter-cleaning-bristol">Gutter Cleaning Bristol</a></li>
              <li><a href="/roof-cleaning-bristol">Roof Cleaning Bristol</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning</a></li>
              <li><a href="/bristol/">All Bristol Services</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>


  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body="See the difference professional driveway cleaning can achieve." align="center" />
      <div class="before-after-wrap">
        <BeforeAfter
          beforeSrc="/images/before-after/drive-before.jpg"
          afterSrc="/images/before-after/drive-after.jpg"
          beforeAlt="Block paving driveway before cleaning — heavy algae, moss and staining"
          afterAlt="Block paving driveway after jet washing — clean stone surface fully restored"
          caption="Block paving driveway — years of algae and staining removed in one visit"
        />
      </div>
      <div class="photo-library" style="margin-top:var(--space-xl)">
        <div class="photo-library__header">
          <p class="photo-library__sub">More photos from recent Bristol driveway jobs</p>
          <span class="photo-library__count">6 photos</span>
        </div>
        <div class="photo-library__grid">
          <a href="/images/before-after/drive1.jpeg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: driveway before cleaning">
            <img src="/images/before-after/drive1.jpeg" alt="Block paving driveway before jet washing — Bristol" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/drive2.jpeg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: driveway after cleaning">
            <img src="/images/before-after/drive2.jpeg" alt="Block paving driveway after jet washing — Bristol" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-block-paving-1.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: block paving clean">
            <img src="/images/before-after/job-block-paving-1.webp" alt="Block paving driveway cleaned in Bristol" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-block-paving-2.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: block paving detail">
            <img src="/images/before-after/job-block-paving-2.webp" alt="Block paving detail — clean joints after re-sanding" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/drive3.jpeg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: driveway cleaned Bristol">
            <img src="/images/before-after/drive3.jpeg" alt="Block paving driveway professionally cleaned in Bristol" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/driveway-before-after-2.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: driveway split result">
            <img src="/images/before-after/driveway-before-after-2.webp" alt="Driveway split image showing dramatic cleaning result" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Driveway Cleaning Bristol FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
