---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';

const title = 'Conservatory Cleaning Bath';
const description = 'Professional conservatory cleaning in Bath. Roof, frame and glass cleaned safely using specialist soft wash. Green algae and black streaks removed. Call 07474 939 398 for a free quote.';

const faqs = [
  {
    q: 'Is it safe to jet wash a conservatory roof?',
    a: 'Direct high-pressure jet washing on polycarbonate or glass conservatory panels is not recommended — it risks cracking panels, forcing water into seals and damaging flashings. We use a soft wash technique with specialist detergents and a low-pressure rinse, which is far safer and more effective for conservatory roofs.'
  },
  {
    q: 'What is causing the green patches on my conservatory roof?',
    a: 'Green patches are algae colonies that take hold in shaded, damp areas — typically north-facing conservatories or those under overhanging trees. Algae degrades polycarbonate over time and reduces light transmission. Our biocide treatment kills the algae at the root and slows regrowth.'
  },
  {
    q: 'Can you clean both the inside and outside of conservatory glass?',
    a: 'We specialise in external cleaning. Internal glass cleaning can be arranged by separate agreement — let us know when you book and we will advise on what is possible.'
  },
  {
    q: 'Will cleaning improve the light inside my conservatory?',
    a: 'Yes, noticeably. Heavy algae and dirt coverage on polycarbonate roofing can reduce light transmission by 30–50%. After cleaning, most customers immediately notice how much brighter the space is.'
  },
  {
    q: 'How long will the clean last?',
    a: 'With our biocide anti-algae treatment, most conservatory roofs stay clean for 2–3 years. North-facing roofs or those under trees will see regrowth faster. We recommend an annual check and retreatment every 2–3 years.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Conservatory Cleaning Bath",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": [{ "@type": "City", "name": "Bath" }, { "@type": "City", "name": "Bristol" }],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" }
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[
  { name: 'Services', item: 'https://rgextremepressure.co.uk/services' },
  { name: 'Conservatory Cleaning Bath', item: 'https://rgextremepressure.co.uk/conservatory-cleaning-bath' }
]}>
  <Hero
    image="/images/before-after/conservatory-action-1.jpg"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Conservatory Cleaning' }]}
    eyebrow="Professional Conservatory Cleaning"
    heading="Conservatory Cleaning Bath"
    body="A green, dirty conservatory roof blocks light and looks neglected. Our specialist soft wash cleans polycarbonate and glass panels, uPVC frames and gutters safely — no high pressure that could crack panels or damage seals."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="What We Do"
            heading="Safe Conservatory Roof & Frame Cleaning"
            body="Conservatory cleaning requires a different approach to general jet washing. Polycarbonate panels, sealed glass units and uPVC frames need low-pressure, detergent-led cleaning that removes algae and grime without risking structural damage. We have the right equipment and the right chemicals for the job."
          />

          <div class="service-intro-image">
            <img src="/images/before-after/conservatory-midclean-1.jpg" alt="Conservatory roof mid-clean — left side green with algae, right side restored to clear panels" loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">What Our Conservatory Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Polycarbonate Roof Soft Wash</strong>
                  <p class="feature-card__body">Biodegradable detergent applied and rinsed at safe low pressure — removes algae and discolouration without cracking panels.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Glass Roof Cleaning</strong>
                  <p class="feature-card__body">Spot-free rinse system for sealed glass conservatory and lantern roof panels — streak-free finish.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">uPVC Frame Cleaning</strong>
                  <p class="feature-card__body">Soft wash removes green streaks, mould and grime from all frame sections — restored to original white.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Algae & Biocide Treatment</strong>
                  <p class="feature-card__body">Kills spores at the source and slows algae regrowth significantly — clean for 2–3 years.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Conservatory Gutter Clear</strong>
                  <p class="feature-card__body">Downpipe flush and gutter clear included — prevents overflow staining and water pooling on the roof.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Ridge & Hip Detail Clean</strong>
                  <p class="feature-card__body">Attention to areas where algae accumulates around fixings, trims and roof-to-wall junctions.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to let the light back in? Get a free quote today.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Method" heading="Why We Don't Jet Wash Conservatory Roofs" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">High-Pressure Jet Wash</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Can crack and shatter polycarbonate panels
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Forces water into seals causing leaks inside
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Damages flashings and trims around the roof
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Algae regrows fast — no biocide treatment
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Our Soft Wash Method</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Low pressure — no risk of cracking panels or seals
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Specialist detergent dissolves algae safely
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Safe for polycarbonate, glass, uPVC and seals
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Biocide treatment keeps it clean for 2–3 years
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Conservatory restored safely — brighter inside, no damage, no leaks
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Assessment</h4>
                  <p class="process-step__body">We inspect roof type, panel condition, frame material and access requirements before pricing.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Detergent Application</h4>
                  <p class="process-step__body">Specialist soft wash solution applied to roof panels and frames at low pressure.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Dwell Time</h4>
                  <p class="process-step__body">Solution left to penetrate and break down algae colonies for the recommended period.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Low-Pressure Rinse</h4>
                  <p class="process-step__body">Thorough rinse at safe pressure removes all residue — panels clear, frames white.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Biocide Treatment</h4>
                  <p class="process-step__body">Anti-algae spray applied to roof panels to significantly slow regrowth.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Green conservatory roof blocking the light? We can quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Let the Light Back In</h3>
            <p class="sidebar-card__body">Get a free, no-obligation quote for conservatory cleaning in Bath and surrounding areas.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Other Services</span>
            <h3 class="sidebar-card__heading">Explore Our Services</h3>
            <ul class="sidebar-links">
              <li><a href="/gutter-cleaning-bath">Gutter Cleaning Bath</a></li>
              <li><a href="/soffit-fascia-cleaning-bath">Soffit & Fascia Cleaning Bath</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning Bath</a></li>
              <li><a href="/roof-cleaning-bath">Roof Cleaning Bath</a></li>
              <li><a href="/driveway-cleaning-bath">Driveway Cleaning Bath</a></li>
              <li><a href="/bristol/">Jet Washing Bristol</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="Our Work" heading="Conservatory Cleaning Results" body="A green, dirty conservatory roof blocks light and looks neglected. Our soft wash system restores glass and polycarbonate roofs safely." align="center" />
      <div class="before-after-wrap">
        <img src="/images/before-after/conservatory-midclean-1.jpg" alt="Conservatory roof mid-clean — left side green with algae, right side restored to clear panels" class="before-after-composite" />
        <p class="before-after-caption">Same conservatory roof, same visit — half cleaned to show exactly what our soft wash system does.</p>
      </div>
      <div class="photo-library">
        <div class="photo-library__header">
          <p class="photo-library__sub">More photos from recent conservatory jobs</p>
          <span class="photo-library__count">4 photos</span>
        </div>
        <div class="photo-library__grid">
          <a href="/images/before-after/conservatory-midclean-1.jpg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: conservatory mid-clean">
            <img src="/images/before-after/conservatory-midclean-1.jpg" alt="Conservatory roof mid-clean showing before and after contrast" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/conservatory-action-1.jpg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: conservatory cleaning in action">
            <img src="/images/before-after/conservatory-action-1.jpg" alt="Robert cleaning a modern lantern roof extension in Bath" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/conservatory-hero-1.jpg" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: large Bath conservatory">
            <img src="/images/before-after/conservatory-hero-1.jpg" alt="Large Bath property conservatory before cleaning" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-08.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: large property with conservatory">
            <img src="/images/before-after/job-gallery-08.webp" alt="Large rendered property with conservatory fully cleaned" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Conservatory Cleaning FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="district-links-section">
    <div class="container">
      <h2 class="district-links__heading">Conservatory Cleaning Across Bath</h2>
      <p class="district-links__intro">We cover every Bath district. Click your area for a dedicated local page.</p>
      <ul class="district-links__grid">
        <li><a href="/conservatory-cleaning/oldfield-park-bath">Conservatory Cleaning Oldfield Park</a></li>
        <li><a href="/conservatory-cleaning/combe-down-bath">Conservatory Cleaning Combe Down</a></li>
        <li><a href="/conservatory-cleaning/bear-flat-bath">Conservatory Cleaning Bear Flat</a></li>
        <li><a href="/conservatory-cleaning/newbridge-bath">Conservatory Cleaning Newbridge</a></li>
        <li><a href="/conservatory-cleaning/twerton-bath">Conservatory Cleaning Twerton</a></li>
        <li><a href="/conservatory-cleaning/weston-bath">Conservatory Cleaning Weston</a></li>
      </ul>
    </div>
  </section>

  <ImageCTA heading="A Clean Conservatory Makes the Room" body="Get a free, no-obligation quote from Bath's highest-rated jet washing service. 111 five-star reviews. Fully insured. Eco-friendly products." cta={{ label: 'Get a Free Quote', href: '/contact' }} image="/images/before-after/conservatory-hero-1.jpg" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
