---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import { locationsDatabase } from '../../data/locations';

export async function getStaticPaths() {
  return locationsDatabase.map((location) => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
---

<Base title={location.metaTitle}>
  {/* ── Hero ── */}
  <Hero
    image="/images/hero-bath.jpg"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Locations', href: '/locations' }, { label: location.townName }]}
    eyebrow={location.heroEyebrow}
    heading={location.heroHeading}
    body={location.heroBody}
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust Bar ── */}
  <section style="background:var(--charcoal);padding:var(--space-xl) 0">
    <div class="container" style="display:flex;justify-content:center;gap:var(--space-2xl);flex-wrap:wrap;text-align:center">
      <div><span class="t-label" style="color:var(--accent);display:block">4.9 Rating</span><span style="color:rgba(255,255,255,.72);font-size:.88rem">Local Homeowners</span></div>
      <div><span class="t-label" style="color:var(--accent);display:block">TrustATrader</span><span style="color:rgba(255,255,255,.72);font-size:.88rem">Certified & Verified</span></div>
      <div><span class="t-label" style="color:var(--accent);display:block">&pound;5M+ Cover</span><span style="color:rgba(255,255,255,.72);font-size:.88rem">Fully Insured</span></div>
      <div><span class="t-label" style="color:var(--accent);display:block">Turnkey</span><span style="color:rgba(255,255,255,.72);font-size:.88rem">Professional Maintenance</span></div>
    </div>
  </section>

  {/* ── Editorial Split: Regional Context ── */}
  <section style="padding:var(--section-pad) 0">
    <div class="container">
      <div class="editorial-grid">
        {/* Left: Regional narrative */}
        <div class="editorial-copy">
          <SectionHeader
            eyebrow={`Regional Operations · ${location.townName}`}
            heading={location.editorialHeading}
            body={location.editorialBody}
          />
        </div>

        {/* Right: Property specialisms checklist */}
        <div class="editorial-checklist">
          <div class="checklist-inner">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Core Property Specialisms</span>
            <h3 class="checklist-heading">What We Deliver in {location.townName}</h3>
            <ul class="checklist">
              {location.propertyFocus.map((item) => (
                <li class="checklist-item">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="checklist-icon">
                    <path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="checklist-badge">
              Fully Vetted &middot; Insured to &pound;5M &middot; Accredited Trades
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Local Logistics Note ── */}
  <section style="background:var(--stone);padding:var(--space-xl) 0">
    <div class="container" style="max-width:var(--text-max)">
      <div class="nuance-block">
        <span class="rule--accent"></span>
        <span class="t-label" style="color:var(--accent)">Local Logistics</span>
        <p class="nuance-text">{location.localNuance}</p>
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading={location.ctaHeading}
    body="Arrange an on-site evaluation with our build management team. Clear advice, strict structural assessment, and itemized transparent cost breakdowns."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-bath.jpg"
    imagePosition="center 60%"
  />
</Base>

<style>
  /* ── Editorial grid: copy left, checklist right ── */
  .editorial-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-3xl, 5rem);
    align-items: start;
  }

  .editorial-copy {
    padding-top: var(--space-xs);
  }

  .editorial-checklist {
    background: #fff;
    border: 1px solid var(--stone);
    padding: var(--space-xl);
  }

  .checklist-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .checklist-heading {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.8rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--chalk);
    margin: 0;
    padding-bottom: var(--space-m);
    border-bottom: 1px solid var(--stone);
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-s);
    font-size: 0.92rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--chalk);
  }

  .checklist-icon {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .checklist-badge {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--concrete);
    text-align: center;
    padding-top: var(--space-m);
    border-top: 1px solid var(--stone);
  }

  /* ── Local nuance callout ── */
  .nuance-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: var(--space-l) var(--space-xl);
    border-left: 3px solid var(--accent);
    background: #fff;
  }

  .nuance-text {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--chalk);
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 960px) {
    .editorial-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 640px) {
    .editorial-grid {
      gap: var(--space-l);
    }

    .nuance-block {
      padding: var(--space-m);
    }
  }
</style>