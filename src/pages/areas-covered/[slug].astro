---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import { locationsDatabase } from '../../data/locations';
import { servicesData } from '../../data/services';

export async function getStaticPaths() {
  return locationsDatabase.map((location) => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;

const isDistrict = location.group === 'bath-district' || location.group === 'bristol-district';
const comboHrefs: Record<string, string> = isDistrict ? {
  'driveway-cleaning': `/driveway-cleaning/${location.slug}`,
  'patio-cleaning':    `/patio-cleaning/${location.slug}`,
  'roof-cleaning':     `/roof-cleaning/${location.slug}`,
} : {};
function serviceHref(s: typeof servicesData[0]) { return comboHrefs[s.id] || s.href; }

// Build FAQ schema
const faqSchema = location.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": location.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
} : null;

// Build Service schema
const serviceSchema = servicesData.map(s => ({
  "@type": "Service",
  "name": `${s.title} in ${location.townName}`,
  "description": location.serviceContext[s.id] || s.description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "07474939398",
    "areaServed": { "@type": "City", "name": location.townName }
  }
}));
---

<Base title={location.metaTitle}
  description={location.metaDescription}>

  {/* ── Schema ── */}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": `RG Extreme Pressure — ${location.townName}`,
    "telephone": "07474939398",
    "address": { "@type": "PostalAddress", "addressLocality": location.townName, "addressRegion": location.county, "addressCountry": "GB" },
    "geo": { "@type": "GeoCoordinates", "latitude": location.lat, "longitude": location.lng },
    "areaServed": { "@type": "City", "name": location.townName },
    "hasOfferCatalog": { "@type": "OfferCatalog", "name": `Jet Washing Services in ${location.townName}`, "itemListElement": serviceSchema },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "bestRating": "5", "reviewCount": "111" }
  })} />

  {/* ── Hero ── */}
  <Hero
    image="/images/before-after/roof-after-2.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Areas Covered' }, { label: location.townName }]}
    eyebrow={location.heroEyebrow}
    heading={location.heroHeading}
    body={location.heroBody}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust Metrics ── */}
  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: '5.2K', label: 'FB Followers' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  {/* ── Editorial Overview ── */}
  <section class="editorial-section">
    <div class="container">
      <SectionHeader
        eyebrow={`Jet Washing Services · ${location.townName}`}
        heading={location.editorialHeading}
        body={location.editorialBody}
      />
      <div class="nuance-block">
        <span class="t-label" style="color:var(--accent)">Local Knowledge</span>
        <p class="nuance-text">{location.localNuance}</p>
      </div>
    </div>
  </section>

  {/* ── Service Cards Grid (matches /services design) ── */}
  <section class="service-cards-section">
    <div class="container">
      <SectionHeader
        eyebrow={`Our Services in ${location.townName}`}
        heading={`Jet Washing Services Available`}
        body={`Professional external cleaning services across ${location.townName} and surrounding areas. Click through for full details.`}
      />
      <div class="service-cards-grid">
        {servicesData.map(s => (
          <a href={serviceHref(s)} class="service-card">
            <div class="service-card__icon">
              {s.id === 'driveway-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="1"/><path d="M5 11V7a2 2 0 012-2h10a2 2 0 012 2v4"/><line x1="3" y1="16" x2="21" y2="16"/></svg>}
              {s.id === 'patio-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>}
              {s.id === 'gutter-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 6l2 12h12l2-12"/><path d="M10 10v4M14 10v4"/><path d="M8 6V4h8v2"/></svg>}
              {s.id === 'roof-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-16 9 16H3z"/><path d="M12 10v6M12 18h.01"/></svg>}
              {s.id === 'render-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>}
              {s.id === 'block-paving-cleaning' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="1" width="10" height="10" rx="1"/><rect x="13" y="1" width="10" height="10" rx="1"/><rect x="1" y="13" width="10" height="10" rx="1"/><rect x="13" y="13" width="10" height="10" rx="1"/></svg>}
            </div>
            <span class="service-card__subtitle">{s.subtitle}</span>
            <h3 class="service-card__title">{s.title}</h3>
            <p class="service-card__desc">{(location.serviceContext[s.id] || s.description).slice(0, 120)}...</p>
            <span class="service-card__link">
              Learn More
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ── 6 Service Sections — each with H2 targeting "service + town" ── */}
  {servicesData.map((service, i) => (
    <section class:list={['service-detail', i % 2 === 0 ? 'service-detail--even' : 'service-detail--odd']}>
      <div class="container">
        <div class="service-detail__grid">
          <div class="service-detail__copy">
            <h2 class="service-detail__h2" id={service.id}>{service.title} in {location.townName}</h2>
            <p class="service-detail__body">{location.serviceContext[service.id] || service.description}</p>
            <ul class="service-detail__features">
              {service.features.map((f) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a href={serviceHref(service)} class="service-detail__link">Learn more about {service.title.toLowerCase()} &rarr;</a>
          </div>
          <div class="service-detail__aside">
            <div class="service-detail__card">
              <span class="service-detail__card-eyebrow">From</span>
              <span class="service-detail__card-price">{service.id === 'gutter-cleaning' ? '£39' : service.id === 'roof-cleaning' ? '£299' : service.id === 'render-cleaning' ? '£89' : service.id === 'patio-cleaning' ? '£79' : '£59'}</span>
              <span class="service-detail__card-label">Free quotes available</span>
              <a href="/contact" class="service-detail__card-cta">Get a Quote</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* ── Video ── */}
  <section class="video-section">
    <div class="container">
      <SectionHeader
        eyebrow="See Us In Action"
        heading="Watch Our Work"
        body={`Professional jet washing that transforms properties across ${location.townName} and surrounding areas.`}
        align="center"
      />
      <div class="video-wrap">
        <iframe
          src="https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2F100091066506303%2Fvideos%2F1751025128677768%2F&show_text=false&width=560&t=0"
          width="560"
          height="314"
          style="border:none;overflow:hidden"
          scrolling="no"
          frameborder="0"
          allowfullscreen="true"
          loading="lazy"
          title="RG Extreme Pressure — jet washing demo video"
        ></iframe>
      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  <section class="faq-section">
    <div class="container" style="max-width:var(--text-max)">
      <SectionHeader
        eyebrow={`Questions About Jet Washing in ${location.townName}`}
        heading={`Frequently Asked Questions`}
      />
      <div class="faq-list">
        {location.faq.map((item, i) => (
          <details class="faq-item">
            <summary class="faq-item__q"><span>{item.q}</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
            <p class="faq-item__a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading={location.ctaHeading}
    body="Call 07474 939 398 for a free, no-obligation quote. We cover all surrounding areas."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after-2.webp"
  />
</Base>

<style>
  /* ── Editorial ── */
  .editorial-section {
    padding: var(--section-pad) 0;
    background: var(--surface);
  }

  /* ── Service Cards (matches /services) ── */
  .service-cards-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    padding-top: var(--space-l);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid rgba(0,85,165,0.08);
    border-radius: var(--radius);
    padding: var(--space-l);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(0,85,165,0.12);
    transform: translateY(-2px);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,85,165,0.06);
    border-radius: 50%;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .service-card__subtitle {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.15;
    color: var(--chalk);
    margin: 0;
  }

  .service-card__desc {
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
  }

  .service-card__link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: auto;
    padding-top: var(--space-s);
  }

  @media (max-width: 768px) {
    .service-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 960px) {
    .service-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .nuance-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-xl);
    padding: var(--space-l) var(--space-xl);
    border-left: 3px solid var(--accent);
    background: #fff;
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .nuance-text {
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--chalk);
    margin: 0;
    font-style: italic;
  }

  /* ── Service detail sections ── */
  .service-detail {
    padding: var(--section-pad) 0;
  }

  .service-detail--even {
    background: #fff;
  }

  .service-detail--odd {
    background: var(--surface);
  }

  .service-detail__grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-3xl);
    align-items: start;
  }

  .service-detail__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--chalk);
    margin: 0 0 var(--space-m);
  }

  .service-detail__body {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--concrete);
    margin: 0 0 var(--space-l);
  }

  .service-detail__features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .service-detail__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--chalk);
  }

  .service-detail__features svg {
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .service-detail__link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }

  .service-detail__link:hover {
    color: var(--accent-dim);
  }

  /* ── Price card ── */
  .service-detail__card {
    background: var(--cta);
    color: #fff;
    border-radius: var(--radius);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
    position: sticky;
    top: 6rem;
  }

  .service-detail__card-eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .service-detail__card-price {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
  }

  .service-detail__card-label {
    font-size: 0.8rem;
    font-weight: 400;
    opacity: 0.8;
    margin-bottom: var(--space-m);
  }

  .service-detail__card-cta {
    display: inline-block;
    background: #fff;
    color: var(--cta);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.2s;
  }

  .service-detail__card-cta:hover {
    background: var(--cta-light);
  }

  /* ── Video ── */
  .video-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .video-wrap {
    max-width: 640px;
    margin: 0 auto;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,85,165,0.1);
  }

  .video-wrap iframe {
    width: 100%;
    height: auto;
    aspect-ratio: 560 / 314;
    display: block;
  }

  /* ── FAQ ── */
  .faq-section {
    padding: var(--section-pad) 0;
    background: #fff;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-xl);
  }

  .faq-item {
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding: var(--space-l);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--chalk);
    cursor: pointer;
    list-style: none;
  }

  .faq-item__q::-webkit-details-marker {
    display: none;
  }

  .faq-item__q svg {
    flex-shrink: 0;
    transition: transform 0.2s;
    color: var(--accent);
  }

  .faq-item[open] .faq-item__q svg {
    transform: rotate(180deg);
  }

  .faq-item__a {
    padding: 0 var(--space-l) var(--space-l);
    font-size: 0.92rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--concrete);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .service-detail__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .service-detail__card {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-s);
      padding: var(--space-l);
    }

    .service-detail__card-price {
      font-size: 1.6rem;
    }

    .nuance-block {
      padding: var(--space-m);
    }
  }
</style>