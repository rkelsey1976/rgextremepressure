---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import FbVideoFacade from '../../components/FbVideoFacade.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import { locationsDatabase } from '../../data/locations';
import ServiceCard from '../../components/ServiceCard.astro';
import { servicesData } from '../../data/services';
import TrustMetrics from '../../components/TrustMetrics.astro';

export async function getStaticPaths() {
  return locationsDatabase.map((location) => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;

const isDistrict = location.group === 'bath-district' || location.group === 'bristol-district';
const comboHrefs: Record<string, string> = isDistrict ? {
  'driveway-cleaning': `/driveway-cleaning/${location.slug}`,
  'patio-cleaning':    `/patio-cleaning/${location.slug}`,
  'roof-cleaning':     `/roof-cleaning/${location.slug}`,
} : {};
function serviceHref(s: typeof servicesData[0]) { return comboHrefs[s.id] || s.href; }

// Build FAQ schema
const faqSchema = location.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": location.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
} : null;

// Build Service schema
const serviceSchema = servicesData.map(s => ({
  "@type": "Service",
  "name": `${s.title} in ${location.townName}`,
  "description": location.serviceContext[s.id] || s.description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "07474939398",
    "areaServed": { "@type": "City", "name": location.townName }
  }
}));
---

<Base title={location.metaTitle}
  description={location.metaDescription}>

  {/* ── Schema ── */}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": `RG Extreme Pressure — ${location.townName}`,
    "telephone": "07474939398",
    "address": { "@type": "PostalAddress", "addressLocality": location.townName, "addressRegion": location.county, "addressCountry": "GB" },
    "geo": { "@type": "GeoCoordinates", "latitude": location.lat, "longitude": location.lng },
    "areaServed": { "@type": "City", "name": location.townName },
    "hasOfferCatalog": { "@type": "OfferCatalog", "name": `Jet Washing Services in ${location.townName}`, "itemListElement": serviceSchema },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "bestRating": "5", "reviewCount": "111" }
  })} />

  {/* ── Hero ── */}
  <Hero
    image="/images/before-after/roof-after.jpg"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Areas Covered' }, { label: location.townName }]}
    eyebrow={location.heroEyebrow}
    heading={location.heroHeading}
    body={location.heroBody}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  {/* ── Trust Metrics ── */}

  {/* ── Editorial Overview ── */}
  <section class="editorial-section">
    <div class="container">
      <SectionHeader
        eyebrow={`Jet Washing Services · ${location.townName}`}
        heading={location.editorialHeading}
        body={location.editorialBody}
      />
      <div class="nuance-block">
        <span class="t-label" style="color:var(--accent)">Local Knowledge</span>
        <p class="nuance-text">{location.localNuance}</p>
      </div>
    </div>
  </section>

  <div class="inline-cta container-cta">
    <p class="inline-cta__text">Need a quote in {location.townName}? We're usually out within the week.</p>
    <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
  </div>

  {/* ── Service Cards Grid (matches /services design) ── */}
  <section class="service-cards-section">
    <div class="container">
      <SectionHeader
        eyebrow={`Our Services in ${location.townName}`}
        heading={`Jet Washing Services Available`}
        body={`Professional external cleaning services across ${location.townName} and surrounding areas. Click through for full details.`}
      />
      <div class="service-cards-grid">
        {servicesData.map(s => (
          <ServiceCard href={serviceHref(s)} image={s.image} title={s.title} subtitle={s.subtitle} description={location.serviceContext[s.id] || s.description} />
        ))}
      </div>
    </div>
  </section>

  {/* ── Video ── */}
  <section class="video-section">
    <div class="container">
      <SectionHeader
        eyebrow="See Us In Action"
        heading="Watch Our Work"
        body={`Professional jet washing that transforms properties across ${location.townName} and surrounding areas.`}
        align="center"
      />
      <div class="video-wrap">
        <FbVideoFacade
          src="https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2F100091066506303%2Fvideos%2F1751025128677768%2F&show_text=false&width=560&t=0"
          title="RG Extreme Pressure — jet washing demo video"
          poster="/images/before-after/roof-after-2.webp"
        />
      </div>
    </div>
  </section>

  {/* ── Before & After ── */}
  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body={`Real results from recent jobs in and around ${location.townName}.`} align="center" />
      <div class="ba-grid">
        <div class="before-after-wrap">
          <BeforeAfter
            beforeSrc="/images/before-after/drive-before.jpg"
            afterSrc="/images/before-after/drive-after.jpg"
            beforeAlt="Block paving driveway before cleaning"
            afterAlt="Block paving driveway after jet washing"
            caption="Driveway — algae and staining removed"
          />
        </div>
        <div class="before-after-wrap">
          <BeforeAfter
            beforeSrc="/images/before-after/roof-before.jpg"
            afterSrc="/images/before-after/roof-after.jpg"
            beforeAlt="Roof tiles covered in moss before cleaning"
            afterAlt="Roof tiles restored after moss removal"
            caption="Roof — moss removed using our spinning brush system"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  <section class="faq-section">
    <div class="container" style="max-width:var(--text-max)">
      <SectionHeader
        eyebrow={`Questions About Jet Washing in ${location.townName}`}
        heading={`Frequently Asked Questions`}
      />
      <div class="faq-list">
        {location.faq.map((item, i) => (
          <details class="faq-item">
            <summary class="faq-item__q"><span>{item.q}</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
            <p class="faq-item__a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading={location.ctaHeading}
    body="Call 07474 939 398 for a free, no-obligation quote. We cover all surrounding areas."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after.jpg"
  />
</Base>

<style>
  /* ── Inline CTA ── */
  .container-cta {
    padding: 0 var(--space-l);
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
  }
  .inline-cta {
    margin: var(--space-2xl) auto;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--accent-dim) 100%);
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
    flex-wrap: wrap;
  }
  .inline-cta__text {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Before & After ── */
  .before-after-section {
    padding: var(--section-pad) 0;
    background: var(--stone);
  }
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }
  .before-after-wrap { max-width: 100%; }

  @media (max-width: 768px) {
    .ba-grid { grid-template-columns: 1fr; }
    .inline-cta { flex-direction: column; align-items: flex-start; }
  }

  /* ── Editorial ── */
  .editorial-section {
    padding: var(--section-pad) 0;
    background: var(--surface);
  }

  /* ── Service Cards (matches /services) ── */
  .service-cards-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    padding-top: var(--space-l);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid rgba(0,85,165,0.08);
    border-radius: var(--radius);
    padding: var(--space-l);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(0,85,165,0.12);
    transform: translateY(-2px);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,85,165,0.06);
    border-radius: 50%;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .service-card__subtitle {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.15;
    color: var(--chalk);
    margin: 0;
  }

  .service-card__desc {
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--concrete);
    margin: 0;
  }

  .service-card__link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: auto;
    padding-top: var(--space-s);
  }

  @media (max-width: 768px) {
    .service-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 960px) {
    .service-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .nuance-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-xl);
    padding: var(--space-l) var(--space-xl);
    border-left: 3px solid var(--accent);
    background: #fff;
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .nuance-text {
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--chalk);
    margin: 0;
    font-style: italic;
  }

  /* ── Video ── */
  .video-section {
    background: #fff;
    padding: var(--section-pad) 0;
  }

  .video-wrap {
    max-width: 640px;
    margin: 0 auto;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,85,165,0.1);
  }

  .video-wrap iframe {
    width: 100%;
    height: auto;
    aspect-ratio: 560 / 314;
    display: block;
  }

  /* ── FAQ ── */
  .faq-section {
    padding: var(--section-pad) 0;
    background: #fff;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-xl);
  }

  .faq-item {
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    padding: var(--space-l);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--chalk);
    cursor: pointer;
    list-style: none;
  }

  .faq-item__q::-webkit-details-marker {
    display: none;
  }

  .faq-item__q svg {
    flex-shrink: 0;
    transition: transform 0.2s;
    color: var(--accent);
  }

  .faq-item[open] .faq-item__q svg {
    transform: rotate(180deg);
  }

  .faq-item__a {
    padding: 0 var(--space-l) var(--space-l);
    font-size: 0.92rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--concrete);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .service-detail__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .nuance-block {
      padding: var(--space-m);
    }
  }
</style>