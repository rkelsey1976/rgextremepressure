---
// services-2/index.astro — New 9-service layout (draft for review)
// Side-by-side with current /services/ — NOT linked from nav yet
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';

const services = [
  {
    icon: 'home',
    title: 'Home Refurbishments & Renovations',
    description: 'Full property transformations — stripping back to the shell and rebuilding with modern standards while respecting original character. From single-room refreshes to complete home overhauls.',
    features: ['Full property strip-outs and rebuilds', 'Period-sensitive renovations', 'Structural alterations and reconfigurations', 'Project-managed from start to finish'],
  },
  {
    icon: 'kitchen',
    title: 'Kitchens & Bathrooms',
    description: 'Complete supply and fit kitchen and bathroom installations. From design through to tiling and final fix — one team, one quote, no subcontractor surprises.',
    features: ['Full supply & fit kitchens', 'Bathroom and wetroom installations', 'Tiling, plumbing and electrical', 'Bespoke joinery and worktops'],
  },
  {
    icon: 'extension',
    title: 'Extensions & Structural Alterations',
    description: 'Single and double-storey extensions, structural knock-throughs, and load-bearing wall removals. Full planning support and building regs compliance included.',
    features: ['Single & double-storey extensions', 'Structural steel and RSJ installations', 'Loft and basement conversions', 'Party wall and planning management'],
  },
  {
    icon: 'masonry',
    title: 'Masonry, Brickwork & Stonework',
    description: 'Bath stone restoration, lime mortar repointing, brickwork repairs and new builds. We work with traditional materials and methods that respect the local architecture.',
    features: ['Bath stone repair and restoration', 'Lime mortar repointing', 'New brickwork and blockwork', 'Stone walling and features'],
  },
  {
    icon: 'paint',
    title: 'Painting & Decorating',
    description: "Interior and exterior painting to a high standard. Careful preparation, quality materials, and a flawless finish — whether it's a heritage property or a modern home.",
    features: ['Internal painting and wallpapering', 'External masonry and woodwork', 'Period-appropriate finishes', 'Preparation and repairs included'],
  },
  {
    icon: 'plaster',
    title: 'Plastering & Rendering',
    description: 'Skimming, boarding, rendering, and traditional lime plasterwork. Smooth finishes inside and weatherproof coatings outside — all carried out by experienced tradesmen.',
    features: ['Skimming and plasterboarding', 'External rendering and K-rend', 'Traditional lime plastering', 'Damp-proof rendering systems'],
  },
  {
    icon: 'maintenance',
    title: 'General Building & Property Maintenance',
    description: 'Ongoing property upkeep, small repairs, and general building works. Leaks, doors, floors, gutters — the jobs that keep your property in good order.',
    features: ['Property maintenance contracts', 'Small repairs and handyman works', 'Door, window and floor repairs', 'Guttering, roofing and drainage'],
  },
  {
    icon: 'landscape',
    title: 'Groundworks, Landscaping & External Works',
    description: 'Driveways, patios, retaining walls, drainage, and garden landscaping. We handle the outside of your property with the same care as the inside.',
    features: ['Driveways and patios', 'Retaining walls and steps', 'Drainage and groundworks', 'Garden hard landscaping'],
  },
  {
    icon: 'damp',
    title: 'Damp, Mould & Small Works Solutions',
    description: "Targeted treatments for damp problems, mould issues, and those smaller jobs that don't need a full project team. Honest diagnosis, effective solutions.",
    features: ['Damp surveys and treatments', 'Mould remediation and prevention', 'Tanking and waterproofing', 'Small works and one-off fixes'],
  },
];

const iconPaths: Record<string, string> = {
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1',
  kitchen: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2M4 7h16M9 7v13m-5 0h16M4 7v13',
  extension: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0V5M5 21v-4m7-12v4m0 4v4',
  masonry: 'M4 4h4v4H4zM10 4h4v4h-4zM16 4h4v4h-4zM4 10h4v4H4zM10 10h4v4h-4zM16 10h4v4h-4zM4 16h4v4H4zM10 16h4v4h-4zM16 16h4v4h-4z',
  paint: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z',
  plaster: 'M4 4h16v2H4zM4 8h16v2H4zM4 12h16v2H4zM4 16h10v2H4z',
  maintenance: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.573-1.066zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
  landscape: 'M3 21h18M3 7v1a3 3 0 006 0V7m0 1a3 3 0 006 0V7m0 1a3 3 0 006 0V7H3l1.5-4h15L21 7M5 21V10M9 21V10M13 21V10M17 21V10',
  damp: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
};
---

<Base title="Our Services | Aspect Builds & Maintenance" preloadImage="/images/hero-batheaston-renovation.webp">
  {/* ── Hero ── */}
  <Hero
    image="/images/hero-batheaston-renovation.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
    eyebrow="What We Do"
    heading="Quality Building You Can Trust"
    body="From full refurbishments and extensions to painting, plastering, and property maintenance — Aspect Builds delivers reliable, high-quality work across Bath and the surrounding areas."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust bar ── */}
  <TrustMetrics metrics={[
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Skilled', label: 'Dependable Workforce' },
    { value: 'Fixed', label: 'Transparent Pricing' },
    { value: 'Clean', label: 'Respect for Your Home' },
  ]} />

  {/* ── Services grid ── */}
  <section class="svc-grid-section">
    <div class="container">
      <SectionHeader
        eyebrow="Our Services"
        heading="What We Do"
        body="Home refurbishments, kitchens, extensions, masonry, painting, plastering, maintenance, landscaping and damp solutions — one team covering everything your property needs."
      />

      <div class="svc-grid">
        {services.map((svc, i) => (
          <div class="svc-card" data-index={i + 1}>
            <div class="svc-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[svc.icon]}/>
              </svg>
            </div>
            <div class="svc-card__num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="svc-card__title">{svc.title}</h3>
            <p class="svc-card__desc">{svc.description}</p>
            <ul class="svc-card__features">
              {svc.features.map((feat) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="svc-card__check">
                    <path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Guarantee section ── */}
  <section class="guarantee-section">
    <div class="container">
      <div class="guarantee-header">
        <div class="guarantee-header__left">
          <span class="rule--accent"></span>
          <span class="t-label guarantee-eyebrow">The Aspect Builds Guarantee</span>
          <h2 class="guarantee-heading">Honest Advice.<br/>Transparent Pricing.<br/>Clean Sites.</h2>
        </div>
        <div class="guarantee-header__right">
          <p class="guarantee-intro">Fully insured and professional service. Skilled, friendly, and dependable workforce. Honest advice with transparent pricing — what we quote is what you pay.</p>
          <a href="/contact" class="btn btn--outline-light guarantee-cta">
            Get a Free Quote
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <div class="guarantee-divider"></div>

      <div class="guarantee-grid">
        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">01</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Fully Insured Service</h3>
            <p class="guarantee-desc">Fully insured and professional service on every project. Your property and our workforce are fully protected.</p>
            <span class="guarantee-proof">Full insurance documentation provided</span>
          </div>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">02</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Transparent Pricing</h3>
            <p class="guarantee-desc">Itemised quotes agreed before work starts. No hidden costs, no surprise extras. Honest advice on what your project needs.</p>
            <span class="guarantee-proof">Fixed quotes on every project</span>
          </div>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">03</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Clean, Respectful Sites</h3>
            <p class="guarantee-desc">Dust sheets, daily tidy-ups, and protected access routes. Your home gets treated with respect — we leave it spotless.</p>
            <span class="guarantee-proof">Clean site protocols as standard</span>
          </div>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-num" aria-hidden="true">04</span>
          <div class="guarantee-item__body">
            <h3 class="guarantee-title">Direct Communication</h3>
            <p class="guarantee-desc">Speak directly to James, the person running your project. No passed messages, no unanswered calls.</p>
            <span class="guarantee-proof">Same-day callback guarantee</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready to Start Your Project?"
    body="Whether you need a full refurbishment, a new kitchen, or a trusted builder for ongoing maintenance — get in touch for a free, no-obligation quote."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/hero-batheaston-renovation.webp"
  />
</Base>

<style>
  /* ── Services grid section ── */
  .svc-grid-section {
    padding: var(--section-pad) 0;
    background: #fff;
  }

  /* ── 3-column card grid ── */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: var(--space-2xl);
  }

  .svc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: var(--space-xl);
    background: #fff;
    border: 1px solid var(--stone);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .svc-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  }

  .svc-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .svc-card__num {
    position: absolute;
    top: var(--space-l);
    right: var(--space-l);
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.12;
  }

  .svc-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--chalk);
    margin: 0;
  }

  .svc-card__desc {
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--concrete);
    margin: 0;
  }

  .svc-card__features {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-top: auto;
  }

  .svc-card__features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--chalk);
  }

  .svc-card__check {
    flex-shrink: 0;
  }

  /* ── Guarantee section ── */
  .guarantee-section {
    background: var(--charcoal);
    padding: var(--section-pad) 0;
  }

  .guarantee-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl, 5rem);
    align-items: end;
  }

  .guarantee-header__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .guarantee-eyebrow {
    color: var(--accent);
  }

  .guarantee-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .guarantee-header__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding-bottom: 0.25rem;
  }

  .guarantee-intro {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-width: 52ch;
  }

  .btn--outline-light {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s;
    align-self: flex-start;
  }

  .btn--outline-light:hover {
    border-color: var(--accent);
    background: rgba(174, 132, 85, 0.1);
  }

  .btn--outline-light svg {
    transition: transform 0.3s var(--ease-out-expo);
  }

  .btn--outline-light:hover svg {
    transform: translateX(4px);
  }

  .guarantee-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: var(--space-2xl) 0;
  }

  .guarantee-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .guarantee-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding: var(--space-xl);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 3px solid transparent;
    transition: border-top-color 0.3s;
  }

  .guarantee-item:hover {
    border-top-color: var(--accent);
  }

  .guarantee-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 5vw, 6rem);
    line-height: 1;
    color: var(--accent);
    opacity: 0.25;
    display: block;
    transition: opacity 0.3s;
  }

  .guarantee-item:hover .guarantee-num {
    opacity: 0.6;
  }

  .guarantee-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    flex: 1;
  }

  .guarantee-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.8vw, 2rem);
    line-height: 1.05;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .guarantee-desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    flex: 1;
  }

  .guarantee-proof {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    padding-top: var(--space-m);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .guarantee-header {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 960px) {
    .svc-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .guarantee-grid {
      grid-template-columns: repeat(2, 1fr);
      border-left: none;
    }

    .guarantee-item {
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }
  }

  @media (max-width: 640px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }

    .guarantee-grid {
      grid-template-columns: 1fr;
    }
  }
</style>