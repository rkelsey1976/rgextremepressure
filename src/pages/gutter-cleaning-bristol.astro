---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';

const title = 'Gutter Cleaning Bristol';
const description = 'Professional gutter cleaning across Bristol (BS1–BS16). Full gutter clear, downpipe flush and inspection. Blocked gutters cause damp and rot. 111 five-star reviews. Call 07474 939 398.';

const faqs = [
  {
    q: 'Do you clean gutters across all Bristol postcodes?',
    a: 'Yes. We cover all Bristol postcodes from BS1 to BS16, including Clifton, Redland, Bishopston, Henleaze, Kingswood, Fishponds, Brislington, Bedminster, Downend, Westbury-on-Trym and surrounding areas.',
  },
  {
    q: 'How often should Bristol gutters be cleaned?',
    a: "We recommend annual gutter clearing for most Bristol properties, ideally in November after leaf fall. Bristol's large street tree population means gutters fill faster than in areas with fewer mature trees — properties on tree-lined streets may benefit from twice-yearly clearing.",
  },
  {
    q: 'Can you clean gutters without ladders in Bristol?',
    a: 'Yes. We use a ground-based SkyVac vacuum system with telescopic lances that reaches up to 40 feet without ladders — ideal for conservatories, extensions and difficult access situations. For heavily compacted debris we use hand-clearing from ladders where access allows.',
  },
  {
    q: 'Will you check for gutter damage during the clean in Bristol?',
    a: 'Absolutely. As part of every Bristol gutter clear we inspect joints, brackets and downpipes for damage. We will report any issues and can carry out minor repairs — resealing joints, reattaching brackets or clearing downpipe blockages — on the same visit.',
  },
  {
    q: 'How much does gutter cleaning cost in Bristol?',
    a: 'Gutter cleaning in Bristol starts from £39 for a standard terraced property. Semi-detached and detached properties typically range from £59–£99 depending on run length and access. We provide free quotes — call 07474 939 398.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Gutter Cleaning Bristol",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" },
  },
  "areaServed": { "@type": "City", "name": "Bristol" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" },
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[{ name: 'Services', item: 'https://rgextremepressure.co.uk/services' }, { name: 'Gutter Cleaning Bristol', item: 'https://rgextremepressure.co.uk/gutter-cleaning-bristol' }]}>
  <Hero
    image="/images/before-after/job-gallery-18.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Bristol', href: '/bristol' }, { label: 'Gutter Cleaning' }]}
    eyebrow="Professional Gutter Cleaning Bristol"
    heading="Gutter Cleaning Bristol"
    body="Blocked gutters are one of the leading causes of damp and structural damage in Bristol homes. Professional gutter clearing, downpipe flushing and minor repair across all Bristol postcodes. 111 five-star reviews. Free quotes."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="Gutter Cleaning Across Bristol"
            heading="Professional Gutter Clearing in Bristol"
            body="Bristol's abundant mature street trees fill gutters with leaf debris faster than almost anywhere in the South West. Blocked gutters overflow onto fascias and soffits, saturate brickwork and cause costly damp problems inside. Our professional gutter clearing removes all debris, flushes downpipes and checks for damage — leaving your gutters working properly."
          />

          <div class="service-intro-image">
            <img src="/images/before-after/gutter-skyvac-action-1.webp" alt="SkyVac ground-based vacuum system clearing blocked gutters at a Bristol property" loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">What Our Bristol Gutter Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Full Gutter Clear</strong>
                  <p class="feature-card__body">All leaves, moss, silt and debris removed from every run of gutter channel.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Downpipe Flush</strong>
                  <p class="feature-card__body">All downpipes flushed to confirm clear flow to drainage — not just the gutters.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">SkyVac Vacuum System</strong>
                  <p class="feature-card__body">Ground-based vacuum reaches up to 40 feet — no ladders on conservatories or difficult sections.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Minor Repairs On the Day</strong>
                  <p class="feature-card__body">Leaking joints resealed and loose brackets refixed on the same visit where needed.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Gutter & Bracket Inspection</strong>
                  <p class="feature-card__body">Joints, brackets and fixings checked for damage as we work — reported and quoted on the spot.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Photo Evidence</strong>
                  <p class="feature-card__body">Before and after photos of blocked sections so you can see the result — no guesswork.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to book? Free quotes across all Bristol postcodes.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Method" heading="Why We Use the SkyVac Vacuum System" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">DIY Ladder Clearing</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Falls from ladders are a leading cause of serious home injury
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Can't reach conservatory gutters safely without walking on glass
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Downpipe blockages often missed — debris pushed further down
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Damage, sagging and leaking joints easily overlooked
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Our SkyVac Vacuum System</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Ground-based operation — no unsafe ladder work
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Reaches up to 40 feet — conservatories and extensions included
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Downpipes flushed and confirmed clear to drainage
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Full inspection and minor repairs included as standard
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Gutters cleared safely and thoroughly — every Bristol postcode covered
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Quote</h4>
                  <p class="process-step__body">We assess run length, access and debris level to price the job accurately — no surprises.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Gutter Clear</h4>
                  <p class="process-step__body">All debris removed from gutters by hand or SkyVac vacuum lance depending on access and debris level.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Downpipe Flush</h4>
                  <p class="process-step__body">Water run through each downpipe to confirm free flow all the way to the drain.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Inspection & Report</h4>
                  <p class="process-step__body">Joints, brackets and fascia board condition checked. We report any issues and quote for repairs on the spot.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Minor Repairs</h4>
                  <p class="process-step__body">Leaking joints resealed and loose brackets refixed where needed — included at no extra charge.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Gutters overflowing? We can usually quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="areas-covered">
            <SectionHeader eyebrow="Bristol Coverage" heading="Bristol Areas We Serve" />
            <p class="areas-text">Clifton, Redland, Cotham, Montpelier, Bishopston, Westbury Park, Henleaze, Stoke Bishop, Fishponds, Stapleton, Downend, Emersons Green, Kingswood, Hanham, Brislington, Totterdown, Knowle, Bedminster, Southville, Ashton, Sea Mills, Shirehampton and all surrounding Bristol postcodes (BS1–BS16).</p>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Get Your Gutters Cleared</h3>
            <p class="sidebar-card__body">Free, no-obligation quotes across all Bristol postcodes. Call or use the contact form.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Bristol Services</span>
            <h3 class="sidebar-card__heading">Also in Bristol</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bristol">Driveway Cleaning Bristol</a></li>
              <li><a href="/patio-cleaning-bristol">Patio Cleaning Bristol</a></li>
              <li><a href="/roof-cleaning-bristol">Roof Cleaning Bristol</a></li>
              <li><a href="/render-cleaning-bristol">Render Cleaning Bristol</a></li>
              <li><a href="/bristol/">All Bristol Services</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Gutter Cleaning Results" body="Blocked gutters cause serious damage. See the before and after." align="center" />
      <div class="before-after-wrap">
        <img src="/images/before-after/gutter-before-1.webp" alt="Gutters packed with moss and debris before professional clearing" class="before-after-composite" />
        <p class="before-after-caption">Completely blocked gutter channel — overflowing onto fascias and down the wall every time it rains.</p>
      </div>
      <div class="photo-library">
        <div class="photo-library__header">
          <p class="photo-library__sub">More photos from recent gutter jobs</p>
          <span class="photo-library__count">4 photos</span>
        </div>
        <div class="photo-library__grid">
          <a href="/images/before-after/gutter-before-1.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: blocked gutters before clearing">
            <img src="/images/before-after/gutter-before-1.webp" alt="Blocked gutters packed with moss and debris before clearing" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-18.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: clean gutters after SkyVac clearing">
            <img src="/images/before-after/job-gallery-18.webp" alt="Clean empty gutters after professional SkyVac clearing" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/gutter-skyvac-action-1.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: SkyVac vacuum system in action">
            <img src="/images/before-after/gutter-skyvac-action-1.webp" alt="SkyVac ground-based vacuum system clearing blocked gutter" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-21.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: dense moss removed from gutter">
            <img src="/images/before-after/job-gallery-21.webp" alt="Dense moss and debris removed from gutter channel" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Gutter Cleaning Bristol FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ImageCTA
    heading="Bristol's Gutter Cleaning Specialists"
    body="Free, no-obligation quotes from a fully insured, five-star-rated jet washing service. Covering all Bristol postcodes. Call 07474 939 398."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/job-gallery-18.webp"
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
