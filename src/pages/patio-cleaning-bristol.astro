---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';

const title = 'Patio Cleaning Bristol';
const description = 'Professional patio cleaning in Bristol. Jet washing for sandstone, porcelain, slate and concrete patios. Algae, moss and black spot removal. Call 07474 939 398 for a free quote.';

const faqs = [
  {
    q: 'Do you clean patios across all Bristol postcodes?',
    a: 'Yes. We cover all Bristol postcodes from BS1 to BS16, including Clifton, Redland, Bishopston, Henleaze, Kingswood, Fishponds, Brislington, Bedminster, Southville, Knowle and surrounding areas.'
  },
  {
    q: 'Will pressure washing damage my Indian sandstone patio?',
    a: 'No. We use a wide-fan lance at controlled pressure on natural stone. This lifts dirt and algae without etching or flaking the surface. Delicate porcelain and slate are cleaned at even lower pressures to protect the finish.'
  },
  {
    q: 'Why does my Bristol patio grow so much algae?',
    a: "Bristol's wet climate and prevailing south-westerly rain makes it one of the worst cities in the UK for algae and moss growth on outdoor surfaces. North-facing and shaded patios are particularly badly affected. Our biocide post-treatment significantly slows regrowth after cleaning."
  },
  {
    q: 'How often should I have my patio cleaned?',
    a: 'Most Bristol patios benefit from a professional clean every 12–18 months. North-facing or shaded patios that collect algae and moss quickly may need annual cleaning to keep them safe and looking their best.'
  },
  {
    q: 'Can you remove black spot staining on my sandstone patio?',
    a: 'Yes. Black spots are caused by lichen embedded in the stone pores. We apply a specialist biocide pre-treatment that kills the lichen, then follow with jet washing to lift the staining. Stubborn spots may require a second treatment.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Patio Cleaning Bristol",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": { "@type": "City", "name": "Bristol" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" }
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[{ name: 'Services', item: 'https://rgextremepressure.co.uk/services' }, { name: 'Patio Cleaning Bristol', item: 'https://rgextremepressure.co.uk/patio-cleaning-bristol' }]}>
  <Hero
    image="/images/before-after/patio-after-1.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Bristol', href: '/bristol' }, { label: 'Patio Cleaning' }]}
    eyebrow="Professional Patio Cleaning Bristol"
    heading="Patio Cleaning Bristol"
    body="Bring your Bristol patio back to life with professional jet washing. Algae, moss and slippery growth removed from sandstone, porcelain, slate and concrete — safely, without damaging delicate surfaces. 111 five-star reviews."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
  minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="Patio Cleaning Across Bristol"
            heading="Professional Patio Jet Washing in Bristol"
            body="Bristol's damp climate means patios grow algae and moss at a relentless pace. A slippery, stained patio isn't just an eyesore — it's a hazard. Our professional patio cleaning removes every trace of growth and staining, with pressure carefully matched to your surface type to avoid any damage."
          />

          <div class="service-features">
            <h3 class="service-features__title">What Our Bristol Patio Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Indian Sandstone Patio Cleaning</strong>
                  <p class="feature-card__body">Gentle pressure matched to the stone — lifts ingrained dirt without flaking or etching the surface.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Porcelain & Slate Tile Washing</strong>
                  <p class="feature-card__body">Low-pressure clean removes algae and staining from delicate surfaces without surface damage.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Concrete Slab & Flagstone Clean</strong>
                  <p class="feature-card__body">Heavier pressure to strip weather staining and organic growth from robust surfaces.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Algae & Moss Treatment</strong>
                  <p class="feature-card__body">Biocide application kills spores and slows regrowth significantly — safer surface underfoot for longer.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Black Spot Lichen Removal</strong>
                  <p class="feature-card__body">Specialist treatment for stubborn lichen staining on sandstone — often mistaken for permanent marks.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Pointing & Joint Clean</strong>
                  <p class="feature-card__body">Debris flushed from between paving joints and slabs, leaving a clean finish throughout.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to book? Free quotes across all Bristol postcodes.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="The Right Equipment" heading="Why We Use a Flat Surface Cleaner" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">Standard Pressure Wand</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Leaves visible stripes and streaks across the surface
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Uneven cleaning — concentrated jet misses between passes
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Operator-dependent — results vary with speed and angle
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    High splash — overspray onto furniture, walls and planting
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Flat Surface Cleaner</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Two or three nozzles on a spinning bar inside a circular housing — uniform coverage every pass
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    No stripes or streaks — the enclosed head distributes pressure evenly across the surface
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Enclosed housing contains splash — protects your furniture, walls and borders
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Covers large areas quickly and consistently — the professional standard
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  A consistently clean finish — no stripes, no missed patches, no mess on your property
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Assessment</h4>
                  <p class="process-step__body">We identify your patio type, surface condition and any problem areas before starting.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Pre-Treatment</h4>
                  <p class="process-step__body">Biocide or specialist cleaner applied to stubborn growth, stains and lichen and left to dwell.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Jet Washing</h4>
                  <p class="process-step__body">Pressure matched to your surface type — higher for concrete and flagstone, lower for sandstone and porcelain.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Rinse & Tidy</h4>
                  <p class="process-step__body">All debris washed away, area left clean and ready to use.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Optional Biocide Spray</h4>
                  <p class="process-step__body">Anti-growth treatment applied across the surface to significantly slow algae and moss regrowth.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Bristol patio slippery or green? We can usually quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="areas-covered">
            <SectionHeader eyebrow="Bristol Coverage" heading="Bristol Areas We Serve" />
            <p class="areas-text">Clifton, Redland, Cotham, Montpelier, Bishopston, Westbury Park, Henleaze, Stoke Bishop, Fishponds, Stapleton, Downend, Emersons Green, Kingswood, Hanham, Brislington, Totterdown, Knowle, Bedminster, Southville, Ashton, Sea Mills, Shirehampton, Portishead and all surrounding Bristol postcodes (BS1–BS16).</p>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Ready to Revive Your Patio?</h3>
            <p class="sidebar-card__body">Call us or request a free, no-obligation quote. We cover all Bristol postcodes and surrounding areas.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Bristol Services</span>
            <h3 class="sidebar-card__heading">Also in Bristol</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bristol">Driveway Cleaning Bristol</a></li>
              <li><a href="/gutter-cleaning-bristol">Gutter Cleaning Bristol</a></li>
              <li><a href="/roof-cleaning-bristol">Roof Cleaning Bristol</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning</a></li>
              <li><a href="/bristol/">All Bristol Services</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>


  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body="See the difference professional patio cleaning can achieve." align="center" />
      <div class="before-after-wrap">
        <BeforeAfter beforeSrc="/images/before-after/patio-before-1.webp" afterSrc="/images/before-after/patio-after-1.webp" beforeAlt="Sandstone patio covered in algae before cleaning" afterAlt="Sandstone patio restored after professional jet washing" caption="Sandstone patio in Bristol — algae and black spot removed" />
      </div>
      <div class="before-after-wrap" style="margin-top:var(--space-xl)">
        <BeforeAfter beforeSrc="/images/before-after/job-patio-before-2.webp" afterSrc="/images/before-after/job-patio-after-2.webp" beforeAlt="Block paving patio slabs covered in algae" afterAlt="Block paving patio cleaned and restored" caption="Block paving patio — full moss and algae removal" />
      </div>
      <div class="before-after-wrap" style="margin-top:var(--space-xl)">
        <img src="/images/before-after/job-patio-steps-1.webp" alt="Patio steps cleaned — algae and moss removed from stone steps" loading="lazy" class="before-after-composite" />
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Patio Cleaning Bristol FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ── Bristol District Links ── */}
  <section class="district-links-section">
    <div class="container">
      <h2 class="district-links__heading">Patio Cleaning Across Bristol</h2>
      <p class="district-links__intro">We cover every Bristol district. Click your area for a dedicated local page.</p>
      <ul class="district-links__grid">
        <li><a href="/patio-cleaning/clifton-bristol">Patio Cleaning Clifton</a></li>
        <li><a href="/patio-cleaning/redland-bristol">Patio Cleaning Redland</a></li>
        <li><a href="/patio-cleaning/bishopston-bristol">Patio Cleaning Bishopston</a></li>
        <li><a href="/patio-cleaning/henleaze-bristol">Patio Cleaning Henleaze</a></li>
        <li><a href="/patio-cleaning/kingswood-bristol">Patio Cleaning Kingswood</a></li>
        <li><a href="/patio-cleaning/fishponds-bristol">Patio Cleaning Fishponds</a></li>
        <li><a href="/patio-cleaning/brislington-bristol">Patio Cleaning Brislington</a></li>
        <li><a href="/patio-cleaning/bedminster-bristol">Patio Cleaning Bedminster</a></li>
        <li><a href="/patio-cleaning/downend-bristol">Patio Cleaning Downend</a></li>
        <li><a href="/patio-cleaning/westbury-on-trym-bristol">Patio Cleaning Westbury-on-Trym</a></li>
      </ul>
    </div>
  </section>

  <ImageCTA
    heading="Bristol's Patio Cleaning Specialists"
    body="Get a free, no-obligation quote from a fully insured, five-star-rated jet washing service. Covering all Bristol postcodes. Call 07474 939 398."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/patio-after-1.webp"
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
  .service-body__grid { display: grid; grid-template-columns: 7fr 4fr; gap: var(--space-3xl, 5rem); align-items: start; }
  .service-features { margin-top: var(--space-2xl); }
  .service-features__title { font-family: var(--font-display); font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.1; text-transform: none; color: var(--chalk); margin: 0 0 var(--space-l); }
  .features-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-m); }
  .feature-card { display: flex; gap: var(--space-m); align-items: flex-start; background: var(--stone); border-radius: 8px; padding: var(--space-l); border-top: 3px solid var(--accent); }
  .feature-card__icon { flex-shrink: 0; width: 2.5rem; height: 2.5rem; background: var(--accent); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; }
  .feature-card__title { display: block; font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; text-transform: none; letter-spacing: 0; color: var(--chalk); margin-bottom: 0.4rem; }
  .feature-card__body { font-size: 0.88rem; line-height: 1.65; color: var(--concrete); margin: 0; }
  @media (max-width: 640px) { .features-grid { grid-template-columns: 1fr; } }
  .inline-cta { margin-top: var(--space-2xl); border-radius: 10px; background: linear-gradient(135deg, var(--navy) 0%, var(--accent-dim) 100%); padding: var(--space-xl) var(--space-2xl); }
  .inline-cta--after-process { margin-top: var(--space-2xl); }
  .inline-cta__inner { display: flex; align-items: center; justify-content: space-between; gap: var(--space-l); flex-wrap: wrap; }
  .inline-cta__text { font-family: var(--font-display); font-size: clamp(1.1rem, 1.8vw, 1.4rem); font-weight: 700; color: #fff; margin: 0; line-height: 1.3; }
