---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(p => !p.data.draft).map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

const ogImage = post.data.image || '/images/hero-home.webp';
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  preloadImage={post.data.image}
>

  {/* Article schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "author": {
      "@type": "Person",
      "name": post.data.author,
      "jobTitle": "Owner",
      "worksFor": {
        "@type": "Organization",
        "name": "RG Extreme Pressure",
        "url": "https://www.rgextremepressure.co.uk"
      }
    },
    "publisher": {
      "@type": "Organization",
      "name": "RG Extreme Pressure",
      "url": "https://www.rgextremepressure.co.uk"
    },
    "image": ogImage ? `https://www.rgextremepressure.co.uk${ogImage}` : undefined,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://www.rgextremepressure.co.uk/blog/${post.id}`
    }
  })} />

  <Hero
    image={post.data.image || '/images/hero-home.webp'}
    overlay="blue"
    minHeight="compact"
    breadcrumb={[{ label: 'Blog', href: '/blog' }, { label: post.data.category }]}
    eyebrow={post.data.category}
    heading={post.data.title}
    body={post.data.description}
    meta={[
      { label: 'By', value: `${post.data.author} · Owner` },
      { label: 'Published', value: formatDate(post.data.pubDate) },
    ]}
  />

  {/* ── Article body ── */}
  <section class="post-body-section">
    <div class="container">
      <div class="post-layout">
        <article class="post-content prose">
          <Content />
        </article>

        {/* Sidebar */}
        <aside class="post-sidebar">
          <div class="post-sidebar__card">
            <span class="post-sidebar__rule"></span>
            <span class="t-label post-sidebar__label">Get a Quote</span>
            <p class="post-sidebar__body">Need professional jet washing in Bath or Bristol? Free quotes, no obligation.</p>
            <a href="/contact" class="post-sidebar__cta">Get a Free Quote →</a>
          </div>

          {post.data.serviceUrl && (
            <div class="post-sidebar__card post-sidebar__card--service">
              <span class="post-sidebar__rule"></span>
              <span class="t-label post-sidebar__label">Related Service</span>
              <p class="post-sidebar__body">{post.data.service}</p>
              <a href={post.data.serviceUrl} class="post-sidebar__cta">View service →</a>
            </div>
          )}

          <div class="post-sidebar__card">
            <span class="post-sidebar__rule"></span>
            <span class="t-label post-sidebar__label">111 Five-Star Reviews</span>
            <p class="post-sidebar__body">Bath's highest-rated jet washing service on Google. Fully insured. Eco-friendly.</p>
            <a href="https://www.google.com/maps?q=RG+Extreme+Pressure+Bath" target="_blank" rel="noopener noreferrer" class="post-sidebar__cta">See Reviews →</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ── CTA strip ── */}
  <section class="post-cta">
    <div class="container">
      <div class="post-cta__inner">
        <div>
          <h2 class="post-cta__heading">Ready for a free quote?</h2>
          <p class="post-cta__body">Get a free, no-obligation quote from Robert. Fully insured, eco-friendly, 111 five-star reviews.</p>
        </div>
        <a href="/contact" class="post-cta__btn">Get a Free Quote →</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Body ── */
  .post-body-section {
    padding: var(--section-pad) 0;
    background: #fff;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ── Prose ── */
  .prose { font-size: 1.05rem; line-height: 1.8; color: var(--chalk); }
  .prose h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 2.5vw, 1.9rem); text-transform: uppercase; letter-spacing: 0.02em; color: var(--chalk); margin: 2.5rem 0 1rem; }
  .prose h3 { font-family: var(--font-display); font-size: clamp(1.1rem, 1.8vw, 1.4rem); text-transform: uppercase; letter-spacing: 0.02em; color: var(--chalk); margin: 2rem 0 0.75rem; }
  .prose p { margin: 0 0 1.3rem; }
  .prose ul, .prose ol { margin: 0 0 1.3rem 1.4rem; }
  .prose li { margin-bottom: 0.4rem; }
  .prose strong { font-weight: 600; color: var(--chalk); }
  .prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--accent-dim); }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
  .prose th { background: var(--chalk); color: #fff; padding: 0.6rem 0.9rem; text-align: left; font-family: var(--font-display); letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.78rem; }
  .prose td { padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--stone); color: var(--concrete); }
  .prose tr:last-child td { border-bottom: none; }

  /* ── Sidebar ── */
  .post-sidebar { display: flex; flex-direction: column; gap: var(--space-l); position: sticky; top: 5rem; }

  .post-sidebar__card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: var(--space-l);
    background: var(--surface);
    border-radius: var(--radius);
  }

  .post-sidebar__card--service { background: var(--accent); }
  .post-sidebar__card--service .post-sidebar__label { color: #fff; }
  .post-sidebar__card--service .post-sidebar__body { color: rgba(255,255,255,0.65); }

  .post-sidebar__rule { display: block; width: 28px; height: 2px; background: var(--accent); border-radius: 1px; }
  .post-sidebar__label { color: var(--accent); }
  .post-sidebar__body { font-size: 0.88rem; line-height: 1.6; color: var(--concrete); margin: 0; }
  .post-sidebar__cta { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); text-decoration: none; transition: letter-spacing 0.2s; }
  .post-sidebar__cta:hover { letter-spacing: 0.16em; }

  /* ── CTA strip ── */
  .post-cta { background: var(--accent); padding: var(--space-2xl) 0; }

  .post-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl); flex-wrap: wrap;
  }

  .post-cta__heading {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .post-cta__body { font-size: 0.95rem; color: rgba(255,255,255,0.8); margin: 0; }

  .post-cta__btn {
    flex-shrink: 0;
    display: inline-block;
    padding: 1rem 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    background: #fff;
    text-decoration: none;
    border-radius: var(--radius);
    transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .post-cta__btn:hover { background: var(--surface); transform: translateY(-2px); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { position: static; }
  }
</style>