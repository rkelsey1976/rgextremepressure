---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';
import BeforeAfter from '../components/BeforeAfter.astro';

const title = 'Roof Cleaning Bristol';
const description = 'Professional roof cleaning and moss removal in Bristol. Spinning brush system cleans tiles safely from ground level — no walking on your roof. 111 five-star reviews. Call 07474 939 398.';

const faqs = [
  {
    q: 'Do you clean roofs across all Bristol postcodes?',
    a: 'Yes. We cover all Bristol postcodes from BS1 to BS16, including Clifton, Redland, Bishopston, Henleaze, Kingswood, Fishponds, Brislington, Bedminster, Downend, Westbury-on-Trym and surrounding areas. Call 07474 939 398 to confirm coverage.',
  },
  {
    q: 'How do you clean Bristol roofs without damaging the tiles?',
    a: 'We use a spinning brush system on telescopic lances operated from ground level. The rotating brush heads remove moss and lichen evenly without the concentrated pressure of a jet wash pointed directly at tiles. Victorian clay, concrete interlocking and modern roof tiles are all cleaned safely with this method.',
  },
  {
    q: 'Why do Bristol roofs get so much moss?',
    a: "Bristol's wet south-westerly climate and relatively mild winters mean moss spores germinate rapidly on roof tiles. North-facing pitches and tiles shaded by mature trees are worst affected. Regular cleaning every 3–5 years prevents the moss from lifting tiles and causing water ingress.",
  },
  {
    q: 'How much does roof cleaning cost in Bristol?',
    a: 'Roof cleaning in Bristol starts from £299 for a standard semi-detached property. The exact price depends on roof size, pitch and extent of moss growth. We provide free, no-obligation quotes — call 07474 939 398.',
  },
  {
    q: 'Does the biocide treatment stop moss coming back?',
    a: 'Biocide significantly slows regrowth by killing remaining spores after the brush clean. Most roofs stay clear for 3–5 years after treatment. It does not provide a permanent barrier — moss will return eventually, especially on north-facing pitches in Bristol\'s wet climate.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Roof Cleaning Bristol",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" },
  },
  "areaServed": { "@type": "City", "name": "Bristol" },
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[{ name: 'Services', item: 'https://rgextremepressure.co.uk/services' }, { name: 'Roof Cleaning Bristol', item: 'https://rgextremepressure.co.uk/roof-cleaning-bristol' }]}>
  <Hero
    image="/images/before-after/roof-after.jpg"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Bristol', href: '/bristol' }, { label: 'Roof Cleaning' }]}
    eyebrow="Professional Roof Cleaning Bristol"
    heading="Roof Cleaning Bristol"
    body="Safe, effective roof moss removal across Bristol. Our spinning brush system cleans tiles from ground level — no walking on your roof, no concentrated pressure on ageing tiles. Biocide treatment included. 111 five-star reviews. Free quotes."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
  minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="Roof Cleaning Across Bristol"
            heading="Professional Roof Moss Removal in Bristol"
            body="Bristol's damp climate and mild winters make it one of the worst cities in the UK for roof moss growth. Left untreated, moss lifts tile edges, blocks gutters and causes water ingress — leading to costly repairs. Our spinning brush system removes moss safely across the whole roof, with biocide treatment applied after to slow regrowth for years."
          />

          <div class="service-intro-image">
            <img src="/images/before-after/roof-after.jpg" alt="Bristol roof moss removal in progress — spinning brush system used from ground level" loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">What Our Bristol Roof Cleaning Includes</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Spinning Brush Moss Removal</strong>
                  <p class="feature-card__body">Rotating brush heads on telescopic lances clean the full roof safely from ground level — no ladders, no walking on tiles.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">No Walking on Your Roof</strong>
                  <p class="feature-card__body">All work carried out from ground level — no foot traffic on ageing tiles, no risk of cracking or slipping.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Safe for All Tile Types</strong>
                  <p class="feature-card__body">Victorian clay, concrete interlocking, slate and modern roof tiles all cleaned without concentrated pressure.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Biocide Treatment</strong>
                  <p class="feature-card__body">Specialist solution applied after brushing kills remaining spores and slows regrowth for 3–5 years.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Gutters Cleared</strong>
                  <p class="feature-card__body">Moss debris cleared from gutters and downpipes as part of every roof clean — no blocked gutters left behind.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Ridge & Hip Tile Inspection</strong>
                  <p class="feature-card__body">Visible ridge and hip tiles checked during the clean — cracked pointing or loose tiles flagged so you can act before they leak.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Ready to book? Free quotes across all Bristol postcodes.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Site Visit</h4>
                  <p class="process-step__body">We assess roof type, tile condition and extent of moss growth — free, no-obligation.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Heavy Moss Removal</h4>
                  <p class="process-step__body">Thick moss clumps manually removed from ridge lines and tile edges before brush cleaning begins.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Spinning Brush Clean</h4>
                  <p class="process-step__body">Telescopic spinning brush system removes remaining moss across the whole roof safely from ground level.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Gutter Clear</h4>
                  <p class="process-step__body">Debris cleared from gutters and downpipes after the roof clean.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Biocide Application</h4>
                  <p class="process-step__body">Anti-moss treatment applied across the full roof to kill remaining spores and slow regrowth for 3–5 years.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Bristol roof going green? We can usually quote within 24 hours.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Get a Free Quote →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="areas-covered">
            <SectionHeader eyebrow="Bristol Coverage" heading="Bristol Areas We Serve" />
            <p class="areas-text">Clifton, Redland, Cotham, Montpelier, Bishopston, Westbury Park, Henleaze, Stoke Bishop, Fishponds, Stapleton, Downend, Emersons Green, Kingswood, Hanham, Brislington, Totterdown, Knowle, Bedminster, Southville, Ashton, Sea Mills, Shirehampton and all surrounding Bristol postcodes (BS1–BS16).</p>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Get Your Bristol Roof Cleaned</h3>
            <p class="sidebar-card__body">Free, no-obligation quotes across all Bristol postcodes. Call or use the contact form.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Bristol Services</span>
            <h3 class="sidebar-card__heading">Also in Bristol</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bristol">Driveway Cleaning Bristol</a></li>
              <li><a href="/patio-cleaning-bristol">Patio Cleaning Bristol</a></li>
              <li><a href="/gutter-cleaning-bristol">Gutter Cleaning Bristol</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning</a></li>
              <li><a href="/bristol/">All Bristol Services</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>


  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Roof Cleaning Results" body="Real results from our roof cleaning work across Bristol and Somerset." align="center" />
      <div class="before-after-wrap">
        <BeforeAfter
          beforeSrc="/images/before-after/roof-before.jpg"
          afterSrc="/images/before-after/roof-after.jpg"
          beforeAlt="Roof tiles covered in moss and algae before cleaning"
          afterAlt="Roof tiles fully restored after professional moss removal"
          caption="Roof moss removal in Bristol — tiles fully restored using our spinning brush system"
        />
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Roof Cleaning Bristol FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ── Bristol District Links ── */}
  <section class="district-links-section">
    <div class="container">
      <h2 class="district-links__heading">Roof Cleaning Across Bristol</h2>
      <p class="district-links__intro">We cover every Bristol district. Click your area for a dedicated local page with specific information and pricing.</p>
      <ul class="district-links__grid">
        <li><a href="/roof-cleaning/clifton-bristol">Roof Cleaning Clifton</a></li>
        <li><a href="/roof-cleaning/redland-bristol">Roof Cleaning Redland</a></li>
        <li><a href="/roof-cleaning/bishopston-bristol">Roof Cleaning Bishopston</a></li>
        <li><a href="/roof-cleaning/henleaze-bristol">Roof Cleaning Henleaze</a></li>
        <li><a href="/roof-cleaning/kingswood-bristol">Roof Cleaning Kingswood</a></li>
        <li><a href="/roof-cleaning/fishponds-bristol">Roof Cleaning Fishponds</a></li>
        <li><a href="/roof-cleaning/brislington-bristol">Roof Cleaning Brislington</a></li>
        <li><a href="/roof-cleaning/bedminster-bristol">Roof Cleaning Bedminster</a></li>
        <li><a href="/roof-cleaning/downend-bristol">Roof Cleaning Downend</a></li>
        <li><a href="/roof-cleaning/westbury-on-trym-bristol">Roof Cleaning Westbury-on-Trym</a></li>
      </ul>
    </div>
  </section>

  <ImageCTA
    heading="Bristol's Roof Cleaning Specialists"
    body="Free, no-obligation quotes from a fully insured, five-star-rated jet washing service. Covering all Bristol postcodes. Call 07474 939 398."
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after.jpg"
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
  .service-body__grid { display: grid; grid-template-columns: 7fr 4fr; gap: var(--space-3xl, 5rem); align-items: start; }
  .service-intro-image { border-radius: 10px; overflow: hidden; aspect-ratio: 16/7; margin-bottom: var(--space-2xl); }
  .service-intro-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .service-features { margin-top: var(--space-2xl); }
  .service-features__title { font-family: var(--font-display); font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.1; text-transform: none; color: var(--chalk); margin: 0 0 var(--space-l); }
  .features-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-m); }
  .feature-card { display: flex; gap: var(--space-m); align-items: flex-start; background: var(--stone); border-radius: 8px; padding: var(--space-l); border-top: 3px solid var(--accent); }
  .feature-card__icon { flex-shrink: 0; width: 2.5rem; height: 2.5rem; background: var(--accent); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; }
  .feature-card__title { display: block; font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; text-transform: none; letter-spacing: 0; color: var(--chalk); margin-bottom: 0.4rem; }
  .feature-card__body { font-size: 0.88rem; line-height: 1.65; color: var(--concrete); margin: 0; }
  @media (max-width: 640px) { .features-grid { grid-template-columns: 1fr; } }
  .inline-cta { margin-top: var(--space-2xl); border-radius: 10px; background: linear-gradient(135deg, var(--navy) 0%, var(--accent-dim) 100%); padding: var(--space-xl) var(--space-2xl); }
  .inline-cta--after-process { margin-top: var(--space-2xl); }
  .inline-cta__inner { display: flex; align-items: center; justify-content: space-between; gap: var(--space-l); flex-wrap: wrap; }
  .inline-cta__text { font-family: var(--font-display); font-size: clamp(1.1rem, 1.8vw, 1.4rem); font-weight: 700; color: #fff; margin: 0; line-height: 1.3; }
  .inline-cta__actions { display: flex; align-items: center; gap: var(--space-m); flex-wrap: wrap; flex-shrink: 0; }
  .inline-cta__call { display: flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.85); font-weight: 600; font-size: 1rem; text-decoration: none; white-space: nowrap; transition: color 0.2s; }
  .inline-cta__call:hover { color: #fff; }
  @media (max-width: 640px) { .inline-cta { padding: var(--space-l); } .inline-cta__inner { flex-direction: column; align-items: flex-start; } }
  .service-process { margin-top: var(--space-3xl); }
  .areas-covered { margin-top: var(--space-3xl); }
  .areas-text { font-size: 0.95rem; line-height: 1.8; color: var(--concrete); }
  .process-steps { list-style: none; padding: 0; margin: var(--space-l) 0 0; display: flex; flex-direction: column; gap: 0; }
  .process-step { display: flex; gap: var(--space-l); align-items: flex-start; position: relative; padding-bottom: var(--space-l); }
  .process-step:not(:last-child)::after { content: ''; position: absolute; left: 1.5rem; top: 3rem; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--accent), rgba(0,85,165,0.1)); }
  .process-step__badge { flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 50%; background: var(--accent); color: #fff; font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }
  .process-step__content { background: var(--stone); border-radius: 8px; padding: var(--space-m) var(--space-l); flex: 1; border-left: 3px solid var(--accent); }
  .process-step__title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; text-transform: none; letter-spacing: 0; color: var(--chalk); margin: 0 0 0.4rem; }
  .process-step__body { font-size: 0.92rem; line-height: 1.7; color: var(--concrete); margin: 0; }
  .service-body__sidebar { display: flex; flex-direction: column; gap: var(--space-xl); align-self: start; position: sticky; top: 6rem; }
  .sidebar-card { background: var(--stone); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-s); }
  .sidebar-card__heading { font-family: var(--font-display); font-size: clamp(1.1rem, 1.5vw, 1.4rem); line-height: 1.1; text-transform: none; color: var(--chalk); margin: 0; }
  .sidebar-card__body { font-size: 0.92rem; line-height: 1.7; color: var(--concrete); margin: 0; }
  .sidebar-card .btn { margin-top: var(--space-xs); align-self: flex-start; }
  .sidebar-card__phone { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 0.04em; color: var(--accent); text-decoration: none; margin-top: var(--space-xs); }
  .sidebar-card__phone svg { flex-shrink: 0; }
  .sidebar-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-links a { font-size: 0.9rem; color: var(--concrete); text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 0.3rem; }
  .sidebar-links a::before { content: '\2192'; color: var(--accent); font-size: 0.8rem; }
  .sidebar-links a:hover { color: var(--accent); }
  .faq-section { padding: var(--section-pad) 0; }
  .faq-list { max-width: 72ch; display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid var(--stone); }
  .faq-item__q { font-family: var(--font-body); font-size: 1rem; font-weight: 500; line-height: 1.5; color: var(--chalk); padding: var(--space-m) 0; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; }
  .faq-item__q::-webkit-details-marker { display: none; }
