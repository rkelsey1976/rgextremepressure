---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ImageCTA from '../components/ImageCTA.astro';
import TrustMetrics from '../components/TrustMetrics.astro';

const title = 'Commercial Jet Washing Bath';
const description = 'Professional commercial jet washing in Bath. Car parks, forecourts, pub terraces, industrial units and retail premises cleaned to a high standard. Fully insured. Call 07474 939 398 for a free site survey.';

const faqs = [
  {
    q: 'Do you work outside of normal business hours?',
    a: 'Yes. We regularly schedule commercial jobs for early mornings, evenings and weekends to minimise disruption to your business and customers. Let us know your trading hours when you enquire and we will work around them.'
  },
  {
    q: 'Can you clean large car parks and forecourts?',
    a: 'Absolutely. We handle everything from small courtyard car parks to large retail forecourts with multiple bays. Larger sites are quoted on a site survey basis so we can assess access, drainage and the volume of traffic marks and oil staining.'
  },
  {
    q: 'Are you insured for commercial premises?',
    a: 'Yes, we carry full public liability insurance suitable for commercial work. We can provide documentation for your records if required — just ask when you book.'
  },
  {
    q: 'How often should a commercial premises be cleaned?',
    a: 'It depends on footfall and usage. High-traffic areas such as pub terraces, restaurant outdoor seating and petrol forecourts benefit from quarterly or bi-annual cleaning. Car parks and industrial loading bays typically need attention annually or after major incidents.'
  },
  {
    q: 'Can you treat oil and fuel stains on a forecourt?',
    a: 'Yes. We use commercial-grade degreaser pre-treatment for oil, fuel and tyre marks before jet washing. Most staining is significantly reduced; some older deep-set stains may require multiple treatments.'
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Jet Washing Bath",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" }
  },
  "areaServed": [{ "@type": "City", "name": "Bath" }, { "@type": "City", "name": "Bristol" }],
};
---

<Base {title} {description} serviceSchema={serviceSchema} faqSchema={faqSchema} breadcrumbs={[
  { name: 'Services', item: 'https://rgextremepressure.co.uk/services' },
  { name: 'Commercial Jet Washing Bath', item: 'https://rgextremepressure.co.uk/commercial-jet-washing-bath' }
]}>
  <Hero
    image="/images/before-after/job-gallery-19.webp"
    overlay="blue"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Commercial Jet Washing' }]}
    eyebrow="Professional Commercial Cleaning"
    heading="Commercial Jet Washing Bath"
    body="A grimy forecourt, stained pub terrace or oil-marked car park sends the wrong message to customers and tenants. We deliver reliable, fully insured commercial jet washing across Bath and the surrounding area — with scheduling that works around your business hours."
    cta={{ label: 'Get a Free Site Survey', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Site Surveys' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">
          <SectionHeader
            eyebrow="What We Do"
            heading="Commercial Pressure Washing for Bath Businesses"
            body="From single-site pubs to multi-unit retail parks, we provide professional jet washing that keeps commercial premises looking their best. All work is fully insured, carried out with commercial-grade equipment, and scheduled to minimise any disruption to your operation."
          />

          <div class="service-intro-image">
            <img src="/images/before-after/job-gallery-19.webp" alt="Commercial jet washing on a large Bath property — forecourt and entrance area cleaned to a high standard" loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">Commercial Premises We Clean</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Car Parks & Forecourts</strong>
                  <p class="feature-card__body">Heavy-duty cleaning for oil stains, tyre marks and general grime. Degreaser pre-treatment for stubborn fuel spills.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Pub Terraces & Restaurant Areas</strong>
                  <p class="feature-card__body">Food staining, chewing gum removal and algae cleared from outdoor dining areas — ready for customers, not embarrassing ones.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Industrial Units & Warehouses</strong>
                  <p class="feature-card__body">External walls, loading bays and concrete aprons cleaned. Heavy plant and machinery residue treated with commercial-grade degreasers.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Retail Premises & Shopping Areas</strong>
                  <p class="feature-card__body">Entrance paving, pedestrian walkways and service yards cleaned to maintain kerb appeal and footfall.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Petrol Station Forecourts</strong>
                  <p class="feature-card__body">Specialist fuel stain treatment and deep-clean of pump islands and canopy surrounds — includes hot water high-pressure wash.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Managed Properties & Estates</strong>
                  <p class="feature-card__body">Block driveways, communal paths and service roads for housing associations and property management companies.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Commercial enquiry? We offer free site surveys across Bath and Bristol.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Book a Site Survey →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>

          <div class="method-comparison">
            <SectionHeader eyebrow="Why It Matters" heading="Professional Equipment vs Hire-It-Yourself" />
            <div class="method-grid">

              <div class="method-card method-card--bad">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--bad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <h4 class="method-card__title">Consumer Pressure Washer Hire</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Underpowered for oil stains, deep grime and gum
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    No commercial degreaser capability
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Hire plus staff time often more expensive than outsourcing
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    No public liability cover if a customer slips after
                  </li>
                </ul>
              </div>

              <div class="method-card method-card--good">
                <div class="method-card__header">
                  <div class="method-card__badge method-card__badge--good">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </div>
                  <h4 class="method-card__title">Our Commercial Equipment</h4>
                </div>
                <ul class="method-card__list">
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    High-flow hot and cold water capability
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Commercial degreaser pre-treatment for fuel and oil
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Surface cleaner attachment for even, streak-free coverage
                  </li>
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    Fully insured — public liability documentation available
                  </li>
                </ul>
                <div class="method-card__result">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Premises cleaned to a high standard — on time, insured, no disruption
                </div>
              </div>

            </div>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How a Commercial Job Works" />
            <ol class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Free Site Survey</h4>
                  <p class="process-step__body">We visit your premises, assess surface types, access points and drainage, and confirm a fixed price before any work starts.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Scheduling</h4>
                  <p class="process-step__body">We agree a date and time that works around your trading hours — early mornings, evenings and weekends available.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Pre-Treatment</h4>
                  <p class="process-step__body">Commercial degreaser applied to problem areas — oil patches, fuel stains, food residue — and left to dwell.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Pressure Wash</h4>
                  <p class="process-step__body">High-flow surface cleaner used for large areas; lance work for edges, gutters and detailed sections.</p>
                </div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div class="process-step__content">
                  <h4 class="process-step__title">Sign-Off</h4>
                  <p class="process-step__body">We walk the site with you before leaving and provide a summary report if needed for your management records.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="inline-cta inline-cta--after-process">
            <div class="inline-cta__inner">
              <p class="inline-cta__text">Need a regular commercial cleaning contract? We offer ongoing scheduled visits.</p>
              <div class="inline-cta__actions">
                <a href="/contact" class="btn btn--primary">Book a Site Survey →</a>
                <a href="tel:07474939398" class="inline-cta__call">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                  07474 939 398
                </a>
              </div>
            </div>
          </div>
        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Site Survey</span>
            <h3 class="sidebar-card__heading">Commercial Enquiries Welcome</h3>
            <p class="sidebar-card__body">Fixed-price quotes after a free site survey. Public liability documentation on request.</p>
            <a href="/contact" class="btn btn--primary">Book a Site Survey <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Other Services</span>
            <h3 class="sidebar-card__heading">Explore Our Services</h3>
            <ul class="sidebar-links">
              <li><a href="/driveway-cleaning-bath">Driveway Cleaning Bath</a></li>
              <li><a href="/patio-cleaning-bath">Patio Cleaning Bath</a></li>
              <li><a href="/gutter-cleaning-bath">Gutter Cleaning Bath</a></li>
              <li><a href="/render-cleaning-bath">Render Cleaning Bath</a></li>
              <li><a href="/roof-cleaning-bath">Roof Cleaning Bath</a></li>
              <li><a href="/bristol/">Jet Washing Bristol</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="Our Work" heading="Commercial Jet Washing Results" body="High-traffic commercial surfaces need more than a consumer pressure washer. Our commercial equipment and degreasers handle what others can't." align="center" />
      <div class="before-after-grid">
        <div class="before-after-item">
          <img src="/images/before-after/job-gallery-20.webp" alt="Commercial forecourt before jet washing — heavy grime and oil staining" loading="lazy" />
          <p class="before-after-label">Before</p>
        </div>
        <div class="before-after-item">
          <img src="/images/before-after/job-gallery-19.webp" alt="Commercial forecourt after jet washing — clean stone surface with no oil staining" loading="lazy" />
          <p class="before-after-label">After</p>
        </div>
      </div>
      <div class="photo-library">
        <div class="photo-library__header">
          <p class="photo-library__sub">More photos from recent commercial jobs</p>
          <span class="photo-library__count">4 photos</span>
        </div>
        <div class="photo-library__grid">
          <a href="/images/before-after/job-gallery-19.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: commercial forecourt after clean">
            <img src="/images/before-after/job-gallery-19.webp" alt="Commercial forecourt fully cleaned — no oil staining" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-20.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: commercial surface before clean">
            <img src="/images/before-after/job-gallery-20.webp" alt="Commercial surface before jet washing" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-21.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: exterior commercial wall clean">
            <img src="/images/before-after/job-gallery-21.webp" alt="Exterior commercial property wall cleaned" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
          <a href="/images/before-after/job-gallery-18.webp" class="photo-library__item" target="_blank" rel="noopener" aria-label="View photo: large property external clean">
            <img src="/images/before-after/job-gallery-18.webp" alt="Large external property jet washed — driveway and front elevation" loading="lazy" />
            <span class="photo-library__overlay"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading="Commercial Jet Washing FAQ" />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="district-links-section">
    <div class="container">
      <h2 class="district-links__heading">Commercial Jet Washing Across Bath</h2>
      <p class="district-links__intro">We cover all commercial premises across Bath and the surrounding area. Click your district for a local landing page.</p>
      <ul class="district-links__grid">
        <li><a href="/commercial-jet-washing/bath-city-centre">Commercial Cleaning Bath City Centre</a></li>
        <li><a href="/commercial-jet-washing/keynsham">Commercial Cleaning Keynsham</a></li>
        <li><a href="/commercial-jet-washing/midsomer-norton">Commercial Cleaning Midsomer Norton</a></li>
        <li><a href="/commercial-jet-washing/radstock">Commercial Cleaning Radstock</a></li>
        <li><a href="/commercial-jet-washing/peasedown-st-john">Commercial Cleaning Peasedown St John</a></li>
        <li><a href="/commercial-jet-washing/saltford">Commercial Cleaning Saltford</a></li>
      </ul>
    </div>
  </section>

