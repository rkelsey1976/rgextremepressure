---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SplitFeature from '../../components/SplitFeature.astro';
import LocationHub from '../../components/LocationHub.astro';
import TrustMetrics from '../../components/TrustMetrics.astro';
import ImageCTA from '../../components/ImageCTA.astro';

const cityAreas = [
  { name: 'Central Bath & Districts', descriptor: 'Georgian townhouses, listed property restorations, timber sash care, and central city maintenance.', href: '/areas-covered/central-bath-districts' },
];

const townAreas = [
  { name: 'Batheaston', descriptor: 'Local village property care, cottage modernizations, and ongoing domestic maintenance.', href: '/areas-covered/batheaston' },
  { name: 'Bathford', descriptor: 'Hillside stone cottage refurbishments, structural brickwork, and traditional masonry updates.', href: '/areas-covered/bathford' },
  { name: 'Bathampton', descriptor: 'Canalside home repairs, structural improvements, and high-quality internal finishes.', href: '/areas-covered/bathampton' },
  { name: 'Box', descriptor: 'Period property maintenance, lime mortar repointing, and historic valley-side home care.', href: '/areas-covered/box' },
  { name: 'Bradford on Avon', descriptor: 'Sympathetic heritage remodelling, lime repointing, and bespoke period joinery installations.', href: '/areas-covered/bradford-on-avon' },
  { name: 'Corsham', descriptor: 'Character cottage updates, historic stone masonry, and high-street standard finishes.', href: '/areas-covered/corsham' },
];

const marketAreas = [
  { name: 'Saltford & Keynsham', descriptor: 'Modern side-return and rear extensions, garage conversions, and open-plan living upgrades.', href: '/areas-covered/saltford-keynsham' },
  { name: 'Chippenham', descriptor: 'Full-scale modern home modernizations, open-plan structural knock-throughs, and structural additions.', href: '/areas-covered/chippenham' },
  { name: 'Frome, Radstock & Midsomer Norton', descriptor: 'Sloped garden landscaping, terraced property updates, and complete structural renovations.', href: '/areas-covered/frome-radstock-midsomer-norton' },
];
---

<Base title="Builders Across Bath & West Wiltshire"
  description="Building services across Bath, Bradford on Avon, Keynsham, Corsham, Frome and surrounding areas. Loft conversions, extensions, heritage and maintenance."
  preloadImage="/images/hero-bath-landscaping.webp">
  {/* ── Hero ── */}
  <Hero
    image="/images/hero-bath-landscaping.webp"
    overlay="left"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Locations' }]}
    eyebrow="Across Bath & West Wiltshire"
    heading="Builders & Property Maintenance"
    body="From historic city-centre restorations to modern family home extensions and complete garden transformations. Trusted, experienced, and fully insured local builders."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    minHeight="compact"
  />

  {/* ── Trust Bar ── */}
  <TrustMetrics
    metrics={[
      { value: 'Insured', label: 'Fully Insured' },
      { value: 'CSCS', label: 'Cardholders' },
      { value: 'City & Guilds', label: 'Qualified' },
      { value: 'Fixed', label: 'Transparent Pricing' },
      { value: 'Clean', label: 'Respect for Your Home' },
    ]}
  />

  {/* ── About Our Coverage ── */}
  <SplitFeature
    image="/images/medford-garden-extension-8.webp"
    imageAlt="Modern extension construction in Bath"
    eyebrow="Proudly Serving Bath, Somerset, and West Wiltshire"
    heading="Heritage Craft. Modern Construction. Local Knowledge."
    body="At Aspect Builds & Maintenance Ltd, we bridge the gap between traditional heritage building practices and modern construction excellence. Based locally, our team handles everything from complex period restorations in strict conservation zones to large-scale contemporary home extensions and landscaping. We understand the local housing stock, the regional planning guidelines, and the unique logistics required to deliver a clean, stress-free build."
    dark={false}
  />

  {/* ── Regional Coverage Network ── */}
  <section style="padding:0 0 var(--section-pad);background:var(--stone)">
    <div class="container">
      <SectionHeader
        eyebrow="Our Regional Coverage Network"
        heading="Where We Build"
        body="We have mapped out our core operational focus areas to align with local property types and architectural demands across county borders."
      />
      <LocationHub
        cityAreas={cityAreas}
        townAreas={townAreas}
        marketAreas={marketAreas}
      />
    </div>
  </section>

  {/* ── Core Expertise ── */}
  <SplitFeature
    image="/images/hero-medford-garden-extension.webp"
    imageAlt="Aspect construction project"
    heading="Our Core Expertise"
    body="Every Aspect project combines local knowledge with professional project management — fixed quotes, clean sites, and results that endure."
    dark={false}
    eyebrow="What We Deliver"
    list={[
      'Extensions & Conversions — single and double-storey extensions, garage conversions, open-plan structural modifications',
      'Renovations & Refurbishments — complete property updates including premium kitchens, luxury bathrooms, and damp remediation',
      'Traditional Stonework & Masonry — heritage stone care, lime mortar repointing, and structural wall repairs',
      'Property Maintenance & Repairs — minor works, roofing repairs, carpentry, painting, and general maintenance',
    ]}
    cta={{ label: 'View Our Services', href: '/services' }}
  />

  {/* ── The Guarantee ── */}
  <section style="background:var(--charcoal);padding:var(--section-pad) 0">
    <div class="container">
      <SectionHeader
        eyebrow="The Aspect Builds Guarantee"
        heading="Built on Trust. Delivered with Precision."
        dark={true}
      />
      <div class="guarantee-grid">
        <div class="guarantee-item">
          <span class="guarantee-item__rule"></span>
          <h3 class="guarantee-item__title">Fixed, Transparent Quotes</h3>
          <p class="guarantee-item__body">No hidden extras. We provide detailed, itemized cost breakdowns before any tools touch your property.</p>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-item__rule"></span>
          <h3 class="guarantee-item__title">Logistical Expertise</h3>
          <p class="guarantee-item__body">Whether navigating tight city-centre resident parking or narrow, winding village lanes, we manage all site logistics completely.</p>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-item__rule"></span>
          <h3 class="guarantee-item__title">Clean & Respectful Sites</h3>
          <p class="guarantee-item__body">Our teams treat your home with the utmost care, keeping worksites clean, organized, and tidy from day one until handover.</p>
        </div>
        <div class="guarantee-item">
          <span class="guarantee-item__rule"></span>
          <h3 class="guarantee-item__title">Direct Communication</h3>
          <p class="guarantee-item__body">Clear, open channels. You will always have a direct point of contact for daily progress updates.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <ImageCTA
    heading="Ready to Start Planning Your Next Project?"
    body="Whether you need minor property maintenance in Bathford or a major home extension in Keynsham, get in touch today to arrange a free, transparent site consultation."
    cta={{ label: 'Arrange a Consultation', href: '/contact' }}
    image="/images/hero-bath-landscaping.webp"
    imagePosition="center 60%"
  />
</Base>

<style>
  /* ── Guarantee grid (dark section) ── */
  .guarantee-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .guarantee-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .guarantee-item__rule {
    display: block;
    width: 32px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 0.25rem;
  }

  .guarantee-item__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.3vw, 1.5rem);
    line-height: 1.1;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .guarantee-item__body {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
  }

  @media (max-width: 960px) {
    .guarantee-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .guarantee-grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
</style>