---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import { locationsDatabase } from '../../data/locations';
import TrustMetrics from '../../components/TrustMetrics.astro';

export function getStaticPaths() {
  const districts = locationsDatabase.filter(
    loc => loc.group === 'bath-district' || loc.group === 'bristol-district'
  );
  return districts.map(loc => ({ params: { slug: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;

const isBristol = loc.group === 'bristol-district';
const parentLabel = isBristol ? 'Patio Cleaning Bristol' : 'Patio Cleaning Bath';
const parentHref  = isBristol ? '/patio-cleaning-bristol' : '/patio-cleaning-bath';
const hubLabel    = isBristol ? 'Bristol' : 'Bath';
const hubHref     = isBristol ? '/bristol' : '/services';

const title       = `Patio Cleaning ${loc.townName} | Jet Washing ${loc.townName}`;
const description = `Professional patio cleaning in ${loc.townName}. Indian sandstone, porcelain, concrete and block paving jet washed, biocide treated and restored. 111 five-star reviews. Call 07474 939 398.`;

const localContext = loc.serviceContext['patio-cleaning'] || `Professional patio jet washing in ${loc.townName} — Indian sandstone, porcelain, concrete and block paving cleaned and restored.`;

const faqs = [
  {
    q: `Do you cover ${loc.townName}?`,
    a: `Yes. ${loc.townName} is one of our regular service areas. We cover all streets and postcodes within ${loc.townName} and the surrounding area. Call 07474 939 398 to confirm coverage and arrange a free quote.`,
  },
  {
    q: `How much does patio cleaning cost in ${loc.townName}?`,
    a: `Patio cleaning in ${loc.townName} typically starts from around £3 per square metre depending on surface type, condition and access. We provide free, no-obligation on-site quotes — call 07474 939 398 or use our contact form.`,
  },
  {
    q: `Will jet washing damage my Indian sandstone in ${loc.townName}?`,
    a: `Not when done correctly. We adjust pressure to suit the stone — sandstone is softer than concrete and requires a lower pressure and wider fan angle. We never use a pin-point lance on natural stone. The result is a thorough clean without etching or surface damage.`,
  },
  {
    q: `How long does patio cleaning take in ${loc.townName}?`,
    a: `A standard patio (around 20–30m²) takes 2–3 hours. Larger areas, heavily soiled surfaces or patios with black spot lichen may take longer. We will give you a time estimate when we visit to quote.`,
  },
  {
    q: `What is black spot and can you remove it from my patio in ${loc.townName}?`,
    a: `Black spot is caused by Gloeocapsa algae — a stubborn organism that penetrates porous stone and appears as dark circular marks. We treat it with a targeted biocide before pressure washing. Most black spot lifts completely, though severe or long-standing cases may require a second treatment.`,
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rgextremepressure.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": hubLabel, "item": `https://rgextremepressure.co.uk${hubHref}` },
    { "@type": "ListItem", "position": 3, "name": parentLabel, "item": `https://rgextremepressure.co.uk${parentHref}` },
    { "@type": "ListItem", "position": 4, "name": `Patio Cleaning ${loc.townName}`, "item": `https://rgextremepressure.co.uk/patio-cleaning/${loc.slug}` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Patio Cleaning ${loc.townName}`,
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" },
  },
  "areaServed": {
    "@type": "Place",
    "name": loc.townName,
    "geo": { "@type": "GeoCoordinates", "latitude": loc.lat, "longitude": loc.lng },
  },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" },
};
---

<Base {title} {description} serviceSchema={serviceSchema}>
  <Hero
    image="/images/before-after/patio-after.jpg"
    overlay="blue"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: hubLabel, href: hubHref },
      { label: parentLabel, href: parentHref },
      { label: loc.townName },
    ]}
    eyebrow={`Patio Cleaning ${loc.townName}`}
    heading={`Patio Cleaning in ${loc.townName}`}
    body={`Professional jet washing restores ${loc.townName} patios to like-new condition. Indian sandstone, porcelain, concrete and block paving — cleaned, biocide treated and optionally sealed. 111 five-star reviews. Free quotes.`}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">

          <SectionHeader
            eyebrow={`Patio Cleaning · ${loc.townName}`}
            heading={`Professional Patio Jet Washing in ${loc.townName}`}
            body={localContext}
          />

          <div class="service-intro-image">
            <img src="/images/before-after/patio-after.jpg" alt={`Patio restored after professional jet washing in ${loc.townName}`} loading="lazy" />
          </div>

          <div class="service-features">
            <h3 class="service-features__title">What's Included</h3>
            <ul class="features-grid">
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Indian Sandstone Clean</strong>
                  <p class="feature-card__body">Low-to-medium pressure wash safe for porous natural stone — no etching or surface damage.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Porcelain & Slate Clean</strong>
                  <p class="feature-card__body">Higher pressure safe for dense porcelain and slate — removes surface algae and soiling completely.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Black Spot Treatment</strong>
                  <p class="feature-card__body">Targeted biocide applied to Gloeocapsa algae before washing — lifts stubborn black spot marks.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Algae & Moss Removal</strong>
                  <p class="feature-card__body">Rotary surface cleaner delivers even pressure — no streaking or line marks across the slab.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Joint & Border Clean</strong>
                  <p class="feature-card__body">Weed growth removed from joints; borders and edging cleaned with a hand lance.</p>
                </div>
              </li>
              <li class="feature-card">
                <div class="feature-card__icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <strong class="feature-card__title">Post-Clean Biocide</strong>
                  <p class="feature-card__body">Applied after washing to kill remaining spores and slow algae regrowth significantly.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <p class="inline-cta__text">Ready to get your patio back in {loc.townName}? Get a free, no-obligation quote today.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ul class="process-steps">
              <li class="process-step">
                <div class="process-step__badge">1</div>
                <div><strong>Free Assessment</strong><p>We identify stone type, condition and any black spot or lichen before quoting.</p></div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">2</div>
                <div><strong>Pre-Treatment</strong><p>Biocide applied to algae and black spot staining, allowed to dwell before washing.</p></div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">3</div>
                <div><strong>Pressure Cleaning</strong><p>Rotary surface cleaner at the right pressure for your patio material — no streaks.</p></div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">4</div>
                <div><strong>Edge Detailing</strong><p>Hand lance used for borders, steps and any areas the surface cleaner can't reach.</p></div>
              </li>
              <li class="process-step">
                <div class="process-step__badge">5</div>
                <div><strong>Final Inspection</strong><p>We walk the job with you before we leave — no surprises, no shortcuts.</p></div>
              </li>
            </ul>
          </div>

          <div class="inline-cta">
            <p class="inline-cta__text">Slippery patio or green sandstone in {loc.townName}? We can usually quote within 24 hours.</p>
            <a href="tel:07474939398" class="btn btn--secondary">Call 07474 939 398</a>
          </div>

        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Get Your Patio Restored</h3>
            <p class="sidebar-card__body">Free, no-obligation quotes in {loc.townName} and surrounding areas. Call or use the contact form.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Services in {loc.townName}</span>
            <h3 class="sidebar-card__heading">Also Available Here</h3>
            <ul class="sidebar-links">
              <li><a href={`/driveway-cleaning/${loc.slug}`}>Driveway Cleaning {loc.townName}</a></li>
              <li><a href={`/roof-cleaning/${loc.slug}`}>Roof Cleaning {loc.townName}</a></li>
              <li><a href={`/areas-covered/${loc.slug}`}>All Services in {loc.townName}</a></li>
              <li><a href={parentHref}>{parentLabel}</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="before-after-section">
    <div class="container">
      <SectionHeader eyebrow="See the Difference" heading="Before and After" body={`Real results from patio cleaning jobs near ${loc.townName}.`} align="center" />
      <div class="before-after-wrap">
        <BeforeAfter
          beforeSrc="/images/before-after/patio-before.jpg"
          afterSrc="/images/before-after/patio-after.jpg"
          beforeAlt="Patio before professional cleaning — algae, moss and black spot"
          afterAlt="Patio restored after jet washing — clean surface"
          caption="Patio cleaning — full algae, moss and black spot removed"
        />
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading={`Patio Cleaning ${loc.townName} FAQ`} />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q"><span>{faq.q}</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ImageCTA
    heading={`Patio Cleaning in ${loc.townName}`}
    body={`Free, no-obligation quotes from a fully insured, five-star-rated jet washing service. Covering ${loc.townName} and all surrounding areas. Call 07474 939 398.`}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/patio-after.jpg"
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
  .service-body__grid { display: grid; grid-template-columns: 7fr 4fr; gap: var(--space-3xl, 5rem); align-items: start; }

  .service-intro-image { margin-top: var(--space-2xl); border-radius: 10px; overflow: hidden; }
  .service-intro-image img { width: 100%; display: block; aspect-ratio: 16/9; object-fit: cover; }

  .service-features { margin-top: var(--space-2xl); }
  .service-features__title { font-family: var(--font-display); font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0 0 var(--space-m); }
  .features-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-m); }
  .feature-card { display: flex; gap: var(--space-m); align-items: flex-start; background: var(--stone); border-radius: 8px; padding: var(--space-l); border-top: 3px solid var(--accent); }
  .feature-card__icon { flex-shrink: 0; width: 2.5rem; height: 2.5rem; background: var(--accent); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; }
  .feature-card__title { display: block; font-family: var(--font-display); font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--chalk); margin-bottom: 0.3rem; }
  .feature-card__body { font-size: 0.88rem; line-height: 1.6; color: var(--concrete); margin: 0; }

  .inline-cta { margin-top: var(--space-2xl); border-radius: 10px; background: linear-gradient(135deg, var(--navy) 0%, var(--accent-dim) 100%); padding: var(--space-xl) var(--space-2xl); display: flex; align-items: center; justify-content: space-between; gap: var(--space-l); flex-wrap: wrap; }
  .inline-cta__text { font-family: var(--font-display); font-size: clamp(1rem, 1.5vw, 1.2rem); color: #fff; margin: 0; line-height: 1.3; }

  .service-process { margin-top: var(--space-3xl); }
  .process-steps { list-style: none; padding: 0; margin: var(--space-l) 0 0; display: flex; flex-direction: column; gap: 0; }
  .process-step { display: flex; gap: var(--space-l); align-items: flex-start; position: relative; padding-bottom: var(--space-l); }
  .process-step:not(:last-child)::after { content: ''; position: absolute; left: 1.5rem; top: 3rem; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--accent), rgba(0,85,165,0.1)); }
  .process-step__badge { flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 50%; background: var(--accent); color: #fff; font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }
  .process-step strong { display: block; font-family: var(--font-display); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--chalk); margin-bottom: 0.25rem; }
  .process-step p { font-size: 0.92rem; line-height: 1.65; color: var(--concrete); margin: 0; }

  .service-body__sidebar { display: flex; flex-direction: column; gap: var(--space-xl); align-self: start; position: sticky; top: 6rem; }
  .sidebar-card { background: var(--stone); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-s); }
  .sidebar-card__heading { font-family: var(--font-display); font-size: clamp(1.1rem, 1.5vw, 1.4rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0; }
  .sidebar-card__body { font-size: 0.92rem; line-height: 1.7; color: var(--concrete); margin: 0; }
  .sidebar-card .btn { margin-top: var(--space-xs); align-self: flex-start; }
  .sidebar-card__phone { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 0.04em; color: var(--accent); text-decoration: none; margin-top: var(--space-xs); }
  .sidebar-card__phone svg { flex-shrink: 0; }
  .sidebar-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-links a { font-size: 0.9rem; color: var(--concrete); text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 0.3rem; }
  .sidebar-links a::before { content: '\2192'; color: var(--accent); font-size: 0.8rem; }
  .sidebar-links a:hover { color: var(--accent); }

  .before-after-section { padding: var(--section-pad) 0; background: var(--stone); }
  .before-after-wrap { max-width: 900px; margin: 0 auto; }

  .faq-section { padding: var(--section-pad) 0; background: var(--surface); }
  .faq-list { max-width: 72ch; display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid var(--stone); }
  .faq-item__q { font-family: var(--font-body); font-size: 1rem; font-weight: 500; line-height: 1.5; color: var(--chalk); padding: var(--space-m) 0; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: var(--space-s); }
  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q svg { flex-shrink: 0; color: var(--accent); transition: transform 0.2s; }
  .faq-item[open] .faq-item__q svg { transform: rotate(180deg); }
  .faq-item__a { font-size: 0.95rem; font-weight: 300; line-height: 1.75; color: var(--concrete); padding: 0 0 var(--space-m); max-width: 60ch; }

  @media (max-width: 960px) {
    .service-body__grid { grid-template-columns: 1fr; gap: var(--space-2xl); }
    .service-body__sidebar { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-l); }
    .features-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .service-body__sidebar { grid-template-columns: 1fr; }
    .inline-cta { flex-direction: column; align-items: flex-start; }
  }
</style>
