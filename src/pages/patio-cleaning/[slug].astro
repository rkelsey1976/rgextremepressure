---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ImageCTA from '../../components/ImageCTA.astro';
import { locationsDatabase } from '../../data/locations';
import TrustMetrics from '../../components/TrustMetrics.astro';

export function getStaticPaths() {
  const districts = locationsDatabase.filter(
    loc => loc.group === 'bath-district' || loc.group === 'bristol-district'
  );
  return districts.map(loc => ({ params: { slug: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;

const isBristol = loc.group === 'bristol-district';
const parentLabel = isBristol ? 'Patio Cleaning Bristol' : 'Patio Cleaning Bath';
const parentHref  = isBristol ? '/patio-cleaning-bristol' : '/patio-cleaning-bath';
const hubLabel    = isBristol ? 'Bristol' : 'Bath';
const hubHref     = isBristol ? '/bristol' : '/services';

const title       = `Patio Cleaning ${loc.townName} | Jet Washing Patios in ${loc.townName}`;
const description = `Professional patio cleaning in ${loc.townName}. Indian sandstone, porcelain, concrete and natural stone jet washed and restored. 111 five-star reviews. Call 07474 939 398.`;

const localContext = loc.serviceContext['patio-cleaning'] || `Professional patio jet washing in ${loc.townName} — Indian sandstone, porcelain, concrete slabs and natural stone cleaned and restored.`;

const faqs = [
  {
    q: `Do you clean patios in ${loc.townName}?`,
    a: `Yes. ${loc.townName} is one of our regular service areas. We clean all patio surface types — Indian sandstone, porcelain, concrete slabs and natural stone. Call 07474 939 398 for a free quote.`,
  },
  {
    q: `Will pressure washing damage my Indian sandstone patio in ${loc.townName}?`,
    a: `Not if done correctly. We reduce pressure for softer stones like sandstone and limestone, and always test a small area first. The key is experience — knowing when to use a surface cleaner, a fan lance, or a low-pressure soft wash approach for each material.`,
  },
  {
    q: `How much does patio cleaning cost in ${loc.townName}?`,
    a: `Patio cleaning in ${loc.townName} typically starts from around £2.50–£3.50 per square metre depending on surface type and condition. We provide free, no-obligation on-site quotes — call 07474 939 398 or use our contact form.`,
  },
  {
    q: `How do you remove black spot algae from patios in ${loc.townName}?`,
    a: `Black spot (Gloeocapsa magna) requires specialist treatment — standard jet washing alone will not remove it. We pre-treat with a targeted biocide, allow dwell time, then use a rotary surface cleaner to lift the staining. Results vary depending on how deep the algae has penetrated, but in most cases we achieve a dramatic improvement.`,
  },
  {
    q: `How long does patio cleaning take in ${loc.townName}?`,
    a: `A typical patio (20–30m²) takes 2–3 hours. Larger areas or heavily soiled patios may take a full day. We will advise on timing at your free quote.`,
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://rgextremepressure.co.uk/" },
    { "@type": "ListItem", "position": 2, "name": hubLabel, "item": `https://rgextremepressure.co.uk${hubHref}` },
    { "@type": "ListItem", "position": 3, "name": parentLabel, "item": `https://rgextremepressure.co.uk${parentHref}` },
    { "@type": "ListItem", "position": 4, "name": `Patio Cleaning ${loc.townName}`, "item": `https://rgextremepressure.co.uk/patio-cleaning/${loc.slug}` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Patio Cleaning ${loc.townName}`,
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "RG Extreme Pressure",
    "telephone": "+447474939398",
    "address": { "@type": "PostalAddress", "addressLocality": "Bath", "addressRegion": "Somerset" },
  },
  "areaServed": {
    "@type": "Place",
    "name": loc.townName,
    "geo": { "@type": "GeoCoordinates", "latitude": loc.lat, "longitude": loc.lng },
  },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "111" },
};
---

<Base {title} {description} serviceSchema={serviceSchema}>
  <Hero
    image="/images/before-after/roof-after-2.webp"
    overlay="blue"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: hubLabel, href: hubHref },
      { label: parentLabel, href: parentHref },
      { label: loc.townName },
    ]}
    eyebrow={`Patio Cleaning ${loc.townName}`}
    heading={`Patio Cleaning in ${loc.townName}`}
    body={`Restore your ${loc.townName} patio to its original colour and texture. We clean all surface types — Indian sandstone, porcelain, concrete slabs and natural stone — with pressure adjusted to protect each material. 111 five-star reviews. Free quotes.`}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
  minHeight="compact"
  />

  <TrustMetrics metrics={[
    { value: '111', label: 'Five-Star Reviews' },
    { value: '10', label: 'Years Experience' },
    { value: 'Insured', label: 'Fully Insured' },
    { value: 'Free', label: 'Free Quotes' },
  ]} />

  <section class="service-body">
    <div class="container">
      <div class="service-body__grid">
        <div class="service-body__main">

          <SectionHeader
            eyebrow={`Patio Cleaning · ${loc.townName}`}
            heading={`Professional Patio Jet Washing in ${loc.townName}`}
            body={localContext}
          />

          <div class="service-features">
            <h3 class="service-features__title">What's Included</h3>
            <ul class="service-features__list">
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Surface assessment</strong> — we identify stone type and condition before choosing the right cleaning method</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Black spot pre-treatment</strong> — targeted biocide applied to break down Gloeocapsa algae before washing</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Rotary surface cleaning</strong> — even pressure across the full slab area, no streaking or line marks</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Joint weed removal</strong> — weed growth removed from between slabs or paving</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Edge and border clean</strong> — borders, edging and surrounding areas cleaned as part of the job</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Post-clean biocide treatment</strong> — slows algae and moss regrowth to extend the clean result</span>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Optional sealant</strong> — penetrating or surface sealant to protect stone and inhibit future growth</span>
              </li>
            </ul>
          </div>

          <div class="service-process">
            <SectionHeader eyebrow="Our Process" heading="How It Works" />
            <ol class="process-steps">
              <li><strong>Free site visit</strong> — we assess surface type, condition and any problem areas including black spot</li>
              <li><strong>Pre-treatment</strong> — biocide applied to algae and stubborn staining, allowed to dwell</li>
              <li><strong>Pressure cleaning</strong> — rotary surface cleaner at the right pressure for your patio material</li>
              <li><strong>Edge detailing</strong> — hand lance used for borders, steps and hard-to-reach areas</li>
              <li><strong>Final inspection</strong> — we walk the job with you before we leave</li>
            </ol>
          </div>

        </div>

        <aside class="service-body__sidebar">
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">Free Quote</span>
            <h3 class="sidebar-card__heading">Get Your Patio Restored</h3>
            <p class="sidebar-card__body">Free, no-obligation quotes in {loc.townName} and surrounding areas. Call or use the contact form.</p>
            <a href="/contact" class="btn btn--primary">Get a Free Quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="tel:07474939398" class="sidebar-card__phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg> 07474 939 398</a>
          </div>
          </div>
          <div class="sidebar-card">
            <span class="rule--accent"></span>
            <span class="t-label" style="color:var(--accent)">More Services in {loc.townName}</span>
            <h3 class="sidebar-card__heading">Also Available Here</h3>
            <ul class="sidebar-links">
              <li><a href={`/driveway-cleaning/${loc.slug}`}>Driveway Cleaning {loc.townName}</a></li>
              <li><a href={`/roof-cleaning/${loc.slug}`}>Roof Cleaning {loc.townName}</a></li>
              <li><a href={`/areas-covered/${loc.slug}`}>All Services in {loc.townName}</a></li>
              <li><a href={parentHref}>{parentLabel}</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <SectionHeader eyebrow="Common Questions" heading={`Patio Cleaning ${loc.townName} FAQ`} />
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ImageCTA
    heading={`Patio Cleaning in ${loc.townName}`}
    body={`Free, no-obligation quotes from a fully insured, five-star-rated jet washing service. Covering ${loc.townName} and all surrounding areas. Call 07474 939 398.`}
    cta={{ label: 'Get a Free Quote', href: '/contact' }}
    image="/images/before-after/roof-after-2.webp"
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>

<style>
  .service-body { padding: var(--section-pad) 0; }
  .service-body__grid { display: grid; grid-template-columns: 7fr 4fr; gap: var(--space-3xl, 5rem); align-items: start; }
  .service-features { margin-top: var(--space-2xl); }
  .service-features__title { font-family: var(--font-display); font-size: clamp(1.3rem, 2vw, 1.8rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0 0 var(--space-m); }
  .service-features__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-m); }
  .service-features__list li { display: flex; align-items: flex-start; gap: var(--space-s); font-size: 0.95rem; line-height: 1.7; color: var(--concrete); }
  .service-features__list li svg { flex-shrink: 0; margin-top: 0.35em; }
  .service-features__list li strong { color: var(--chalk); }
  .service-process { margin-top: var(--space-3xl); }
  .process-steps { list-style: none; padding: 0; margin: 0; counter-reset: step; display: flex; flex-direction: column; gap: var(--space-m); }
  .process-steps li { counter-increment: step; display: flex; align-items: flex-start; gap: var(--space-s); font-size: 0.95rem; line-height: 1.7; color: var(--concrete); }
  .process-steps li::before { content: counter(step); font-family: var(--font-display); font-size: 1.8rem; line-height: 1; color: var(--accent); flex-shrink: 0; min-width: 2rem; }
  .process-steps li strong { color: var(--chalk); }
  .service-body__sidebar { display: flex; flex-direction: column; gap: var(--space-xl); position: sticky; top: 6rem; }
  .sidebar-card { background: var(--stone); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-s); }
  .sidebar-card__heading { font-family: var(--font-display); font-size: clamp(1.1rem, 1.5vw, 1.4rem); line-height: 1.1; text-transform: uppercase; color: var(--chalk); margin: 0; }
  .sidebar-card__body { font-size: 0.92rem; line-height: 1.7; color: var(--concrete); margin: 0; }
  .sidebar-card .btn { margin-top: var(--space-xs); align-self: flex-start; }
  .sidebar-card__phone { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 0.04em; color: var(--accent); text-decoration: none; margin-top: var(--space-xs); }
  .sidebar-card__phone svg { flex-shrink: 0; }
  .sidebar-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .sidebar-links a { font-size: 0.9rem; color: var(--concrete); text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 0.3rem; }
  .sidebar-links a::before { content: '\2192'; color: var(--accent); font-size: 0.8rem; }
  .sidebar-links a:hover { color: var(--accent); }
  .faq-section { padding: var(--section-pad) 0; background: var(--surface); }
  .faq-list { max-width: 72ch; display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid var(--stone); }
  .faq-item__q { font-family: var(--font-body); font-size: 1rem; font-weight: 500; line-height: 1.5; color: var(--chalk); padding: var(--space-m) 0; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; }
  .faq-item__q::-webkit-details-marker { display: none; }
  .faq-item__q::after { content: '+'; font-family: var(--font-display); font-size: 1.5rem; color: var(--accent); flex-shrink: 0; margin-left: var(--space-s); }
  .faq-item[open] .faq-item__q::after { content: '\2212'; }
  .faq-item__a { font-size: 0.95rem; font-weight: 300; line-height: 1.75; color: var(--concrete); padding: 0 0 var(--space-m); max-width: 60ch; }
  @media (max-width: 960px) { .service-body__grid { grid-template-columns: 1fr; gap: var(--space-2xl); } .service-body__sidebar { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-l); } }
  @media (max-width: 640px) { .service-body__sidebar { grid-template-columns: 1fr; } }
</style>
