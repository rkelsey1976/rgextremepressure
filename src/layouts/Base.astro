---
// Base layout — shared <head>, nav, footer for all Aspect Builds pages
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  preloadImage?: string;
  ogImage?: string;
  bodyClass?: string;
  serviceSchema?: Record<string, unknown>;
}

const {
  title,
  description = 'Bath builders specialising in loft conversions, house extensions, heritage restoration and property maintenance. Fixed quotes, clean sites, fully insured.',
  preloadImage,
  ogImage = '/images/hero-james-bath-property-1.webp',
  bodyClass,
  serviceSchema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL   = new URL(ogImage, Astro.site);
---

