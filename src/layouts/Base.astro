---
// Base layout — shared <head>, nav, footer for all RG Extreme Pressure pages
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  preloadImage?: string;
  ogImage?: string;
  bodyClass?: string;
  serviceSchema?: Record<string, unknown>;
  faqSchema?: Record<string, unknown>;
  breadcrumbs?: { name: string; item: string }[];
  noindex?: boolean;
}

const {
  title,
  description = 'Professional jet washing and pressure washing in Bath and Bristol. Driveway cleaning, gutter clearing, roof cleaning, render cleaning. 111 five-star reviews. Call 07474 939 398.',
  preloadImage,
  ogImage = '/images/hero-home.webp',
  bodyClass,
  serviceSchema,
  faqSchema,
  breadcrumbs = [],
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL   = new URL(ogImage, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{title} | RG Extreme Pressure</title>
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0d1520" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="RG Extreme Pressure" />
  <meta property="og:title"       content={`${title} | RG Extreme Pressure`} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="en_GB" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={`${title} | RG Extreme Pressure`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />
  {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

  <!-- Google Analytics 4 — loaded only after cookie consent -->
  <script id="ga4-init" is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '');
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@400;500;600;700;800;900&display=swap" /></noscript>
